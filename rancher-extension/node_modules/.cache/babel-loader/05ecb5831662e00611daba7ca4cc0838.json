{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/pages/c/_cluster/settings/DefaultLinksEditor.vue?vue&type=template&id=bd132f66&scoped=true","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/pages/c/_cluster/settings/DefaultLinksEditor.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/pages/c/_cluster/settings/DefaultLinksEditor.vue"],"names":["t"],"mappings":";;qBA0CO,KAAK,EAAC,WAAW;qBACf,KAAK,EAAC,UAAU;qBAMhB,KAAK,EAAC,cAAc;qBAChB,KAAK,EAAC,YAAY;qBAGlB,KAAK,EAAC,YAAY;;;;;;wBAX7B,oBAoDM,OApDN,UAoDM;IAnDJ,oBAIM,OAJN,UAIM;MAHJ,oBAEK,6BADAA,MAAC;;;IAIR,oBA4CM,OA5CN,UA4CM;MA3CJ,oBAEQ,SAFR,UAEQ,mBADHA,MAAC;;MAEN,oBAEQ,SAFR,UAEQ,mBADHA,MAAC;;gCAEN,oBAA4B,WAArB,KAAK,EAAC,YAAY;;yBAEzB,oBAkCW,6BAjCS,YAAK,GAAf,GAAG,EAAC,CAAC;oEACP,CAAC;UAEP,oBAKM;YAJJ,KAAK,mBAAC,aAAa,mBACM,GAAG,CAAC,OAAO;;YAEpC,oBAA4B,+BAAnB,GAAG,CAAC,KAAK;;;UAGpB,oBAKM;YAJJ,KAAK,mBAAC,eAAe,mBACI,GAAG,CAAC,OAAO;;YAEpC,oBAA4B,+BAAnB,GAAG,CAAC,KAAK;;;YAIX,GAAG,CAAC,QAAQ,KAAK,eAAM;6BADhC,oBAYM;gBAVH,GAAG,EAAE,CAAC;gBACP,KAAK,EAAC,yBAAyB;;kBAGtB,eAAM;mCADf,aAME;;sBAJQ,KAAK,EAAE,GAAG,CAAC,OAAO;oDAAX,GAAG,CAAC,OAAO;sBAC1B,WAAS,EAAC,gCAAgC;sBACzC,aAAW,4BAA4B,CAAC;sBACxC,OAAK,aAAE,iBAAQ,CAAC,GAAG,EAAE,CAAC,EAAE,MAAM;;;;6BAGnC,oBAEE","sourcesContent":["<script>\nimport { _VIEW } from '@shell/config/query-params';\nimport { Checkbox } from '@components/Form/Checkbox';\n\nexport default {\n  name: 'DefaultLinksEditor',\n\n  emits: ['update:value'],\n\n  components: { Checkbox },\n\n  props: {\n    // Array of objects with key, label, value and enabled properties\n    value: {\n      type:    Array,\n      default: () => [],\n    },\n\n    mode: {\n      type:     String,\n      required: true\n    },\n  },\n\n  computed: {\n    isView() {\n      return this.mode === _VIEW;\n    }\n  },\n\n  methods: {\n    showhide(row, i, e) {\n      const value = this.value[i];\n\n      value['enabled'] = !!value.enabled;\n      this.$emit('update:value', this.value);\n    },\n  }\n};\n</script>\n\n<template>\n  <div class=\"key-value\">\n    <div class=\"clearfix\">\n      <h3>\n        {{ t('customLinks.settings.default') }}\n      </h3>\n    </div>\n\n    <div class=\"kv-container\">\n      <label class=\"text-label\">\n        {{ t('customLinks.settings.keyLabel') }}\n      </label>\n      <label class=\"text-label\">\n        {{ t('customLinks.settings.valueLabel') }}\n      </label>\n      <label class=\"text-label\" />\n\n      <template\n        v-for=\"(row,i) in value\"\n        :key=\"i\"\n      >\n        <div\n          class=\"kv-item key\"\n          :class=\"{'link-hidden': !row.enabled}\"\n        >\n          <span>{{ row.label }}</span>\n        </div>\n\n        <div\n          class=\"kv-item value\"\n          :class=\"{'link-hidden': !row.enabled}\"\n        >\n          <span>{{ row.value }}</span>\n        </div>\n\n        <div\n          v-if=\"!row.readonly && !isView\"\n          :key=\"i+'show'\"\n          class=\"link-show-hide-checkbox\"\n        >\n          <Checkbox\n            v-if=\"!isView\"\n            v-model:value=\"row.enabled\"\n            label-key=\"customLinks.settings.showLabel\"\n            :data-testid=\"`custom-links__checkbox-${i}`\"\n            @input=\"showhide(row, i, $event)\"\n          />\n        </div>\n        <div\n          v-else\n        />\n      </template>\n    </div>\n  </div>\n</template>\n\n<style lang=\"scss\" scoped>\n.key-value {\n  width: 100%;\n\n  .kv-container {\n    display: grid;\n    align-items: center;\n    grid-template-columns: 1fr 1fr 50px;\n    column-gap: $column-gutter;\n\n    .kv-item {\n      background-color: var(--disabled-bg);\n      border: 1px solid var(--border);\n      border-radius: 5px;\n      width: 100%;\n      margin: 10px 0px 10px 0px;\n      height: 40px;\n      line-height: 40px;\n      padding: 0 10px;\n\n      &.link-hidden {\n        color: var(--disabled-text);\n      }\n\n      &.key {\n        align-self: flex-start;\n      }\n    }\n  }\n}\n</style>\n"]}]}