AE,YAAK,CAAC,IAAI;kEAAV,YAAK,CAAC,IAAI;UACxB,IAAI,EAAE,WAAI;UACV,QAAQ,EAAE,eAAQ;UACnB,KAAK,EAAC,MAAM;UACX,KAAK,EAAEA,MAAC;;;;MAGb,oBAWM,OAXN,UAWM;QAVJ,aASE;UARQ,KAAK,EAAS,aAAI;kEAAJ,aAAI;0BAA1B,gBAA2B;UAC1B,IAAI,EAAE,WAAI;UACV,QAAQ,EAAE,eAAQ;UACnB,KAAK,EAAC,MAAM;UACZ,IAAI,EAAC,QAAQ;UACb,GAAG,EAAC,GAAG;UACP,GAAG,EAAC,OAAO;UACV,KAAK,EAAEA,MAAC;;;;;IAIf,oBAmBM,OAnBN,UAmBM;MAlBJ,oBAQM,OARN,UAQM;QAPJ,aAME;UALQ,KAAK,EAAS,YAAK,CAAC,SAAS;kEAAf,YAAK,CAAC,SAAS;0BAArC,gBAAsC;UACrC,IAAI,EAAE,WAAI;UACV,QAAQ,EAAE,eAAQ;UACnB,IAAI,EAAC,QAAQ;UACZ,KAAK,EAAEA,MAAC;;;;MAGb,oBAQM,OARN,UAQM;QAPJ,aAME;UALQ,KAAK,EAAS,YAAK,CAAC,GAAG;kEAAT,YAAK,CAAC,GAAG;0BAA/B,gBAAgC;UAC/B,IAAI,EAAE,WAAI;UACV,QAAQ,EAAE,eAAQ;UACnB,IAAI,EAAC,QAAQ;UACZ,KAAK,EAAEA,MAAC;;;;;gCAIf,oBAAsB,SAAjB,KAAK,EAAC,QAAQ;;IACnB,oBAIM,OAJN,WAIM;MAHJ,oBAEM,OAFN,WAEM;QADJ,oBAA8C,6BAAvCA,MAAC;;;;IAGZ,oBAUM,OAVN,WAUM;MATJ,oBAQM,OARN,WAQM;QAPJ,aAME;UALQ,KAAK,EAAE,YAAK,CAAC,MAAM,CAAC,IAAI;kEAAjB,YAAK,CAAC,MAAM,CAAC,IAAI;UAC/B,OAAO,EAAE,uBAAiB;UAC1B,IAAI,EAAE,WAAI;UACV,QAAQ,EAAE,eAAQ;UAClB,KAAK,EAAEA,MAAC;;;;;gCAIf,oBAAsB,SAAjB,KAAK,EAAC,QAAQ;;IACnB,oBAIM,OAJN,WAIM;MAHJ,oBAEM,OAFN,WAEM;QADJ,oBAAkD,6BAA3CA,MAAC;;;;IAGZ,oBAWM,OAXN,WAWM;MAVJ,oBASM,OATN,WASM;QARJ,aAOE;UANQ,KAAK,EAAE,YAAK,CAAC,QAAQ;kEAAd,YAAK,CAAC,QAAQ;UAC5B,mBAAiB,EAAEA,MAAC;UACpB,IAAI,EAAE,WAAI;UACV,SAAS,EAAE,gBAAS;UACpB,QAAQ,EAAE,eAAQ;UAClB,mBAAiB,EAAE,IAAI","sourcesContent":["<script>\nimport { LabeledInput } from '@components/Form/LabeledInput';\nimport SecretSelector from '@shell/components/form/SecretSelector';\nimport { updatePort } from './utils';\nimport LabeledSelect from '@shell/components/form/LabeledSelect';\n\nexport default {\n  components: {\n    LabeledInput, LabeledSelect, SecretSelector\n  },\n  props: {\n    value: {\n      type:    Object,\n      default: () => {\n        return {};\n      }\n    },\n    disabled: {\n      type:    Boolean,\n      default: false\n    },\n    mode: {\n      type:     String,\n      required: true,\n    },\n    namespace: {\n      type:     String,\n      required: true\n    }\n  },\n  data() {\n    const formatTypeOptions = ['json', 'out_file', 'ltsv', 'csv', 'msgpack', 'hash', 'single_value'];\n\n    this.value['format'] = this.value.format || { type: formatTypeOptions[0] };\n\n    return { formatTypeOptions };\n  },\n  computed: {\n    port: {\n      get() {\n        return this.value.port;\n      },\n      set(port) {\n        updatePort((value) => (this.value.port = value), port);\n      }\n    }\n  }\n};\n</script>\n\n<template>\n  <div class=\"opensearch\">\n    <div class=\"row\">\n      <div class=\"col span-6\">\n        <h3>{{ t('logging.output.sections.target') }}</h3>\n      </div>\n    </div>\n    <div class=\"row mb-10\">\n      <div class=\"col span-8\">\n        <LabeledInput\n          v-model:value=\"value.host\"\n          :mode=\"mode\"\n          :disabled=\"disabled\"\n          class=\"host\"\n          :label=\"t('logging.redis.host')\"\n        />\n      </div>\n      <div class=\"col span-2\">\n        <LabeledInput\n          v-model:value.number=\"port\"\n          :mode=\"mode\"\n          :disabled=\"disabled\"\n          class=\"port\"\n          type=\"number\"\n          min=\"1\"\n          max=\"65535\"\n          :label=\"t('logging.redis.port')\"\n        />\n      </div>\n    </div>\n    <div class=\"row\">\n      <div class=\"col span-6\">\n        <LabeledInput\n          v-model:value.number=\"value.db_number\"\n          :mode=\"mode\"\n          :disabled=\"disabled\"\n          type=\"number\"\n          :label=\"t('logging.redis.dbNumber')\"\n        />\n      </div>\n      <div class=\"col span-6\">\n        <LabeledInput\n          v-model:value.number=\"value.ttl\"\n          :mode=\"mode\"\n          :disabled=\"disabled\"\n          type=\"number\"\n          :label=\"t('logging.redis.ttl')\"\n        />\n      </div>\n    </div>\n    <div class=\"spacer\" />\n    <div class=\"row\">\n      <div class=\"col span-6\">\n        <h3>{{ t('logging.redis.format.title') }}</h3>\n      </div>\n    </div>\n    <div class=\"row mb-10\">\n      <div class=\"col span-6\">\n        <LabeledSelect\n          v-model:value=\"value.format.type\"\n          :options=\"formatTypeOptions\"\n          :mode=\"mode\"\n          :disabled=\"disabled\"\n          :label=\"t('logging.redis.format.type')\"\n        />\n      </div>\n    </div>\n    <div class=\"spacer\" />\n    <div class=\"row\">\n      <div class=\"col span-6\">\n        <h3>{{ t('logging.output.sections.access') }}</h3>\n      </div>\n    </div>\n    <div class=\"row\">\n      <div class=\"col span-6\">\n        <SecretSelector\n          v-model:value=\"value.password\"\n          :secret-name-label=\"t('logging.elasticsearch.password')\"\n          :mode=\"mode\"\n          :namespace=\"namespace\"\n          :disabled=\"disabled\"\n          :show-key-selector=\"true\"\n        />\n      </div>\n    </div>\n  </div>\n</template>\n<style>\n.row {\n  margin-bottom: 5px;\n}\n</style>\n"]}]}