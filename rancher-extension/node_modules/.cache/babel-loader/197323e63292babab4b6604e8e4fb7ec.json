jBR,UAiBQ;YAbN,oBAYQ;iCAXN,oBAUK,6BATgB,UAAG,CAAC,UAAU,GAAzB,GAAG,EAAE,CAAC;sCADhB,oBAUK,QARF,GAAG,EAAE,CAAC;kBAEP,oBAEK;oBAFA,KAAK,uCAAuB,GAAG,CAAC,SAAS;sCACzC,GAAG,CAAC,KAAK;;kBAEd,oBAEK,MAFL,UAEK,mBADA,GAAG,CAAC,KAAK;;;;;;;sBA5DtB,CAyBO;MAzBP,oBAyBO;SAvBG,UAAG,CAAC,YAAY;2BADxB,aAGE;;cADC,MAAM,EAAE,UAAG,CAAC,UAAU;;;;SAGjB,UAAG,CAAC,MAAM,IAAI,UAAG,CAAC,MAAM,CAAC,MAAM;2BADvC,oBAGW,KAHX,UAGW,EAAV,QAAM;2BACP,oBAeO,QAfP,UAeO;gDAXF,UAAG,CAAC,MAAM,CAAC,OAAO,IAAG,GACxB;eACQ,UAAG,CAAC,MAAM,CAAC,IAAI;iCADvB,oBAKM,OALN,UAKM,EAFL,eACE,oBAAG,UAAG,CAAC,MAAM,CAAC,OAAO,IAAG,aAC3B;mBACiB,UAAG,CAAC,gBAAgB;mCAArC,oBAGO;gDAFL,oBAAqC,OAAlC,KAAK,EAAC,yBAAyB;uCAAG,GACrC,oBAAG,UAAG,CAAC,MAAM,CAAC,OAAO","sourcesContent":["<script>\nimport ProgressBarMulti from '@shell/components/ProgressBarMulti';\n\nexport default {\n  components: { ProgressBarMulti },\n\n  props: {\n    row: {\n      type:     Object,\n      required: true\n    },\n\n    col: {\n      type:    Object,\n      default: null\n    }\n  },\n\n  computed: {\n    canAdjust() {\n      const row = this.row;\n\n      if ( !row.scales ) {\n        return false;\n      }\n\n      if ( row.scales.global || row.scales.auto ) {\n        return false;\n      }\n\n      return true;\n    },\n\n    showHover() {\n      return this.row.complexScale || this.canAdjust;\n    }\n  },\n\n  methods: {\n    scaleDown() {\n      this.row.scaleDown();\n    },\n\n    scaleUp() {\n      this.row.scaleUp();\n    },\n  },\n};\n</script>\n\n<template>\n  <v-dropdown\n    :class=\"{'hand': showHover}\"\n    placement=\"top\"\n    :show-group=\"row.id\"\n    :triggers=\"showHover ? ['click'] : []\"\n    offset=\"1\"\n  >\n    <span>\n      <ProgressBarMulti\n        v-if=\"row.complexScale\"\n        :values=\"row.scaleParts\"\n      />\n      <p\n        v-if=\"row.scales && row.scales.global\"\n        class=\"scale\"\n      >Global</p>\n      <span\n        v-else\n        class=\"scale\"\n      >\n        {{ row.scales.current }}\n        <div\n          v-if=\"row.scales.auto\"\n          class=\"text-small text-muted\"\n        >\n          ({{ row.scales.desired }})\n        </div>\n        <span v-else-if=\"row.showDesiredScale\">\n          <i class=\"icon icon-chevron-right\" />\n          {{ row.scales.desired }}\n        </span>\n      </span>\n    </span>\n\n    <template #popper>\n      <div\n        v-if=\"canAdjust\"\n        class=\"text-center pb-5\"\n      >\n        <button\n          type=\"button\"\n          class=\"btn btn-sm bg-primary scale-btn\"\n          @click=\"scaleDown\"\n        >\n          <i class=\"icon icon-minus\" />\n        </button>\n        <button\n          type=\"button\"\n          class=\"btn btn-sm bg-primary scale-btn\"\n          @click=\"scaleUp\"\n        >\n          <i class=\"icon icon-plus\" />\n        </button>\n      </div>\n      <table\n        v-if=\"row.complexScale\"\n        class=\"fixed\"\n      >\n        <tbody>\n          <tr\n            v-for=\"(obj, i) in row.scaleParts\"\n            :key=\"i\"\n          >\n            <td :class=\"{'text-left': true, [obj.textColor]: true}\">\n              {{ obj.label }}\n            </td>\n            <td class=\"text-right\">\n              {{ obj.value }}\n            </td>\n          </tr>\n        </tbody>\n      </table>\n    </template>\n  </v-dropdown>\n</template>\n\n<style lang=\"scss\">\n  .col-scale {\n    position: relative;\n\n    .trigger {\n      width: 100%;\n    }\n  }\n\n  .scale {\n    margin: 0;\n    padding: 0;\n    line-height: initial;\n  }\n\n</style>\n"]}]}