AL,WAAK;gBAML,eAAM;;cALpB,IAAI,EAAE,WAAI;cACX,KAAK,EAAC,wBAAwB;cAC9B,WAAS,EAAC,gCAAgC;cAC1C,OAAO,EAAC,qKAAqK;cAC7K,aAAW,EAAC,kCAAkC;;;;UAIlD,oBAgBM;YAfJ,aAKE;cAJQ,KAAK,EAAEC,sBAAiB;;sDAAjBA,sBAAiB;gBAGjB,eAAM;;cAFpB,IAAI,EAAE,WAAI;cACX,WAAS,EAAC,8CAA8C;;;aAIlDA,sBAAiB;+BADzB,aAQE;;kBANQ,KAAK,EAAE,iBAAW;;0DAAX,iBAAW;oBAKX,eAAM;;kBAJpB,IAAI,EAAE,WAAI;kBACX,WAAS,EAAC,2CAA2C;kBACpD,MAAM,EAAED,MAAC,2BAA2B,aAAO;kBAC5C,KAAK,EAAC,OAAO;;;;;UAIjB,oBAgBM;YAfJ,aAKE;cAJQ,KAAK,EAAEE,kBAAa;;sDAAbA,kBAAa;gBAGb,eAAM;;cAFpB,IAAI,EAAE,WAAI;cACX,WAAS,EAAC,0CAA0C;;;aAI9CA,kBAAa;+BADrB,aAQE;;kBANQ,KAAK,EAAE,aAAO;;0DAAP,aAAO;oBAKP,eAAM;;kBAJpB,IAAI,EAAE,WAAI;kBACX,WAAS,EAAC,uCAAuC;kBAChD,MAAM,EAAEF,MAAC,2BAA2B,aAAO;kBAC5C,KAAK,EAAC,eAAe","sourcesContent":["<script>\nimport RadioGroup from '@components/Form/Radio/RadioGroup.vue';\nimport Checkbox from '@components/Form/Checkbox/Checkbox.vue';\nimport UnitInput from '@shell/components/form/UnitInput.vue';\nimport { mapGetters } from 'vuex';\n\nconst DEFAULTS = {\n  deleteEmptyDirData:              true, // Show; Kill pods using emptyDir volumes and lose the data\n  disableEviction:                 false, // Hide; false = evict pods, true = delete pods\n  enabled:                         false, // Show; true = Nodes must be drained before upgrade; false = YOLO\n  force:                           false, // Show; true = Delete standalone pods, false = fail if there are any\n  gracePeriod:                     -1, // Show; Pod shut down time, negative value uses pod default\n  ignoreDaemonSets:                true, // Hide; true = work, false = never work because there's always daemonSets\n  skipWaitForDeleteTimeoutSeconds: 0, // Hide; If the pod deletion time is older than this > 0, don't wait, for some reason\n  timeout:                         120, // Show; Give up after this many seconds\n};\n\nexport default {\n  emits: ['update:value'],\n\n  components: {\n    RadioGroup, Checkbox, UnitInput\n  },\n  props: {\n    value: {\n      type:    Object,\n      default: () => {},\n    },\n\n    mode: {\n      type:     String,\n      required: true,\n    }\n  },\n\n  data() {\n    return {\n      deleteEmptyDirData:              DEFAULTS.deleteEmptyDirData,\n      disableEviction:                 DEFAULTS.disableEviction,\n      enabled:                         DEFAULTS.enabled,\n      force:                           DEFAULTS.force,\n      gracePeriod:                     DEFAULTS.gracePeriod,\n      ignoreDaemonSets:                DEFAULTS.ignoreDaemonSets,\n      skipWaitForDeleteTimeoutSeconds: DEFAULTS.skipWaitForDeleteTimeoutSeconds,\n      timeout:                         DEFAULTS.timeout,\n    };\n  },\n\n  created() {\n    for ( const k in DEFAULTS ) {\n      if ( typeof this.value[k] === 'undefined' ) {\n        this.$data[k] = DEFAULTS[k];\n      } else {\n        this.$data[k] = this.value[k];\n      }\n    }\n\n    this.customGracePeriod = this.gracePeriod >= 0;\n    this.customTimeout = this.timeout >= 0;\n\n    this.update();\n  },\n\n  computed: { ...mapGetters({ t: 'i18n/t' }) },\n\n  methods: {\n    update() {\n      const out = {};\n\n      for ( const k in DEFAULTS ) {\n        out[k] = this[k];\n      }\n\n      if ( !this.customGracePeriod ) {\n        out.gracePeriod = -1;\n      }\n\n      if ( !this.customTimeout ) {\n        out.timeout = 0;\n      }\n\n      this.$emit('update:value', out);\n    },\n  },\n};\n</script>\n\n<template>\n  <div>\n    <RadioGroup\n      v-model:value=\"enabled\"\n      name=\"enabled\"\n      :options=\"[false, true]\"\n      :label=\"t('cluster.rke2.drain.label')\"\n      :labels=\"[t('generic.no'), t('generic.yes')]\"\n      :tooltip=\"t('cluster.rke2.drain.toolTip')\"\n      :mode=\"mode\"\n      @update:value=\"update\"\n    />\n\n    <template v-if=\"enabled\">\n      <div class=\"mt-20\">\n        <Checkbox\n          v-model:value=\"deleteEmptyDirData\"\n          :mode=\"mode\"\n          label-key=\"cluster.rke2.drain.deleteEmptyDir.label\"\n          tooltip-key=\"cluster.rke2.drain.deleteEmptyDir.tooltip\"\n          @update:value=\"update\"\n        />\n      </div>\n      <div>\n        <Checkbox\n          v-model:value=\"force\"\n          :mode=\"mode\"\n          label=\"Delete standalone pods\"\n          label-key=\"cluster.rke2.drain.force.label\"\n          tooltip=\"Delete standalone pods which are not managed by a Workload controller (Deployment, Job, etc).  Draining will fail if this is not set and there are standalone pods.\"\n          tooltop-key=\"cluster.rke2.drain.force.tooltip\"\n          @update:value=\"update\"\n        />\n      </div>\n      <div>\n        <Checkbox\n          v-model:value=\"customGracePeriod\"\n          :mode=\"mode\"\n          label-key=\"cluster.rke2.drain.gracePeriod.checkboxLabel\"\n          @update:value=\"update\"\n        />\n        <UnitInput\n          v-if=\"customGracePeriod\"\n          v-model:value=\"gracePeriod\"\n          :mode=\"mode\"\n          label-key=\"cluster.rke2.drain.gracePeriod.inputLabel\"\n          :suffix=\"t('suffix.seconds', {count: timeout})\"\n          class=\"mb-10\"\n          @update:value=\"update\"\n        />\n      </div>\n      <div>\n        <Checkbox\n          v-model:value=\"customTimeout\"\n          :mode=\"mode\"\n          label-key=\"cluster.rke2.drain.timeout.checkboxLabel\"\n          @update:value=\"update\"\n        />\n        <UnitInput\n          v-if=\"customTimeout\"\n          v-model:value=\"timeout\"\n          :mode=\"mode\"\n          label-key=\"cluster.rke2.drain.timeout.inputLabel\"\n          :suffix=\"t('suffix.seconds', {count: timeout})\"\n          class=\"drain-timeout\"\n          @update:value=\"update\"\n        />\n      </div>\n    </template>\n  </div>\n</template>\n\n<style lang=\"scss\" scoped>\n  $drain-timeout-index: 18px;\n\n  .drain-timeout {\n    margin-top: 5px;\n    margin-left: $drain-timeout-index;\n    width: calc(100% - $drain-timeout-index);\n  }\n</style>\n"]}]}