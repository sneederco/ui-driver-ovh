{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/dialog/DeactivateDriverDialog.vue?vue&type=template&id=158f1a33","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/dialog/DeactivateDriverDialog.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/dialog/DeactivateDriverDialog.vue"],"names":["t"],"mappings":";;qBA8EU,KAAK,EAAC,mBAAmB;qBAMxB,KAAK,EAAC,aAAa;qBACjB,KAAK,EAAC,uBAAuB;;;;;;;;wBAbxC,aAyCO;IAxCL,KAAK,EAAC,mBAAmB;IACxB,uBAAqB,EAAE,KAAK;IAC5B,aAAW,EAAE,mBAAmB;;IAEtB,KAAK,WACd,CAEK;MAFL,oBAEK,MAFL,UAEK,mBADAA,MAAC;;IAIG,IAAI,WACb,CAWM;MAXN,oBAWM,OAXN,UAWM;QAVJ,oBAEM,OAFN,UAEM;0BADJ,oBAAqC;oCAAjB,sBAAa;;;;2BAEnC,oBAME,6BALmB,YAAM,GAAjB,GAAG,EAAE,CAAC;gCADhB,aAME;YAJC,GAAG,EAAE,CAAC;YACP,KAAK,EAAC,OAAO;YACZ,KAAK,EAAE,GAAG;YACX,aAAW,EAAC,gCAAgC;;;;;IAKvC,OAAO,WAChB,CAKS;MALT,oBAKS;QAJP,KAAK,EAAC,oBAAoB;QACzB,OAAK,0CAAE,yCAAK;0BAEVA,MAAC;;gCAEN,oBAAsB,SAAjB,KAAK,EAAC,QAAQ;;MACnB,aAKE;QAJA,IAAI,EAAC,YAAY;QACjB,KAAK,EAAC,oBAAoB;QACzB,aAAW,EAAE,2BAA2B;QACxC,OAAK,EAAE,cAAK","sourcesContent":["<script>\nimport AsyncButton from '@shell/components/AsyncButton';\nimport { Card } from '@components/Card';\nimport { Banner } from '@components/Banner';\nimport { exceptionToErrorsArray } from '@shell/utils/error';\nimport { resourceNames } from '@shell/utils/string';\nimport { mapGetters } from 'vuex';\n\nexport default {\n  emits: ['close'],\n\n  components: {\n    Card,\n    AsyncButton,\n    Banner,\n  },\n\n  props: {\n    drivers: {\n      type:     Array,\n      required: true\n    },\n    driverType: {\n      type:     String,\n      required: true\n    }\n  },\n\n  data() {\n    return { errors: [] };\n  },\n  computed: {\n    formattedText() {\n      const driverNames = this.drivers.map((obj) => obj.nameDisplay);\n      const count = driverNames.length;\n      const remaining = driverNames.length > 5 ? driverNames.length - 5 : 0;\n\n      const plusMore = this.t('drivers.deactivate.andOthers', { count: remaining });\n      const names = resourceNames(driverNames, plusMore, this.t, false);\n      const warningDrivers = this.t('drivers.deactivate.warningDrivers', { names, count });\n\n      return this.t('drivers.deactivate.warning', { warningDrivers, count });\n    },\n    ...mapGetters({ t: 'i18n/t' }),\n  },\n  methods: {\n    resourceNames,\n    close(buttonDone) {\n      if (buttonDone && typeof buttonDone === 'function') {\n        buttonDone(true);\n      }\n      this.$emit('close');\n    },\n    async apply(buttonDone) {\n      try {\n        await Promise.all(this.drivers.map(\n          (driver) => this.$store.dispatch('rancher/request', {\n            url:    `v3/${ this.driverType }/${ escape(driver.id) }?action=deactivate`,\n            method: 'POST'\n          })\n        ));\n\n        this.close(buttonDone);\n      } catch (err) {\n        this.errors = exceptionToErrorsArray(err);\n        buttonDone(false);\n      }\n    }\n  }\n};\n</script>\n<template>\n  <Card\n    class=\"prompt-deactivate\"\n    :show-highlight-border=\"false\"\n    :data-testid=\"'prompt-deactivate'\"\n  >\n    <template #title>\n      <h4 class=\"text-default-text\">\n        {{ t('drivers.deactivate.title') }}\n      </h4>\n    </template>\n\n    <template #body>\n      <div class=\"pl-10 pr-10\">\n        <div class=\"text info mb-10 mt-20\">\n          <span v-clean-html=\"formattedText\" />\n        </div>\n        <Banner\n          v-for=\"(err, i) in errors\"\n          :key=\"i\"\n          color=\"error\"\n          :label=\"err\"\n          data-testid=\"deactivate-driver-error-banner\"\n        />\n      </div>\n    </template>\n\n    <template #actions>\n      <button\n        class=\"btn role-secondary\"\n        @click=\"close\"\n      >\n        {{ t('generic.cancel') }}\n      </button>\n      <div class=\"spacer\" />\n      <AsyncButton\n        mode=\"deactivate\"\n        class=\"btn bg-error ml-10\"\n        :data-testid=\"'deactivate-driver-confirm'\"\n        @click=\"apply\"\n      />\n    </template>\n  </Card>\n</template>\n\n<style lang='scss'>\n  .prompt-deactivate {\n    &.card-container {\n      box-shadow: none;\n    }\n    #confirm {\n      width: 90%;\n      margin-left: 3px;\n    }\n\n    .actions {\n      text-align: right;\n    }\n\n    .card-actions {\n      display: flex;\n\n      .spacer {\n        flex: 1;\n      }\n    }\n  }\n</style>\n"]}]}