O;sEAA7B,YAAK,CAAC,eAAe,CAAC,OAAO;cAC3C,KAAK,EAAEA,MAAC;;;;;OAIL,YAAK,CAAC,cAAc;yBAD5B,oBAQM,OARN,UAQM;YAJJ,aAGE;cAFQ,KAAK,EAAE,YAAK,CAAC,cAAc,CAAC,OAAO;sEAA5B,YAAK,CAAC,cAAc,CAAC,OAAO;cAC1C,KAAK,EAAEA,MAAC;;;;;;IAIf,oBA6BM,OA7BN,UA6BM;OA3BI,YAAK,CAAC,KAAK;yBADnB,oBASM,OATN,UASM;YALJ,aAIE;cAHQ,KAAK,EAAE,YAAK,CAAC,KAAK,CAAC,OAAO;sEAAnB,YAAK,CAAC,KAAK,CAAC,OAAO;cACjC,KAAK,EAAEA,MAAC;cACR,QAAQ,EAAE,YAAK,CAAC,KAAK,IAAI,YAAK,CAAC,KAAK,CAAC,OAAO;;;;;OAIzC,YAAK,CAAC,MAAM;yBADpB,oBAQM,OARN,UAQM;YAJJ,aAGE;cAFQ,KAAK,EAAE,YAAK,CAAC,MAAM,CAAC,OAAO;sEAApB,YAAK,CAAC,MAAM,CAAC,OAAO;cAClC,KAAK,EAAEA,MAAC;;;;;OAIL,YAAK,CAAC,SAAS;yBADvB,oBAQM,OARN,UAQM;YAJJ,aAGE;cAFQ,KAAK,EAAE,YAAK,CAAC,SAAS,CAAC,OAAO;sEAAvB,YAAK,CAAC,SAAS,CAAC,OAAO;cACrC,KAAK,EAAEA,MAAC;;;;;;IAIf,oBAqBM,OArBN,UAqBM;OAnBI,YAAK,CAAC,KAAK;yBADnB,oBASM,OATN,WASM;YALJ,aAIE;cAHQ,KAAK,EAAE,YAAK,CAAC,KAAK,CAAC,OAAO;;sDAAnB,YAAK,CAAC,KAAK,CAAC,OAAO;gBAEnB,oBAAW;;cADzB,KAAK,EAAEA,MAAC;;;;;OAKL,YAAK,CAAC,OAAO;yBADrB,oBAQM,OARN,WAQM;YAJJ,aAGE;cAFQ,KAAK,EAAE,YAAK,CAAC,OAAO,CAAC,OAAO;sEAArB,YAAK,CAAC,OAAO,CAAC,OAAO;cACnC,KAAK,EAAEA,MAAC;;;;;kCAGb,oBAA0B,SAArB,KAAK,EAAC,YAAY;;;KAGjB,qBAAe;uBADvB,oBAWM,OAXN,WAWM;UAPJ,oBAMM,OANN,WAMM;YALJ,aAIS,qBAJD,KAAK,EAAC,MAAM;gCAClB,CAEE;gCAFF,oBAEE;0CADcA,MAAC;;;;;;;;;IAMvB,oBAAiD,6BAA1CA,MAAC;;IACR,oBAiBM,OAjBN,WAiBM;MAhBJ,aAIS,qBAJD,KAAK,EAAC,MAAM;0BAClB,CAEE;0BAFF,oBAEE;oCADcA,MAAC;;;;;;MAGnB,aAKE;QAJA,GAAG,EAAC,aAAa;QACjB,KAAK,EAAC,mBAAmB;QACxB,KAAK,EAAE,iBAAW;QAClB,SAAO,EAAE,sBAAa;;;MAEzB,aAIE;QAHA,KAAK,EAAC,qBAAsB;QAC3B,KAAK,EAAEA,MAAC;QACR,UAAQ,EAAE,uBAAc","sourcesContent":["<script>\nimport debounce from 'lodash/debounce';\nimport jsyaml from 'js-yaml';\nimport { Checkbox } from '@components/Form/Checkbox';\nimport YamlEditor from '@shell/components/YamlEditor';\nimport { mapGetters } from 'vuex';\nimport FileSelector from '@shell/components/form/FileSelector';\nimport { Banner } from '@components/Banner';\n\nconst defaultOverlayFile = `#apiVersion: install.istio.io/v1alpha1\n#kind: IstioOperator\n#spec:\n#  components:\n#    ingressGateways:\n#    - enabled: true\n#      name: istio-ingressgateway\n#    - enabled: true\n#      k8s:\n#        resources:\n#          requests:\n#            cpu: 200m\n#        service:\n#          ports:\n#          - name: tcp-citadel-grpc-tls\n#            port: 8060\n#            targetPort: 8060\n#          - name: tcp-dns\n#            port: 5353\n#        serviceAnnotations:\n#          cloud.google.com/load-balancer-type: internal\n#      name: ilb-gateway\n#      namespace: user-ingressgateway-ns\n#    - enabled: true\n#      k8s:\n#        resources:\n#          requests:\n#            cpu: 200m\n#        service:\n#          ports:\n#          - name: tcp-citadel-grpc-tls\n#            port: 8060\n#            targetPort: 8060\n#          - name: tcp-dns\n#            port: 5353\n#        serviceAnnotations:\n#          cloud.google.com/load-balancer-type: internal\n#      name: other-gateway\n#      namespace: istio-system\n`;\n\nexport default {\n  emits: ['update:value'],\n\n  components: {\n    Checkbox,\n    FileSelector,\n    YamlEditor,\n    Banner\n  },\n\n  props: {\n    value: {\n      type:    Object,\n      default: () => {\n        return {};\n      }\n    }\n  },\n\n  data() {\n    let overlayFile = this.value.overlayFile;\n\n    if (!overlayFile?.length) {\n      overlayFile = defaultOverlayFile;\n    }\n\n    return {\n      overlayFile,\n      showKialiBanner: this.value.kiali?.enabled\n    };\n  },\n\n  computed: {\n    ...mapGetters(['currentCluster'], { t: 'i18n/t' }),\n    valuesYaml: {\n      get() {\n        try {\n          const yaml = jsyaml.dump(this.value);\n\n          return yaml;\n        } catch (e) {\n          return null;\n        }\n      },\n      set: debounce(function(neu) {\n        try {\n          const obj = jsyaml.load(neu);\n\n          Object.assign(this.value, obj);\n        } catch (e) {\n\n        }\n      }, 500)\n    },\n  },\n\n  methods: {\n    update() {\n      this.$emit('update:value', this.value);\n    },\n\n    valuesChanged(value) {\n      try {\n        jsyaml.load(value);\n        if (value === defaultOverlayFile) {\n          value = '';\n        } else {\n          this.overlayFile = value;\n        }\n        this.value.overlayFile = value;\n      } catch (e) {\n      }\n    },\n\n    onFileSelected(value) {\n      this.$refs['yaml-editor'].updateValue(value);\n    },\n\n    changeKiali(value) {\n      if (value && this.value.pilot) {\n        this.value.pilot.enabled = true;\n        this.showKialiBanner = true;\n      } else if (!value) {\n        this.showKialiBanner = false;\n      }\n    }\n  }\n};\n</script>\n\n<template>\n  <div>\n    <h3>\n      {{ t('istio.titles.components') }}\n    </h3>\n    <div class=\"row mb-10\">\n      <div\n        v-if=\"value.cni\"\n        class=\"col span-4\"\n      >\n        <Checkbox\n          v-model:value=\"value.cni.enabled\"\n          :label=\"t('istio.cni')\"\n          @update:value=\"update\"\n        />\n      </div>\n      <div\n        v-if=\"value.ingressGateways\"\n        class=\"col span-4\"\n      >\n        <Checkbox\n          v-model:value=\"value.ingressGateways.enabled\"\n          :label=\"t('istio.ingressGateway')\"\n        />\n      </div>\n      <div\n        v-if=\"value.egressGateways\"\n        class=\"col span-4\"\n      >\n        <Checkbox\n          v-model:value=\"value.egressGateways.enabled\"\n          :label=\"t('istio.egressGateway')\"\n        />\n      </div>\n    </div>\n    <div class=\"row mb-10\">\n      <div\n        v-if=\"value.pilot\"\n        class=\"col span-4\"\n      >\n        <Checkbox\n          v-model:value=\"value.pilot.enabled\"\n          :label=\"t('istio.pilot')\"\n          :disabled=\"value.kiali && value.kiali.enabled\"\n        />\n      </div>\n      <div\n        v-if=\"value.policy\"\n        class=\"col span-4\"\n      >\n        <Checkbox\n          v-model:value=\"value.policy.enabled\"\n          :label=\"t('istio.policy')\"\n        />\n      </div>\n      <div\n        v-if=\"value.telemetry\"\n        class=\"col span-4\"\n      >\n        <Checkbox\n          v-model:value=\"value.telemetry.enabled\"\n          :label=\"t('istio.telemetry')\"\n        />\n      </div>\n    </div>\n    <div class=\"row mb-20\">\n      <div\n        v-if=\"value.kiali\"\n        class=\"col span-4\"\n      >\n        <Checkbox\n          v-model:value=\"value.kiali.enabled\"\n          :label=\"t('istio.kiali')\"\n          @update:value=\"changeKiali\"\n        />\n      </div>\n      <div\n        v-if=\"value.tracing\"\n        class=\"col span-4\"\n      >\n        <Checkbox\n          v-model:value=\"value.tracing.enabled\"\n          :label=\"t('istio.tracing')\"\n        />\n      </div>\n      <div class=\"col span-4\" />\n    </div>\n    <div\n      v-if=\"showKialiBanner\"\n      class=\"row\"\n    >\n      <div class=\"col span-12\">\n        <Banner color=\"info\">\n          <span\n            v-clean-html=\"t('istio.pilotRequired', {}, true)\"\n          />\n        </Banner>\n      </div>\n    </div>\n\n    <h3>{{ t('istio.customOverlayFile.label') }}</h3>\n    <div class=\"custom-overlay\">\n      <Banner color=\"info\">\n        <span\n          v-clean-html=\"t('istio.customOverlayFile.tip', {}, true)\"\n        />\n      </Banner>\n      <YamlEditor\n        ref=\"yaml-editor\"\n        class=\"yaml-editor mb-10\"\n        :value=\"overlayFile\"\n        @onInput=\"valuesChanged\"\n      />\n      <FileSelector\n        class=\"role-primary  btn-sm\"\n        :label=\"t('generic.readFromFile')\"\n        @selected=\"onFileSelected\"\n      />\n    </div>\n  </div>\n</template>\n\n<style lang='scss'>\n  $yaml-height: 200px;\n\n  .custom-overlay {\n    &>DIV{\n      color: var(--input-label);\n      &>*{\n        padding: 3px;\n      }\n    }\n\n    & .yaml-editor{\n      flex: 1;\n      min-height: $yaml-height;\n      & .code-mirror .CodeMirror {\n        position: initial;\n        height: auto;\n        min-height: $yaml-height;\n      }\n    }\n  }\n</style>\n"]}]}