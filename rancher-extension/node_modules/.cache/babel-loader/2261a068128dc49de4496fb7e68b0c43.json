,OAAO;;sCAEb,CAEM;sBAFN,oBAEM,OAFN,UAEM;wCADJ,oBAA4E;kDAA1DA,MAAC,yCAAyC,cAAK;;;;sBAEnE,oBAuCM,OAvCN,UAuCM;wBAtCJ,oBAoBM,OApBN,UAoBM;0BAnBJ,oBAkBK,MAlBL,WAkBK;4BAjBH,oBAAoE,6BAA7DA,MAAC;;4BACR,oBAMK;8BALH,oBAAiE,4BAA3DA,MAAC;;8BAA2D,aAIhE;gCAHC,KAAK,EAAE,IAAI;gCACX,IAAI,EAAEC,cAAS;gCACf,YAAU,EAAED,MAAC;;;;4BAGlB,oBAMK;8BALH,oBAAiE,4BAA3DA,MAAC;;8BAA2D,aAIhE;gCAHC,KAAK,EAAE,IAAI;gCACX,IAAI,EAAEC,cAAS;gCACf,YAAU,EAAED,MAAC;;;;4BAGlB,oBAAoE,6BAA7DA,MAAC;;4BACR,oBAAoE,6BAA7DA,MAAC;;;;wBAGZ,oBAgBM,OAhBN,WAgBM;0BAfJ,aAQE;4BAPQ,KAAK,EAAET,UAAK,CAAC,eAAe;oFAArBA,UAAK,CAAC,eAAe;4BACnC,KAAK,EAAES,MAAC;4BACR,IAAI,EAAEV,SAAI;4BACX,QAAQ,EAAR,EAAQ;4BACR,IAAI,EAAC,oBAAoB;4BACxB,OAAO,EAAEU,MAAC;4BACV,eAAa,EAAE,IAAI;;;0BAEtB,aAKE;4BAJA,KAAK,EAAC,wBAAwB;4BAC7B,KAAK,EAAEA,MAAC;4BACR,IAAI,EAAEV,SAAI;4BACV,UAAQ,uCAAEC,UAAK,CAAC,eAAe,GAAG,MAAM;;;;;;;;;kBAKjD,aAkCU;oBAjCP,IAAI,EAAE,CAAC;oBACR,KAAK,EAAC,OAAO;;sCAEb,CAEM;sBAFN,oBAEM,OAFN,WAEM;wCADJ,oBAA4E;kDAA1DS,MAAC,yCAAyC,cAAK;;;;sBAEnE,oBA0BM,OA1BN,WA0BM;wBAzBJ,oBAOM,OAPN,WAOM;0CANJ,oBAAoF;oDAAjEA,MAAC,gDAAgD,cAAK;;;0BACzE,oBAIK,MAJL,WAIK;4BAHH,oBAAoE,6BAA7DA,MAAC;;4BACR,oBAAoE,6BAA7DA,MAAC;;4BACR,oBAAoE,6BAA7DA,MAAC;;;;wBAGZ,oBAgBM,OAhBN,WAgBM;0BAfJ,aAQE;4BAPQ,KAAK,EAAET,UAAK,CAAC,wBAAwB;oFAA9BA,UAAK,CAAC,wBAAwB;4BAC5C,KAAK,EAAES,MAAC;4BACR,IAAI,EAAEV,SAAI;4BACX,QAAQ,EAAR,EAAQ;4BACR,IAAI,EAAC,oBAAoB;4BACxB,OAAO,EAAEU,MAAC;4BACV,eAAa,EAAE,IAAI;;;0BAEtB,aAKE;4BAJA,KAAK,EAAC,wBAAwB;4BAC7B,KAAK,EAAEA,MAAC;4BACR,IAAI,EAAEV,SAAI;4BACV,UAAQ,uCAAEC,UAAK,CAAC,wBAAwB,GAAG,MAAM","sourcesContent":["<script>\nimport Loading from '@shell/components/Loading';\nimport CreateEditView from '@shell/mixins/create-edit-view';\nimport AuthConfig from '@shell/mixins/auth-config';\n\nimport CruResource from '@shell/components/CruResource';\nimport InfoBox from '@shell/components/InfoBox';\nimport { Checkbox } from '@components/Form/Checkbox';\nimport { LabeledInput } from '@components/Form/LabeledInput';\nimport AllowedPrincipals from '@shell/components/auth/AllowedPrincipals';\nimport FileSelector from '@shell/components/form/FileSelector';\nimport AuthBanner from '@shell/components/auth/AuthBanner';\nimport CopyToClipboardText from '@shell/components/CopyToClipboardText';\nimport AuthProviderWarningBanners from '@shell/edit/auth/AuthProviderWarningBanners';\n\nconst NAME = 'googleoauth';\n\nexport default {\n  components: {\n    Loading,\n    CruResource,\n    InfoBox,\n    LabeledInput,\n    Checkbox,\n    AllowedPrincipals,\n    FileSelector,\n    AuthBanner,\n    CopyToClipboardText,\n    AuthProviderWarningBanners\n  },\n\n  mixins: [CreateEditView, AuthConfig],\n\n  computed: {\n    tArgs() {\n      const hostname = window.location.hostname;\n\n      return {\n        hostname,\n        serverUrl: this.serverUrl,\n        provider:  this.displayName,\n        username:  this.principal.loginName || this.principal.name,\n      };\n    },\n\n    NAME() {\n      return NAME;\n    },\n\n    toSave() {\n      return {\n        enabled:           true,\n        googleOauthConfig: this.model,\n        description:       'Enable Google OAuth',\n      };\n    }\n  },\n};\n</script>\n\n<template>\n  <Loading v-if=\"$fetchState.pending\" />\n  <div v-else>\n    <CruResource\n      :cancel-event=\"true\"\n      :done-route=\"doneRoute\"\n      :mode=\"mode\"\n      :resource=\"model\"\n      :subtypes=\"[]\"\n      :validation-passed=\"true\"\n      :finish-button-mode=\"model.enabled ? 'edit' : 'enable'\"\n      :can-yaml=\"false\"\n      :errors=\"errors\"\n      :show-cancel=\"showCancel\"\n      @error=\"e=>errors = e\"\n      @finish=\"save\"\n      @cancel=\"cancel\"\n    >\n      <template v-if=\"model.enabled && !isEnabling && !editConfig\">\n        <AuthBanner\n          :t-args=\"tArgs\"\n          :disable=\"disable\"\n          :edit=\"goToEdit\"\n        >\n          <template #rows>\n            <tr><td>{{ t(`authConfig.${NAME}.adminEmail`) }}: </td><td>{{ model.adminEmail }}</td></tr>\n            <tr><td>{{ t(`authConfig.${NAME}.domain`) }}: </td><td>{{ model.hostname }}</td></tr>\n\n            <tr><td>{{ t('authConfig.ldap.nestedGroupMembership.label') }}: </td><td>{{ model.nestedGroupMembershipEnabled ? t('generic.enabled') : t('generic.disabled') }}</td></tr>\n          </template>\n        </AuthBanner>\n\n        <hr role=\"none\">\n\n        <AllowedPrincipals\n          provider=\"googleoauth\"\n          :auth-config=\"model\"\n          :mode=\"mode\"\n        />\n      </template>\n\n      <template v-else>\n        <AuthProviderWarningBanners\n          v-if=\"!model.enabled\"\n          :t-args=\"tArgs\"\n        />\n        <div\n          :style=\"{'align-items':'center'}\"\n          class=\"row mb-20\"\n        >\n          <div class=\"col span-5\">\n            <LabeledInput\n              v-model:value=\"model.adminEmail\"\n              :label=\"t(`authConfig.${NAME}.adminEmail`)\"\n              :mode=\"mode\"\n              required\n            />\n          </div>\n          <div class=\"col span-5\">\n            <LabeledInput\n              v-model:value=\"model.hostname\"\n              :label=\"t(`authConfig.${NAME}.domain`)\"\n              :mode=\"mode\"\n              required\n            />\n          </div>\n          <div class=\"col span-2\">\n            <Checkbox\n              v-model:value=\"model.nestedGroupMembershipEnabled\"\n              :mode=\"mode\"\n              :label=\"t('authConfig.ldap.nestedGroupMembership.label')\"\n            />\n          </div>\n        </div>\n        <InfoBox\n          :step=\"1\"\n          class=\" mt-20 mb-20\"\n        >\n          <h3 v-clean-html=\"t('authConfig.googleoauth.steps.1.title', tArgs, true)\" />\n          <ul class=\"mt-0 step-list\">\n            <li>{{ t('authConfig.googleoauth.steps.1.body.1', {}, true) }} </li>\n            <li>\n              <b>{{ t('authConfig.googleoauth.steps.1.body.2', {}, true) }}</b> {{ t('authConfig.googleoauth.steps.1.topPrivateDomain', {}, true) }} <CopyToClipboardText\n                :plain=\"true\"\n                :text=\"tArgs.hostname\"\n                :aria-label=\"t('authConfig.googleoauth.steps.1.ariaLabel.hostname')\"\n              />\n            </li>\n            <li>\n              <b>{{ t('authConfig.googleoauth.steps.1.body.3', {}, true) }}</b> <CopyToClipboardText\n                :plain=\"true\"\n                :text=\"serverUrl\"\n                :aria-label=\"t('authConfig.googleoauth.steps.1.ariaLabel.serverUrl')\"\n              />\n            </li>\n            <li>{{ t('authConfig.googleoauth.steps.1.body.4', {}, true) }} </li>\n            <li>{{ t('authConfig.googleoauth.steps.1.body.5', {}, true) }} </li>\n          </ul>\n        </InfoBox>\n        <InfoBox\n          :step=\"2\"\n          class=\"mb-20\"\n        >\n          <div class=\"row\">\n            <h3 v-clean-html=\"t('authConfig.googleoauth.steps.2.title', tArgs, true)\" />\n          </div>\n          <div class=\"row\">\n            <div class=\"col span-6\">\n              <ul class=\"mt-0 step-list\">\n                <li>{{ t('authConfig.googleoauth.steps.2.body.1', {}, true) }} </li>\n                <li>\n                  <b>{{ t('authConfig.googleoauth.steps.2.body.2', {}, true) }}</b> <CopyToClipboardText\n                    :plain=\"true\"\n                    :text=\"serverUrl\"\n                    :aria-label=\"t('authConfig.googleoauth.steps.1.ariaLabel.serverUrl')\"\n                  />\n                </li>\n                <li>\n                  <b>{{ t('authConfig.googleoauth.steps.2.body.3', {}, true) }}</b> <CopyToClipboardText\n                    :plain=\"true\"\n                    :text=\"serverUrl+'/verify-auth'\"\n                    :aria-label=\"t('authConfig.googleoauth.steps.2.ariaLabel.serverUrlVerify')\"\n                  />\n                </li>\n                <li>{{ t('authConfig.googleoauth.steps.2.body.4', {}, true) }} </li>\n                <li>{{ t('authConfig.googleoauth.steps.2.body.5', {}, true) }} </li>\n              </ul>\n            </div>\n            <div class=\"col span-6\">\n              <LabeledInput\n                v-model:value=\"model.oauthCredential\"\n                :label=\"t(`authConfig.googleoauth.oauthCredentials.label`)\"\n                :mode=\"mode\"\n                required\n                type=\"multiline-password\"\n                :tooltip=\"t(`authConfig.googleoauth.oauthCredentials.tip`)\"\n                :hover-tooltip=\"true\"\n              />\n              <FileSelector\n                class=\"role-tertiary add mt-5\"\n                :label=\"t('generic.readFromFile')\"\n                :mode=\"mode\"\n                @selected=\"model.oauthCredential = $event\"\n              />\n            </div>\n          </div>\n        </InfoBox>\n        <InfoBox\n          :step=\"3\"\n          class=\"mb-20\"\n        >\n          <div class=\"row\">\n            <h3 v-clean-html=\"t('authConfig.googleoauth.steps.3.title', tArgs, true)\" />\n          </div>\n          <div class=\"row\">\n            <div class=\"col span-6\">\n              <div v-clean-html=\"t('authConfig.googleoauth.steps.3.introduction', tArgs, true)\" />\n              <ul class=\"mt-10 step-list\">\n                <li>{{ t('authConfig.googleoauth.steps.3.body.1', {}, true) }} </li>\n                <li>{{ t('authConfig.googleoauth.steps.3.body.2', {}, true) }} </li>\n                <li>{{ t('authConfig.googleoauth.steps.3.body.3', {}, true) }} </li>\n              </ul>\n            </div>\n            <div class=\"col span-6\">\n              <LabeledInput\n                v-model:value=\"model.serviceAccountCredential\"\n                :label=\"t(`authConfig.googleoauth.serviceAccountCredentials.label`)\"\n                :mode=\"mode\"\n                required\n                type=\"multiline-password\"\n                :tooltip=\"t(`authConfig.googleoauth.serviceAccountCredentials.tip`)\"\n                :hover-tooltip=\"true\"\n              />\n              <FileSelector\n                class=\"role-tertiary add mt-5\"\n                :label=\"t('generic.readFromFile')\"\n                :mode=\"mode\"\n                @selected=\"model.serviceAccountCredential = $event\"\n              />\n            </div>\n          </div>\n        </InfoBox>\n      </template>\n    </CruResource>\n  </div>\n</template>\n<style lang=\"scss\" scoped>\n  .step-list li:not(:last-child) {\n    margin-bottom: 8px;\n  }\n\n  .banner {\n    display: block;\n\n    &:deep() code {\n      padding: 0 3px;\n      margin: 0 3px;\n    }\n  }\n</style>\n"]}]}