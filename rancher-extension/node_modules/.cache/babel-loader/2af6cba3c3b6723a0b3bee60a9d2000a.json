directTo', { provider: this.name });\n    },\n  },\n};\n</script>\n\n<template>\n  <div class=\"text-center\">\n    <button\n      ref=\"btn\"\n      class=\"btn bg-primary\"\n      style=\"font-size: 18px;\"\n      @click=\"login\"\n    >\n      {{ t('login.loginWithProvider', {provider: uniqueDisplayName}) }}\n    </button>\n  </div>\n</template>\n"]}]}