{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/dialog/GitRepoForceUpdateDialog.vue?vue&type=template&id=3eed93ec&scoped=true","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/dialog/GitRepoForceUpdateDialog.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/dialog/GitRepoForceUpdateDialog.vue"],"names":["t"],"mappings":";;qBA+EQ,KAAK,EAAC,mBAAmB;qBAKtB,KAAK,EAAC,OAAO;qBAGd,KAAK,EAAC,MAAM;;;;;;;;wBAfpB,aA+CO;IA9CL,KAAK,EAAC,qBAAqB;IAC1B,uBAAqB,EAAE,KAAK;;IAElB,KAAK,WACd,CAGE;sBAHF,oBAGE,MAHF,UAGE;gCAFcA,MAAC;;;IAKR,IAAI,WACb,CAKM;MALN,oBAKM,OALN,UAKM;0CAJDA,MAAC,qDAAoD,GAAC;wBAAA,oBAGvD,QAHuD,UAGvD;kCAFc,sBAAa,CAAC,cAAK,QAAQA,MAAC;;;;MAI9C,aAKS;QAJP,KAAK,EAAC,MAAM;QACZ,WAAS,EAAC,iDAAiD;;0BAE3D,CAA0G;0BAA1G,oBAA0G;oCAAtFA,MAAC,6DAA6D,cAAK,CAAC,MAAM;;;;;;yBAEhG,oBAKE,6BAJmB,YAAM,GAAjB,GAAG,EAAE,CAAC;8BADhB,aAKE;UAHC,GAAG,EAAE,CAAC;UACP,KAAK,EAAC,OAAO;UACZ,KAAK,EAAE,GAAG;;;;IAIJ,OAAO,WAChB,CAKS;MALT,oBAKS;QAJP,KAAK,EAAC,oBAAoB;QACzB,OAAK,0CAAE,yCAAK;0BAEVA,MAAC;;gCAEN,oBAAsB,SAAjB,KAAK,EAAC,QAAQ;;MACnB,aAKE;QAJA,IAAI,EAAC,QAAQ;QACb,KAAK,EAAC,mBAAmB;QACxB,aAAW,EAAE,2BAA2B;QACxC,OAAK,EAAE,cAAK","sourcesContent":["<script>\nimport { mapGetters, mapState } from 'vuex';\nimport { resourceNames } from '@shell/utils/string';\nimport { exceptionToErrorsArray } from '@shell/utils/error';\nimport { Banner } from '@components/Banner';\nimport { Card } from '@components/Card';\nimport AsyncButton from '@shell/components/AsyncButton';\n\nexport default {\n  name: 'GitRepoForceUpdateDialog',\n\n  emits: ['close'],\n\n  components: {\n    AsyncButton,\n    Banner,\n    Card,\n  },\n\n  props: {\n    repositories: {\n      type:     Array,\n      required: true,\n    },\n  },\n\n  data() {\n    return { errors: [] };\n  },\n\n  computed: {\n    ...mapState('action-menu', ['toRemove']),\n    ...mapGetters({ t: 'i18n/t' }),\n\n    names() {\n      return this.repositories.map((repository) => repository.nameDisplay);\n    }\n  },\n\n  methods: {\n    resourceNames,\n\n    close(buttonDone) {\n      if (buttonDone && typeof buttonDone === 'function') {\n        buttonDone(true);\n      }\n      this.$emit('close');\n    },\n\n    async apply(buttonDone) {\n      try {\n        await Promise.all(this.repositories.map((repository) => this.updateGitRepo(repository)));\n\n        this.close();\n      } catch (err) {\n        this.errors = exceptionToErrorsArray(err);\n        buttonDone(false);\n      }\n    },\n\n    updateGitRepo(repository) {\n      const now = repository.spec.forceSyncGeneration || 1;\n\n      repository.spec.forceSyncGeneration = now + 1;\n\n      return repository.save();\n    },\n  }\n};\n</script>\n\n<template>\n  <Card\n    class=\"prompt-force-update\"\n    :show-highlight-border=\"false\"\n  >\n    <template #title>\n      <h4\n        v-clean-html=\"t('fleet.gitRepo.actions.forceUpdate.promptTitle')\"\n        class=\"text-default-text\"\n      />\n    </template>\n\n    <template #body>\n      <div class=\"mb-20\">\n        {{ t('fleet.gitRepo.actions.forceUpdate.promptNames') }} <span\n          v-clean-html=\"resourceNames(names, null, t)\"\n          class=\"body\"\n        />\n      </div>\n      <Banner\n        color=\"info\"\n        label-key=\"fleet.gitRepo.actions.forceUpdate.promptWarning\"\n      >\n        <span v-clean-html=\"t('fleet.gitRepo.actions.forceUpdate.promptWarning', { count: names.length}, true)\" />\n      </Banner>\n      <Banner\n        v-for=\"(err, i) in errors\"\n        :key=\"i\"\n        color=\"error\"\n        :label=\"err\"\n      />\n    </template>\n\n    <template #actions>\n      <button\n        class=\"btn role-secondary\"\n        @click=\"close\"\n      >\n        {{ t('generic.cancel') }}\n      </button>\n      <div class=\"spacer\" />\n      <AsyncButton\n        mode=\"update\"\n        class=\"btn bg-info ml-10\"\n        :data-testid=\"'deactivate-driver-confirm'\"\n        @click=\"apply\"\n      />\n    </template>\n  </Card>\n</template>\n\n<style lang='scss' scoped>\n  .card-container {\n    box-shadow: none;\n  }\n\n  :deep() .card-actions {\n    display: flex;\n    justify-content: end;\n  }\n</style>\n"]}]}