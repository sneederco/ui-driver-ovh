ultiline\"\n            data-testid=\"ace-cacerts-input\"\n            :tooltip=\"t('cluster.rke2.address.caCerts.toolTip')\"\n            @update:value=\"$emit('ca-certs-changed', $event)\"\n          />\n          <FileSelector\n            :mode=\"mode\"\n            class=\"btn btn-sm bg-primary mt-10\"\n            :label=\"t('generic.readFromFile')\"\n            @selected=\"onCertSelected\"\n          />\n        </div>\n      </div>\n    </template>\n  </div>\n</template>\n"]}]}