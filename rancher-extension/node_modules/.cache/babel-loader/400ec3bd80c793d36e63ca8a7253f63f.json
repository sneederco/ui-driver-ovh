ult: () => ({})\r\n    },\r\n    mode: {\r\n      type:     String,\r\n      required: true,\r\n    },\r\n  },\r\n  data() {\r\n    const readOnlyOptions = [\r\n      {\r\n        label: this.t('generic.yes'),\r\n        value: true\r\n      },\r\n      {\r\n        label: this.t('generic.no'),\r\n        value: false\r\n      }\r\n    ];\r\n\r\n    this.value.spec['rbd'] = this.value.spec.rbd || {};\r\n    this.value.spec.rbd['readOnly'] = this.value.spec.rbd.readOnly || false;\r\n    this.value.spec.rbd['secretRef'] = this.value.spec.rbd.secretRef || {};\r\n\r\n    return { readOnlyOptions };\r\n  },\r\n};\r\n</script>\r\n\r\n<template>\r\n  <div>\r\n    <div class=\"row mb-20\">\r\n      <div class=\"col span-6\">\r\n        <LabeledInput\r\n          v-model:value=\"value.spec.rbd.user\"\r\n          :mode=\"mode\"\r\n          :label=\"t('persistentVolume.rbd.user.label')\"\r\n          :placeholder=\"t('persistentVolume.rbd.user.placeholder')\"\r\n        />\r\n      </div>\r\n      <div class=\"col span-6\">\r\n        <LabeledInput\r\n          v-model:value=\"value.spec.rbd.keyring\"\r\n          :mode=\"mode\"\r\n          :label=\"t('persistentVolume.rbd.keyRing.label')\"\r\n          :placeholder=\"t('persistentVolume.rbd.keyRing.placeholder')\"\r\n        />\r\n      </div>\r\n    </div>\r\n    <div class=\"row mb-20\">\r\n      <div class=\"col span-6\">\r\n        <LabeledInput\r\n          v-model:value=\"value.spec.rbd.pool\"\r\n          :mode=\"mode\"\r\n          :label=\"t('persistentVolume.rbd.pool.label')\"\r\n          :placeholder=\"t('persistentVolume.rbd.pool.placeholder')\"\r\n        />\r\n      </div>\r\n      <div class=\"col span-6\">\r\n        <LabeledInput\r\n          v-model:value=\"value.spec.rbd.image\"\r\n          :mode=\"mode\"\r\n          :label=\"t('persistentVolume.rbd.image.label')\"\r\n          :placeholder=\"t('persistentVolume.rbd.image.placeholder')\"\r\n        />\r\n      </div>\r\n    </div>\r\n    <div class=\"row mb-20\">\r\n      <div class=\"col span-6\">\r\n        <LabeledInput\r\n          v-model:value=\"value.spec.rbd.secretRef.name\"\r\n          :mode=\"mode\"\r\n          :label=\"t('persistentVolume.shared.secretName.label')\"\r\n          :placeholder=\"t('persistentVolume.shared.secretName.placeholder')\"\r\n        />\r\n      </div>\r\n      <div class=\"col span-6\">\r\n        <LabeledInput\r\n          v-model:value=\"value.spec.rbd.secretRef.namespace\"\r\n          :mode=\"mode\"\r\n          :label=\"t('persistentVolume.shared.secretNamespace.label')\"\r\n          :placeholder=\"t('persistentVolume.shared.secretNamespace.placeholder')\"\r\n        />\r\n      </div>\r\n    </div>\r\n    <div class=\"row mb-20\">\r\n      <div class=\"col span-6\">\r\n        <LabeledInput\r\n          v-model:value=\"value.spec.rbd.fsType\"\r\n          :mode=\"mode\"\r\n          :label=\"t('persistentVolume.shared.filesystemType.label')\"\r\n          :placeholder=\"t('persistentVolume.shared.filesystemType.placeholder')\"\r\n        />\r\n      </div>\r\n      <div class=\"col span-6\">\r\n        <RadioGroup\r\n          v-model:value=\"value.spec.rbd.readOnly\"\r\n          name=\"readOnly\"\r\n          :mode=\"mode\"\r\n          :label=\"t('persistentVolume.shared.readOnly.label')\"\r\n          :options=\"readOnlyOptions\"\r\n          :row=\"true\"\r\n        />\r\n      </div>\r\n    </div>\r\n    <div class=\"row mb-20\">\r\n      <div class=\"col span-6\">\r\n        <ArrayList\r\n          v-model:value=\"value.spec.rbd.monitors\"\r\n          :add-label=\"t('persistentVolume.shared.monitors.add')\"\r\n          :mode=\"mode\"\r\n        />\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n"]}]}