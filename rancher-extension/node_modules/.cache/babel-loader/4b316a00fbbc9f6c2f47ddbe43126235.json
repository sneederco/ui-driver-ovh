{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/detail/catalog.cattle.io.app.vue?vue&type=template&id=c5c16544&scoped=true","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/detail/catalog.cattle.io.app.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/detail/catalog.cattle.io.app.vue"],"names":["$fetchState","t"],"mappings":";;;;;EA0HM,KAAK,EAAC,kBAAkB;;;;;;;;;;;;UAJbA,gBAAW,CAAC,OAAO;qBAAlC,aAAsC;qBACtC,oBA6DM;SA3DI,wBAAe;2BADvB,oBAKO,QALP,UAKO;gDADFC,MAAC,yCAAwC,MAAI,oBAAG,wBAAe,CAAC,MAAM,CAAC,MAAM,IAAG,OAAK;cAAA,oBAAoF;gBAAhF,OAAK,uCAAE,wBAAe,CAAC,QAAQ;kCAASA,MAAC;;;;QAGvI,aAoDe;UAnDb,KAAK,EAAC,OAAO;UACb,aAAW,EAAC,WAAW;UACtB,cAAc,EAAE,KAAK;UACrB,UAAU,EAAE,KAAK;UACjB,WAAW,EAAE,KAAK;UAClB,SAAO,uCAAE,mBAAU,CAAC,MAAM;;4BAE3B,CAeM;YAfN,aAeM;cAdJ,IAAI,EAAC,WAAW;cACf,KAAK,EAAEA,MAAC;cACR,MAAM,EAAE,CAAC;;;iBAGF,eAAM;mCADd,aAIE;;sBAFA,KAAK,EAAC,MAAM;sBACX,KAAK,EAAEA,MAAC,8CAA8C,YAAK,CAAC,QAAQ,CAAC,IAAI;;mCAE5E,aAIE;;sBAFC,KAAK,EAAE,YAAK;sBACb,GAAG,EAAC,cAAc;;;;;;YAGtB,aAWM;cAVJ,IAAI,EAAC,aAAa;cACjB,KAAK,EAAEA,MAAC;cACR,MAAM,EAAE,CAAC;;gCAEV,CAKE;gBALF,aAKE;kBAJA,GAAG,EAAC,MAAM;kBACT,SAAS,EAAE,KAAK;kBAChB,KAAK,EAAE,mBAAU;kBAClB,aAAW,EAAC,WAAW;;;;;;aAInB,kBAAS;+BADjB,aAOM;;kBALJ,IAAI,EAAC,QAAQ;kBACZ,KAAK,EAAEA,MAAC;kBACR,MAAM,EAAE,CAAC;;oCAEV,CAAmD;oBAAnD,aAAmD;sBAAjC,KAAK,EAAE,YAAK,CAAC,IAAI,CAAC,IAAI,CAAC,MAAM;8EAAtB,YAAK,CAAC,IAAI,CAAC,IAAI,CAAC,MAAM;;;;;;;aAGzC,iBAAQ;+BADhB,aAOM;;kBALJ,IAAI,EAAC,OAAO;kBACX,KAAK,EAAEA,MAAC;kBACR,MAAM,EAAE,CAAC;;oCAEV,CAAkD;oBAAlD,aAAkD;sBAAhC,KAAK,EAAE,YAAK,CAAC,IAAI,CAAC,IAAI,CAAC,KAAK;8EAArB,YAAK,CAAC,IAAI,CAAC,IAAI,CAAC,KAAK","sourcesContent":["<script>\nimport YamlEditor from '@shell/components/YamlEditor';\nimport Loading from '@shell/components/Loading';\nimport Markdown from '@shell/components/Markdown';\nimport Tab from '@shell/components/Tabbed/Tab';\nimport { Banner } from '@components/Banner';\nimport RelatedResources from '@shell/components/RelatedResources';\nimport jsyaml from 'js-yaml';\nimport merge from 'lodash/merge';\nimport { CATALOG } from '@shell/config/types';\nimport { sortBy } from '@shell/utils/sort';\nimport { allHash } from '@shell/utils/promise';\nimport { mergeWithReplace } from '@shell/utils/object';\nimport ResourceTabs from '@shell/components/form/ResourceTabs/index.vue';\n\nexport default {\n  name: 'DetailRelease',\n\n  components: {\n    Markdown, ResourceTabs, Tab, Loading, YamlEditor, Banner, RelatedResources\n  },\n\n  props: {\n    value: {\n      type:     Object,\n      required: true,\n    },\n  },\n\n  data() {\n    return { allOperations: [] };\n  },\n\n  async fetch() {\n    const promises = {\n      catalog:       this.$store.dispatch('catalog/load'),\n      allOperations: this.$store.dispatch('cluster/findAll', { type: CATALOG.OPERATION }),\n      secret:        this.value.fetchValues(true),\n    };\n\n    const res = await allHash(promises);\n\n    this.allOperations = res.allOperations;\n  },\n\n  computed: {\n    hasNotes() {\n      return !!this.value?.spec?.info?.notes;\n    },\n\n    hasReadme() {\n      return !!this.value?.spec?.info?.readme;\n    },\n\n    valuesYaml() {\n      const combined = mergeWithReplace(\n        merge({}, this.value?.chartValues || {}),\n        this.value?.values || {},\n      );\n\n      return jsyaml.dump(combined);\n    },\n\n    isBusy() {\n      if (this.value?.metadata?.state?.transitioning && this.value?.metadata?.state?.name === 'pending-install') {\n        return true;\n      }\n\n      return false;\n    },\n\n    filteredOperations() {\n      return this.allOperations.filter((operation) => {\n        if (operation.status?.releaseName === this.value.metadata.name &&\n            operation.status?.namespace === this.value.metadata.namespace) {\n          return true;\n        }\n      });\n    },\n\n    latestOperation() {\n      if (this.filteredOperations.length > 0) {\n        const sortedOperations = sortBy(Object.values(this.filteredOperations), ['createdAt', 'created', 'metadata.creationTimestamp'], true);\n\n        return sortedOperations[0];\n      }\n\n      return false;\n    },\n\n  },\n\n  methods: {\n    tabChanged({ tab }) {\n      window.scrollTop = 0;\n\n      this.selectedTabName = tab.name;\n\n      if ( tab.name === 'values-yaml' ) {\n        this.$nextTick(() => {\n          if ( this.$refs.yaml ) {\n            this.$refs.yaml.refresh();\n            this.$refs.yaml.focus();\n          }\n        });\n      }\n    },\n  },\n\n  watch: {\n    'value.secretId'(neu, old) {\n      this.value.fetchValues(true);\n    }\n  },\n};\n</script>\n\n<template>\n  <Loading v-if=\"$fetchState.pending\" />\n  <div v-else>\n    <span\n      v-if=\"latestOperation\"\n      class=\"latest-operation\"\n    >\n      {{ t('catalog.app.section.lastOperation') }}: ( {{ latestOperation.status.action }} ) - <a @click=\"latestOperation.openLogs()\">  {{ t('catalog.app.section.openLogs') }}</a>\n    </span>\n\n    <ResourceTabs\n      class=\"mt-20\"\n      default-tab=\"resources\"\n      :needConditions=\"false\"\n      :needEvents=\"false\"\n      :needRelated=\"false\"\n      @changed=\"tabChanged($event)\"\n    >\n      <Tab\n        name=\"resources\"\n        :label=\"t('catalog.app.section.resources.label')\"\n        :weight=\"4\"\n      >\n        <Banner\n          v-if=\"isBusy\"\n          color=\"info\"\n          :label=\"t('catalog.app.section.resources.busy', { app: value.metadata.name })\"\n        />\n        <RelatedResources\n          v-else\n          :value=\"value\"\n          rel=\"helmresource\"\n        />\n      </Tab>\n      <Tab\n        name=\"values-yaml\"\n        :label=\"t('catalog.app.section.values')\"\n        :weight=\"3\"\n      >\n        <YamlEditor\n          ref=\"yaml\"\n          :scrolling=\"false\"\n          :value=\"valuesYaml\"\n          editor-mode=\"VIEW_CODE\"\n        />\n      </Tab>\n      <Tab\n        v-if=\"hasReadme\"\n        name=\"readme\"\n        :label=\"t('catalog.app.section.readme')\"\n        :weight=\"2\"\n      >\n        <Markdown v-model:value=\"value.spec.info.readme\" />\n      </Tab>\n      <Tab\n        v-if=\"hasNotes\"\n        name=\"notes\"\n        :label=\"t('catalog.app.section.notes')\"\n        :weight=\"1\"\n      >\n        <Markdown v-model:value=\"value.spec.info.notes\" />\n      </Tab>\n    </ResourceTabs>\n  </div>\n</template>\n\n<style lang=\"scss\" scoped>\n.latest-operation a {\n  cursor: pointer;\n}\n</style>\n"]}]}