{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/form/ResourceSelector.vue?vue&type=template&id=5f5abd66","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/form/ResourceSelector.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/form/ResourceSelector.vue"],"names":["t"],"mappings":";;qBAmHS,KAAK,EAAC,KAAK;qBACT,KAAK,EAAC,aAAa;qBAUrB,KAAK,EAAC,KAAK;qBACT,KAAK,EAAC,aAAa;qBAMrB,KAAK,EAAC,KAAK;qBACT,KAAK,EAAC,aAAa;;;;;;;;wBApB5B,oBAgCM;IA/BJ,oBAUM,OAVN,UAUM;MATJ,oBAQM,OARN,UAQM;QAPJ,aAME;UALQ,KAAK,EAAE,4BAAmB;kEAAnB,4BAAmB;UACjC,IAAI,EAAE,WAAI;UACV,aAAW,EAAE,KAAK;UAClB,IAAI,EAAE,WAAI;UACV,kBAAgB,EAAE,4BAAmB;;;;;IAI5C,oBAMM,OANN,UAMM;MALJ,oBAIM,OAJN,UAIM;QAHJ,aAES;UAFA,KAAK,GAAG,uBAAiB,CAAC,IAAI;;4BACrC,CAA+F;4BAA/F,oBAA+F;sCAA3EA,MAAC,oDAAoD,uBAAiB;;;;;;;;IAIhG,oBAYM,OAZN,UAYM;MAXJ,oBAUM,OAVN,UAUM;QATJ,aAQE;UAPC,IAAI,EAAE,uBAAiB,CAAC,OAAO;UAC/B,OAAO,EAAE,kBAAY;UACtB,WAAS,EAAC,IAAI;UACb,eAAa,EAAE,KAAK;UACpB,MAAM,EAAE,eAAM;UACd,SAAS,EAAE,KAAK;UAChB,MAAM,EAAE,KAAK","sourcesContent":["<script>\nimport { Banner } from '@components/Banner';\nimport MatchExpressions from '@shell/components/form/MatchExpressions';\nimport ResourceTable from '@shell/components/ResourceTable';\nimport { _EDIT } from '@shell/config/query-params';\nimport { convert, simplify } from '@shell/utils/selector';\nimport throttle from 'lodash/throttle';\nimport { COUNT } from '@shell/config/types';\nimport { matching } from '@shell/utils/selector-typed';\n\nexport default {\n  name: 'ResourceSelector',\n\n  components: {\n    Banner,\n    MatchExpressions,\n    ResourceTable,\n  },\n\n  props: {\n    mode: {\n      type:    String,\n      default: _EDIT,\n    },\n    type: {\n      type:     String,\n      required: true,\n    },\n    value: {\n      type:     Object,\n      required: true,\n    },\n    namespace: {\n      type:    String,\n      default: '',\n    },\n  },\n\n  async fetch() {\n    this.updateMatchingResources();\n  },\n\n  data() {\n    return {\n      matchingResources: {\n        matched: 0,\n        matches: [],\n        none:    true,\n        sample:  null,\n        total:   0,\n      },\n      tableHeaders: this.$store.getters['type-map/headersFor'](\n        this.$store.getters['cluster/schemaFor'](this.type)\n      ),\n      inStore: this.$store.getters['currentProduct'].inStore,\n    };\n  },\n\n  watch: {\n    namespace:                'updateMatchingResources',\n    'value.matchLabels':      'updateMatchingResources',\n    'value.matchExpressions': 'updateMatchingResources',\n  },\n\n  computed: {\n    schema() {\n      return this.$store.getters['cluster/schemaFor'](this.type);\n    },\n    /**\n     * of type matchExpression aka `KubeLabelSelectorExpression[]`\n     */\n    selectorExpressions: {\n      get() {\n        return convert(\n          this.value.matchLabels || {},\n          this.value.matchExpressions || []\n        );\n      },\n      set(selectorExpressions) {\n        const { matchLabels, matchExpressions } = simplify(selectorExpressions);\n\n        this.value['matchLabels'] = matchLabels;\n        this.value['matchExpressions'] = matchExpressions;\n      }\n    },\n    allResourcesInScope() {\n      const counts = this.$store.getters[`${ this.inStore }/all`](COUNT)?.[0]?.counts || {};\n\n      if (this.namespace) {\n        return counts?.[this.type].namespaces[this.namespace]?.count || 0;\n      }\n\n      return counts[this.type]?.summary?.count || 0;\n    }\n  },\n\n  methods: {\n    updateMatchingResources: throttle(async function() {\n      this.matchingResources = await matching({\n        labelSelector: { matchExpressions: this.selectorExpressions },\n        type:          this.type,\n        inStore:       this.inStore,\n        $store:        this.$store,\n        inScopeCount:  this.allResourcesInScope,\n        namespace:     this.namespace,\n        transient:     true,\n      });\n    }, 250, { leading: true }),\n  }\n\n};\n</script>\n\n<template>\n  <div>\n    <div class=\"row\">\n      <div class=\"col span-12\">\n        <MatchExpressions\n          v-model:value=\"selectorExpressions\"\n          :mode=\"mode\"\n          :show-remove=\"false\"\n          :type=\"type\"\n          :target-resources=\"allResourcesInScope\"\n        />\n      </div>\n    </div>\n    <div class=\"row\">\n      <div class=\"col span-12\">\n        <Banner :color=\"(matchingResources.none ? 'warning' : 'success')\">\n          <span v-clean-html=\"t('generic.selectors.matchingResources.matchesSome', matchingResources)\" />\n        </Banner>\n      </div>\n    </div>\n    <div class=\"row\">\n      <div class=\"col span-12\">\n        <ResourceTable\n          :rows=\"matchingResources.matches\"\n          :headers=\"tableHeaders\"\n          key-field=\"id\"\n          :table-actions=\"false\"\n          :schema=\"schema\"\n          :groupable=\"false\"\n          :search=\"false\"\n        />\n      </div>\n    </div>\n  </div>\n</template>\n"]}]}