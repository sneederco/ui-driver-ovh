{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/edit/workload/VolumeClaimTemplate.vue?vue&type=template&id=4962ee6d&scoped=true","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/edit/workload/VolumeClaimTemplate.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/edit/workload/VolumeClaimTemplate.vue"],"names":["t"],"mappings":";;qBAoGe,KAAK,EAAC,kBAAkB;;;;;;;wBARrC,oBAkCM;IAjCJ,oBAgCM;MA/BJ,aA8BmB;QA7BT,KAAK,EAAE,eAAS;gEAAT,eAAS;QACxB,KAAK,EAAC,OAAO;QACZ,OAAK,uCAAE,eAAM;;QAEH,OAAO,WAChB,CAOM,AARY,KAAK;UACvB,oBAOM,OAPN,UAOM;aALI,KAAK,CAAC,GAAG,CAAC,KAAK,CAAC,QAAQ;+BADhC,aAKE;;kBAHC,KAAK,EAAE,KAAK,CAAC,GAAG,CAAC,KAAK;kBACtB,IAAI,EAAE,WAAI;kBACV,OAAK,aAAE,kBAAS,CAAC,KAAK,CAAC,GAAG,CAAC,KAAK;;;;;UAGrC,aAIE;YAHC,IAAI,EAAE,KAAK,CAAC,GAAG,CAAC,KAAK,CAAC,QAAQ,CAAC,IAAI;YACnC,IAAI,EAAE,WAAI;YACV,SAAS,EAAE,YAAK,CAAC,QAAQ,CAAC,IAAI,CAAC,UAAU;;;QAGnC,GAAG;YAEH,eAAM;6BADf,oBAOS;;gBALP,IAAI,EAAC,QAAQ;gBACb,KAAK,EAAC,uBAAuB;gBAC5B,OAAK,0CAAE,2CAAM;kCAEXA,MAAC","sourcesContent":["<script>\nimport Mount from '@shell/edit/workload/storage/Mount';\nimport { mapGetters } from 'vuex';\nimport PersistentVolumeClaim from '@shell/edit/workload/storage/persistentVolumeClaim/persistentvolumeclaim.vue';\nimport { PVC } from '@shell/config/types';\nimport { _VIEW } from '@shell/config/query-params';\nimport ArrayListGrouped from '@shell/components/form/ArrayListGrouped';\n\nexport default {\n  components: {\n    ArrayListGrouped,\n    Mount,\n    PersistentVolumeClaim\n  },\n\n  props: {\n    mode: {\n      type:    String,\n      default: 'create'\n    },\n\n    namespace: {\n      type:    String,\n      default: null\n    },\n\n    value: {\n      type:    Object,\n      default: () => {\n        return {};\n      }\n    },\n  },\n\n  data() {\n    return { templates: this.value.volumeClaimTemplates, name: '' };\n  },\n\n  computed: {\n    isView() {\n      return this.mode === _VIEW;\n    },\n\n    ...mapGetters({ t: 'i18n/t' })\n  },\n\n  watch: {\n    namespace(neu) {\n      this.pvc.metadata.namespace = neu;\n    },\n  },\n\n  methods: {\n    update() {\n      this.value['volumeClaimTemplates'] = this.templates;\n    },\n\n    updatePVC(pvc) {\n      const storage = pvc?.spec?.resources?.requests?.storage;\n\n      if (storage) {\n        if (!storage.toString().match(/[0-9]*[a-zA-Z]+$/)) {\n          pvc.spec.resources.requests.storage += 'Gi';\n        }\n      }\n      this.name = pvc?.metadata?.name;\n      this.update();\n    },\n\n    addPVC() {\n      if (!this.value.volumeClaimTemplates) {\n        this.value['volumeClaimTemplates'] = [];\n      }\n      this.templates = this.value.volumeClaimTemplates;\n\n      const namespace = this.namespace || this.$store.getters['defaultNamespace'];\n\n      const data = { type: PVC };\n\n      data.metadata = { namespace };\n\n      this.$store.dispatch('cluster/create', data).then((pvc) => {\n        pvc.applyDefaults();\n        this.templates.push(pvc);\n        this.update();\n      });\n    },\n  }\n};\n</script>\n\n<template>\n  <div>\n    <div>\n      <ArrayListGrouped\n        v-model:value=\"templates\"\n        class=\"mb-20\"\n        @input=\"update()\"\n      >\n        <template #default=\"props\">\n          <div class=\"bordered-section\">\n            <PersistentVolumeClaim\n              v-if=\"props.row.value.metadata\"\n              :value=\"props.row.value\"\n              :mode=\"mode\"\n              @input=\"updatePVC(props.row.value)\"\n            />\n          </div>\n          <Mount\n            :name=\"props.row.value.metadata.name\"\n            :mode=\"mode\"\n            :container=\"value.template.spec.containers[0]\"\n          />\n        </template>\n        <template #add>\n          <button\n            v-if=\"!isView\"\n            type=\"button\"\n            class=\"btn role-tertiary add\"\n            @click=\"addPVC\"\n          >\n            {{ t('volumeClaimTemplate.add.label') }}\n          </button>\n        </template>\n      </ArrayListGrouped>\n    </div>\n  </div>\n</template>\n\n<style lang='scss' scoped>\n.remove-btn{\n  position: absolute;\n  top:0px;\n  right:0px;\n}\n</style>\n"]}]}