{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/initialize/App.vue?vue&type=template&id=27115e83","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/initialize/App.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/initialize/App.vue"],"names":[],"mappings":";;qBA6DO,EAAE,EAAC,QAAQ;qBAGZ,EAAE,EAAC,UAAU;;;;;;wBAHjB,oBAOM,OAPN,UAOM;IANJ,aAA6B,0BAAhB,GAAG,EAAC,SAAS;;IAC1B,oBAIM,OAJN,UAIM;MADJ,aAAe","sourcesContent":["<script>\nimport NuxtLoading from '@shell/components/nav/GlobalLoading.vue';\n\nimport '@shell/assets/styles/app.scss';\n\nexport default {\n  data: () => ({ isOnline: true }),\n\n  created() {\n    // add to window so we can listen when ready\n    window.$globalApp = this;\n\n    // This is needed for Harvester https://github.com/rancher/dashboard/issues/10681\n    const isHarvester = this.$globalApp?.$store.getters['currentCluster']?.isHarvester;\n\n    if (!isHarvester) {\n      Object.defineProperty(window, '$nuxt', {\n        get() {\n          console.warn('window.$nuxt is deprecated. It would be best to stop using globalState all together. For an alternative you can use window.$globalApp.'); // eslint-disable-line no-console\n\n          return window.$globalApp;\n        }\n      });\n    }\n\n    this.refreshOnlineStatus();\n    // Setup the listeners\n    window.addEventListener('online', this.refreshOnlineStatus);\n    window.addEventListener('offline', this.refreshOnlineStatus);\n\n    // Add $nuxt.context\n    this.context = this.$options.context;\n  },\n\n  mounted() {\n    this.$loading = this.$refs.loading;\n  },\n\n  computed: {\n    isOffline() {\n      return !this.isOnline;\n    },\n  },\n\n  methods: {\n    refreshOnlineStatus() {\n      if (typeof window.navigator.onLine === 'undefined') {\n        // If the browser doesn't support connection status reports\n        // assume that we are online because most apps' only react\n        // when they now that the connection has been interrupted\n        this.isOnline = true;\n      } else {\n        this.isOnline = window.navigator.onLine;\n      }\n    },\n  },\n\n  components: { NuxtLoading }\n};\n</script>\n<template>\n  <div id=\"__nuxt\">\n    <NuxtLoading ref=\"loading\" />\n    <div\n      id=\"__layout\"\n    >\n      <router-view />\n    </div>\n  </div>\n</template>\n"]}]}