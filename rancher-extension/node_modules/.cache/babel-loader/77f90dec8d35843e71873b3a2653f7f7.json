pCJ,oBAYM,OAZN,UAYM;gBAXJ,aAUE;kBATQ,KAAK,EAAE,KAAK,CAAC,GAAG,CAAC,KAAK,CAAC,IAAI;gDAApB,KAAK,CAAC,GAAG,CAAC,KAAK,CAAC,IAAI;kBAClC,IAAI,EAAE,WAAI;kBACV,OAAO,EAAE,uBAAiB;kBAC1B,QAAQ,EAAE,KAAK;kBACf,QAAQ,EAAE,IAAI;kBACd,UAAU,EAAE,IAAI;kBAChB,QAAQ,EAAE,IAAI;kBACd,OAAO,EAAEA,MAAC;kBACV,KAAK,EAAEA,MAAC;;;;cAGb,oBAUM,OAVN,UAUM;gBATJ,aAQE;kBAPQ,KAAK,EAAS,KAAK,CAAC,GAAG,CAAC,KAAK,CAAC,KAAK;gDAArB,KAAK,CAAC,GAAG,CAAC,KAAK,CAAC,KAAK;kCAA3C,gBAA4C;kBAC3C,IAAI,EAAE,WAAI;kBACX,IAAI,EAAC,QAAQ;kBACb,GAAG,EAAC,GAAG;kBACN,QAAQ,EAAE,IAAI;kBACd,OAAO,EAAEA,MAAC;kBACV,KAAK,EAAEA,MAAC;;;;cAGb,oBAWM,OAXN,UAWM;gBAVJ,aASE;kBARQ,KAAK,EAAS,KAAK,CAAC,GAAG,CAAC,KAAK,CAAC,aAAa;gDAA7B,KAAK,CAAC,GAAG,CAAC,KAAK,CAAC,aAAa;kCAAnD,gBAAoD;kBACnD,IAAI,EAAE,WAAI;kBACX,IAAI,EAAC,QAAQ;kBACb,GAAG,EAAC,GAAG;kBACP,GAAG,EAAC,MAAM;kBACT,QAAQ,EAAE,IAAI;kBACd,OAAO,EAAEA,MAAC;kBACV,KAAK,EAAEA,MAAC;;;;;;;;;;IAQvB,oBAwBM,OAxBN,UAwBM;MAvBJ,oBAWM,OAXN,UAWM;QAVJ,aASE;UARQ,KAAK,EAAE,YAAK,CAAC,IAAI,CAAC,QAAQ,CAAC,WAAI,EAAE,YAAY;kEAAtC,YAAK,CAAC,IAAI,CAAC,QAAQ,CAAC,WAAI,EAAE,YAAY;UACpD,IAAI,EAAE,WAAI;UACV,OAAO,EAAE,yBAAmB;UAC5B,QAAQ,EAAE,KAAK;UACf,QAAQ,EAAE,IAAI;UACd,UAAU,EAAE,IAAI;UAChB,KAAK,EAAEA,MAAC;UACR,OAAO,EAAEA,MAAC;;;;MAGf,oBAUM,OAVN,UAUM;QATJ,aAQE;UAPQ,KAAK,EAAS,YAAK,CAAC,IAAI,CAAC,QAAQ,CAAC,WAAI,EAAE,0BAA0B;kEAApD,YAAK,CAAC,IAAI,CAAC,QAAQ,CAAC,WAAI,EAAE,0BAA0B;0BAA1E,gBAA2E;UAC1E,IAAI,EAAE,WAAI;UACX,IAAI,EAAC,QAAQ;UACb,GAAG,EAAC,GAAG;UACP,GAAG,EAAC,MAAM;UACT,KAAK,EAAEA,MAAC;UACR,OAAO,EAAEA,MAAC;;;;;8BAIjB,oBAAyB,SAApB,KAAK,EAAC,WAAW","sourcesContent":["<script>\n\nimport { _EDIT } from '@shell/config/query-params';\nimport LabeledSelect from '@shell/components/form/LabeledSelect.vue';\nimport { LabeledInput } from '@components/Form/LabeledInput';\nimport ArrayListGrouped from '@shell/components/form/ArrayListGrouped.vue';\n\nexport default {\n  components: {\n    ArrayListGrouped,\n    LabeledInput,\n    LabeledSelect\n  },\n  props: {\n    value: {\n      type:    Object,\n      default: () => {\n      }\n    },\n    mode: {\n      type:    String,\n      default: _EDIT\n    },\n    type: {\n      type:    String,\n      default: 'scaleUp'\n    },\n  },\n  data() {\n    if (!this.value.spec.behavior[this.type].policies) {\n      this.value.spec.behavior[this.type]['policies'] = [];\n    }\n    if (!this.value.spec.behavior[this.type].selectPolicy) {\n      this.value.spec.behavior[this.type]['selectPolicy'] = 'Max';\n    }\n    if (this.value.spec.behavior[this.type].stabilizationWindowSeconds === null || typeof this.value.spec.behavior[this.type].stabilizationWindowSeconds === 'undefined') {\n      if (this.type === 'scaleUp') {\n        this.value.spec.behavior[this.type]['stabilizationWindowSeconds'] = 0;\n      }\n      if (this.type === 'scaleDown') {\n        this.value.spec.behavior[this.type]['stabilizationWindowSeconds'] = 300;\n      }\n    }\n\n    return { selectPolicyOptions: ['Max', 'Min', 'Disabled'], policyTypeOptions: ['Pods', 'Percent'] };\n  },\n};\n</script>\n\n<template>\n  <div>\n    <div class=\"row mb-20\">\n      <div class=\"col span-12\">\n        <ArrayListGrouped\n          v-model:value=\"value.spec.behavior[type].policies\"\n          :add-label=\"t('hpa.scalingRule.addPolicy')\"\n          :default-add-value=\"{}\"\n          :mode=\"mode\"\n        >\n          <template #default=\"props\">\n            <div class=\"row\">\n              <div class=\"col span-4\">\n                <LabeledSelect\n                  v-model:value=\"props.row.value.type\"\n                  :mode=\"mode\"\n                  :options=\"policyTypeOptions\"\n                  :multiple=\"false\"\n                  :taggable=\"true\"\n                  :searchable=\"true\"\n                  :required=\"true\"\n                  :tooltip=\"t('hpa.scalingRule.policy.typeTooltip')\"\n                  :label=\"t('hpa.scalingRule.policy.type')\"\n                />\n              </div>\n              <div class=\"col span-4\">\n                <LabeledInput\n                  v-model:value.number=\"props.row.value.value\"\n                  :mode=\"mode\"\n                  type=\"number\"\n                  min=\"1\"\n                  :required=\"true\"\n                  :tooltip=\"t('hpa.scalingRule.policy.valueTooltip')\"\n                  :label=\"t('hpa.scalingRule.policy.value')\"\n                />\n              </div>\n              <div class=\"col span-4\">\n                <LabeledInput\n                  v-model:value.number=\"props.row.value.periodSeconds\"\n                  :mode=\"mode\"\n                  type=\"number\"\n                  min=\"1\"\n                  max=\"1800\"\n                  :required=\"true\"\n                  :tooltip=\"t('hpa.scalingRule.policy.periodSecondsTooltip')\"\n                  :label=\"t('hpa.scalingRule.policy.periodSeconds')\"\n                />\n              </div>\n            </div>\n          </template>\n        </ArrayListGrouped>\n      </div>\n    </div>\n    <div class=\"row\">\n      <div class=\"col span-6\">\n        <LabeledSelect\n          v-model:value=\"value.spec.behavior[type].selectPolicy\"\n          :mode=\"mode\"\n          :options=\"selectPolicyOptions\"\n          :multiple=\"false\"\n          :taggable=\"true\"\n          :searchable=\"true\"\n          :label=\"t('hpa.scalingRule.selectPolicy')\"\n          :tooltip=\"t('hpa.scalingRule.selectPolicyTooltip')\"\n        />\n      </div>\n      <div class=\"col span-6\">\n        <LabeledInput\n          v-model:value.number=\"value.spec.behavior[type].stabilizationWindowSeconds\"\n          :mode=\"mode\"\n          type=\"number\"\n          min=\"0\"\n          max=\"3600\"\n          :label=\"t('hpa.scalingRule.stabilizationWindowSeconds')\"\n          :tooltip=\"t('hpa.scalingRule.stabilizationWindowSecondsTooltip')\"\n        />\n      </div>\n    </div>\n    <div class=\"row mb-40\" />\n  </div>\n</template>\n"]}]}