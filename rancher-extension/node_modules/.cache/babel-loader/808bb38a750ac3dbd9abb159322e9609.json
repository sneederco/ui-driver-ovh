C,oBAAoB;sEAAzB,aAAI,CAAC,oBAAoB;cACxC,IAAI,EAAC,MAAM;cACX,WAAW,EAAC,WAAW;cACtB,IAAI,EAAE,WAAI;cACV,KAAK,EAAEA,MAAC;;;;UAGb,oBAQM,OARN,UAQM;YAPJ,aAME;cALQ,KAAK,EAAE,aAAI,CAAC,iBAAiB;sEAAtB,aAAI,CAAC,iBAAiB;cACpC,IAAI,EAAE,WAAI;cACV,KAAK,EAAEA,MAAC;cACR,MAAM,EAAE,eAAQ,GAAGA,MAAC,sCAAsCA,MAAC;cAC3D,OAAO,EAAE,eAAQ,GAAGA,MAAC,kDAAkD,SAAS;;;;;;KAKvE,aAAI,CAAC,gBAAgB;uBAArC,oBAqBW;oCApBT,oBAAsB,SAAjB,KAAK,EAAC,QAAQ;;UAEnB,aAQE;YAPC,KAAK,EAAE,eAAQ;YAChB,IAAI,EAAC,SAAS;YACb,OAAO,EAAE,aAAa;YACtB,KAAK,EAAEA,MAAC;YACR,MAAM,GAAGA,MAAC,oBAAoBA,MAAC;YAC/B,IAAI,EAAE,WAAI;YACV,gBAAY,EAAE,wBAAe;;;WAIxB,eAAQ;6BADhB,aAOE;;gBALQ,KAAK,EAAE,aAAI,CAAC,EAAE;wEAAP,aAAI,CAAC,EAAE;gBACrB,SAAS,EAAE,YAAK,CAAC,QAAQ,CAAC,SAAS;gBACnC,sBAAoB,EAAE,yBAAkB;gBACxC,IAAI,EAAE,WAAI;gBACV,mBAAiB,uCAAEC,UAAK,4BAA4B,MAAM;;;;;;gCAI/D,oBAAsB,SAAjB,KAAK,EAAC,QAAQ;;IAEnB,oBAaM,OAbN,UAaM;MAZJ,oBAWM,OAXN,UAWM;SATI,8BAAqB;2BAD7B,aASE;;cAPC,KAAK,EAAE,gCAAuB;cAC/B,IAAI,EAAC,qBAAqB;cACzB,OAAO,EAAE,aAAa;cACtB,KAAK,EAAED,MAAC;cACR,MAAM,GAAGA,MAAC,0CAA0CA,MAAC;cACrD,IAAI,EAAE,WAAI;cACV,gBAAY,uCAAEC,UAAK,uCAAuC,MAAM","sourcesContent":["<script>\nimport { LabeledInput } from '@components/Form/LabeledInput';\n\nimport { RadioGroup } from '@components/Form/Radio';\n\nimport S3Config from '@shell/edit/provisioning.cattle.io.cluster/tabs/etcd/S3Config';\nimport UnitInput from '@shell/components/form/UnitInput';\n\nexport default {\n  emits: ['s3-backup-changed', 'config-etcd-expose-metrics-changed', 'etcd-validation-changed'],\n\n  components: {\n    LabeledInput,\n    RadioGroup,\n    S3Config,\n    UnitInput\n  },\n\n  props: {\n    mode: {\n      type:     String,\n      required: true,\n    },\n\n    value: {\n      type:     Object,\n      required: true,\n    },\n    selectedVersion: {\n      type:     Object,\n      required: true,\n    },\n\n    s3Backup: {\n      type:     Boolean,\n      required: false,\n      default:  false\n    },\n    registerBeforeHook: {\n      type:     Function,\n      required: true,\n    },\n\n  },\n\n  computed: {\n    etcd() {\n      return this.value.spec.rkeConfig.etcd;\n    },\n    argsEtcdExposeMetrics() {\n      return !!this.selectedVersion?.serverArgs?.['etcd-expose-metrics'];\n    },\n    configEtcdExposeMetrics() {\n      return !!this.value.spec.rkeConfig.machineGlobalConfig['etcd-expose-metrics'];\n    },\n  },\n  methods: {\n    s3BackupChanged(val) {\n      this.$emit('s3-backup-changed', val);\n      this.$emit('etcd-validation-changed', !val);\n    },\n    disableSnapshotsChanged(val) {\n      if (val) {\n        this.$emit('etcd-validation-changed', true);\n        this.$emit('s3-backup-changed', false);\n      }\n    }\n  }\n};\n</script>\n\n<template>\n  <div>\n    <div class=\"row\">\n      <div class=\"col span-6\">\n        <RadioGroup\n          v-model:value=\"etcd.disableSnapshots\"\n          name=\"etcd-disable-snapshots\"\n          :options=\"[true, false]\"\n          :label=\"t('cluster.rke2.etcd.disableSnapshots.label')\"\n          :labels=\"[t('generic.disable'), t('generic.enable')]\"\n          :mode=\"mode\"\n          @update:value=\"disableSnapshotsChanged\"\n        />\n      </div>\n    </div>\n    <div\n      v-if=\"etcd.disableSnapshots !== true\"\n      class=\"row\"\n    >\n      <div class=\"col span-6\">\n        <LabeledInput\n          v-model:value=\"etcd.snapshotScheduleCron\"\n          type=\"cron\"\n          placeholder=\"0 * * * *\"\n          :mode=\"mode\"\n          :label=\"t('cluster.rke2.etcd.snapshotScheduleCron.label')\"\n        />\n      </div>\n      <div class=\"col span-6\">\n        <UnitInput\n          v-model:value=\"etcd.snapshotRetention\"\n          :mode=\"mode\"\n          :label=\"t('cluster.rke2.etcd.snapshotRetention.label')\"\n          :suffix=\"s3Backup ? t('cluster.rke2.snapshots.s3Suffix') : t('cluster.rke2.snapshots.suffix')\"\n          :tooltip=\"s3Backup ? t('cluster.rke2.etcd.snapshotRetention.tooltip') : undefined\"\n        />\n      </div>\n    </div>\n\n    <template v-if=\"etcd.disableSnapshots !== true\">\n      <div class=\"spacer\" />\n\n      <RadioGroup\n        :value=\"s3Backup\"\n        name=\"etcd-s3\"\n        :options=\"[false, true]\"\n        :label=\"t('cluster.rke2.etcd.s3backups.label')\"\n        :labels=\"[t('generic.disable'),t('generic.enable')]\"\n        :mode=\"mode\"\n        @update:value=\"s3BackupChanged\"\n      />\n\n      <S3Config\n        v-if=\"s3Backup\"\n        v-model:value=\"etcd.s3\"\n        :namespace=\"value.metadata.namespace\"\n        :register-before-hook=\"registerBeforeHook\"\n        :mode=\"mode\"\n        @validationChanged=\"$emit('etcd-validation-changed', $event)\"\n      />\n    </template>\n\n    <div class=\"spacer\" />\n\n    <div class=\"row\">\n      <div class=\"col span-6\">\n        <RadioGroup\n          v-if=\"argsEtcdExposeMetrics\"\n          :value=\"configEtcdExposeMetrics\"\n          name=\"etcd-expose-metrics\"\n          :options=\"[false, true]\"\n          :label=\"t('cluster.rke2.etcd.exportMetric.label')\"\n          :labels=\"[t('cluster.rke2.etcd.exportMetric.false'), t('cluster.rke2.etcd.exportMetric.true')]\"\n          :mode=\"mode\"\n          @update:value=\"$emit('config-etcd-expose-metrics-changed', $event)\"\n        />\n      </div>\n    </div>\n  </div>\n</template>\n"]}]}