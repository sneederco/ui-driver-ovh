{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/CopyToClipboardText.vue?vue&type=template&id=d7ed0a12&scoped=true","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/CopyToClipboardText.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/CopyToClipboardText.vue"],"names":["t","$attrs"],"mappings":";;;;;;UAgDU,WAAI;qBADZ,oBAiBI,KAjBJ,YAiBI;;QAfF,KAAK,GAAC,wBAAwB,cAEV,YAAM,WAAW,YAAK;QAD1C,IAAI,EAAC,QAAQ;QAEb,IAAI,EAAC,GAAG;QACP,YAAU,EAAEA,MAAC;SACNC,WAAM;QACb,OAAK,0CAAE,6CAAO;QACd,OAAK,oDAAQ,6CAAO;;0CAElB,WAAI,IAAG,GACV;QAAA,oBAIE;UAHA,KAAK,mBAAC,MAAM,kBACY,YAAM,oBAAoB,YAAM;UACvD,GAAG,GAAG,YAAM,GAAGD,MAAC,8BAA8BA,MAAC","sourcesContent":["<script>\nimport { copyTextToClipboard } from '@shell/utils/clipboard';\nimport { exceptionToErrorsArray } from '@shell/utils/error';\nexport default {\n  emits: ['error'],\n\n  props: {\n    text: {\n      type:     String,\n      required: true,\n    },\n    // Show as plain - don't show in link style\n    plain: {\n      type:    Boolean,\n      default: false\n    }\n  },\n\n  data() {\n    return { copied: false };\n  },\n\n  methods: {\n    clicked(event) {\n      if (!this.copied) {\n        event.preventDefault();\n        copyTextToClipboard(this.text).then(() => {\n          this.copied = true;\n\n          let t = event.target;\n\n          if (t.tagName === 'I') {\n            t = t.parentElement || t;\n          }\n          setTimeout(() => {\n            this.copied = false;\n          }, 500);\n        }).catch((e) => {\n          this.$emit('error', exceptionToErrorsArray(e));\n        });\n      }\n    },\n  }\n};\n</script>\n\n<template>\n  <a\n    v-if=\"text\"\n    class=\"copy-to-clipboard-text\"\n    role=\"button\"\n    :class=\"{ 'copied': copied, 'plain': plain}\"\n    href=\"#\"\n    :aria-label=\"t('generic.copyToClipboard')\"\n    v-bind=\"$attrs\"\n    @click=\"clicked\"\n    @keyup.space=\"clicked\"\n  >\n    {{ text }}\n    <i\n      class=\"icon\"\n      :class=\"{ 'icon-copy': !copied, 'icon-checkmark': copied}\"\n      :alt=\"!copied ? t('generic.copyToClipboard') : t('generic.copiedToClipboard')\"\n    />\n  </a>\n</template>\n<style lang=\"scss\" scoped>\n  .copy-to-clipboard-text {\n    white-space: nowrap;\n    &.plain {\n      color: var(--body-text);\n\n      &:hover {\n        text-decoration: none;\n      }\n    }\n\n    &.copied {\n      pointer-events: none;\n      color: var(--success);\n    }\n  }\n</style>\n"]}]}