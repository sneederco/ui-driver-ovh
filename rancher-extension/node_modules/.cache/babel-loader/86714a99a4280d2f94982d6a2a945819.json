{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/form/Command.vue?vue&type=template&id=659f4d28","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/form/Command.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/form/Command.vue"],"names":["t"],"mappings":";;qBAqHS,KAAK,EAAC,KAAK;;EAEZ,KAAK,EAAC,YAAY;EAClB,aAAW,EAAC,uBAAuB;;;EAanC,KAAK,EAAC,YAAY;EAClB,aAAW,EAAC,oBAAoB;;qBAc/B,KAAK,EAAC,WAAW;;EAElB,KAAK,EAAC,YAAY;EAClB,aAAW,EAAC,0BAA0B;;qBAUnC,KAAK,EAAC,YAAY;;EAElB,KAAK,EAAE,2BAA2B;EACnC,KAAK,EAAC,KAAK;;;EAGT,KAAK,EAAC,YAAY;EAClB,aAAW,EAAC,qBAAqB;;;;EAYjC,KAAK,EAAC,YAAY;EAClB,aAAW,EAAC,mBAAmB;;;;;;;;;;wBAjEzC,oBAsFM;IArFJ,oBA6BM,OA7BN,UA6BM;MA5BJ,oBAaM,OAbN,UAaM;QATJ,YAQO,+BARP,CAQO;UAPL,aAME;YALQ,KAAK,EAAE,aAAO;;oDAAP,aAAO;cAIP,eAAM;;YAHpB,IAAI,EAAE,WAAI;YACV,KAAK,EAAEA,MAAC;YACR,WAAW,EAAEA,MAAC;;;;;MAKrB,oBAaM,OAbN,UAaM;QATJ,YAQO,4BARP,CAQO;UAPL,aAME;YALQ,KAAK,EAAE,UAAI;;oDAAJ,UAAI;cAIJ,eAAM;;YAHpB,IAAI,EAAE,WAAI;YACV,KAAK,EAAEA,MAAC;YACR,WAAW,EAAEA,MAAC;;;;;;IAOvB,oBA4CM,OA5CN,UA4CM;MA3CJ,oBAWM,OAXN,UAWM;QAPJ,aAME;UALQ,KAAK,EAAE,gBAAU;;kDAAV,gBAAU;YAIV,eAAM;;UAHpB,IAAI,EAAE,WAAI;UACV,KAAK,EAAEA,MAAC;UACR,WAAW,EAAEA,MAAC;;;;MAInB,oBA8BM,OA9BN,UA8BM;QA7BJ,oBA4BM,OA5BN,UA4BM;UAxBJ,oBAWM,OAXN,UAWM;YAPJ,aAME;cALQ,KAAK,EAAE,oBAAW;;sDAAX,oBAAW;gBAIX,eAAM;;cAHpB,KAAK,EAAEA,MAAC;cACR,OAAO,EAAE,oBAAc;cACvB,IAAI,EAAE,WAAI;;;;WAKP,WAAK;6BADb,oBAWM,OAXN,UAWM;gBANJ,aAKE;kBAJQ,KAAK,EAAE,SAAG;;0DAAH,SAAG;oBAGH,eAAM;;kBAFpB,IAAI,EAAE,WAAI;kBACV,KAAK,EAAEA,MAAC;;;;;;;;gCAOnB,oBAAsB,SAAjB,KAAK,EAAC,QAAQ;;IACnB,oBAAiD,6BAA1CA,MAAC;;IACR,aAME;MALC,IAAI,EAAE,WAAI;MACV,aAAW,EAAE,iBAAU;MACvB,OAAO,EAAE,cAAO;MAChB,KAAK,EAAE,YAAK;MACZ,OAAO,EAAE,cAAO","sourcesContent":["<script>\nimport { LabeledInput } from '@components/Form/LabeledInput';\nimport ShellInput from '@shell/components/form/ShellInput';\nimport LabeledSelect from '@shell/components/form/LabeledSelect';\nimport { Checkbox } from '@components/Form/Checkbox';\nimport EnvVars from '@shell/components/form/EnvVars';\n\nexport default {\n  emits: ['update:value'],\n\n  components: {\n    LabeledInput,\n    ShellInput,\n    LabeledSelect,\n    Checkbox,\n    EnvVars,\n  },\n\n  props: {\n    mode: {\n      type:     String,\n      required: true,\n    },\n    configMaps: {\n      type:    Array,\n      default: () => [],\n    },\n    secrets: {\n      type:    Array,\n      default: () => [],\n    },\n    // container spec\n    value: {\n      type:    Object,\n      default: () => {\n        return {};\n      },\n    },\n    loading: {\n      default: false,\n      type:    Boolean\n    },\n  },\n\n  data() {\n    return {\n      args:           this.value.args,\n      command:        this.value.command,\n      commandOptions: ['No', 'Once', 'Yes'],\n      stdin:          this.value.stdin || false,\n      stdinOnce:      this.value.stdin || false,\n      tty:            this.value.tty || false,\n      workingDir:     this.value.workingDir,\n    };\n  },\n\n  computed: {\n    stdinSelect: {\n      get() {\n        if (this.stdin) {\n          if (this.stdinOnce) {\n            return 'Once';\n          }\n\n          return 'Yes';\n        }\n\n        return 'No';\n      },\n      set(neu) {\n        switch (neu) {\n        case 'Yes':\n          this.stdin = true;\n          this.stdinOnce = false;\n          break;\n        case 'Once':\n          this.stdin = true;\n          this.stdinOnce = true;\n          break;\n        default:\n          this.stdin = false;\n          this.stdinOnce = false;\n          this.tty = false;\n          break;\n        }\n      },\n    },\n  },\n\n  methods: {\n    update() {\n      const out = {\n        stdin:      this.stdin,\n        stdinOnce:  this.stdinOnce,\n        command:    this.command,\n        args:       this.args,\n        workingDir: this.workingDir,\n        tty:        this.tty,\n      };\n\n      for (const prop in out) {\n        const val = out[prop];\n\n        if (val === '' || typeof val === 'undefined' || val === null) {\n          delete this.value[prop];\n        } else {\n          this.value[prop] = val;\n        }\n      }\n\n      this.$emit('update:value', this.value);\n    },\n  },\n};\n</script>\n<template>\n  <div>\n    <div class=\"row\">\n      <div\n        class=\"col span-6\"\n        data-testid=\"input-command-command\"\n      >\n        <slot name=\"entrypoint\">\n          <ShellInput\n            v-model:value=\"command\"\n            :mode=\"mode\"\n            :label=\"t('workload.container.command.command')\"\n            :placeholder=\"t('generic.placeholder', {text: '/bin/sh'}, true)\"\n            @update:value=\"update\"\n          />\n        </slot>\n      </div>\n      <div\n        class=\"col span-6\"\n        data-testid=\"input-command-args\"\n      >\n        <slot name=\"command\">\n          <ShellInput\n            v-model:value=\"args\"\n            :mode=\"mode\"\n            :label=\"t('workload.container.command.args')\"\n            :placeholder=\"t('generic.placeholder', {text: '/usr/sbin/httpd -f httpd.conf'}, true)\"\n            @update:value=\"update\"\n          />\n        </slot>\n      </div>\n    </div>\n\n    <div class=\"row mt-20\">\n      <div\n        class=\"col span-6\"\n        data-testid=\"input-command-workingDir\"\n      >\n        <LabeledInput\n          v-model:value=\"workingDir\"\n          :mode=\"mode\"\n          :label=\"t('workload.container.command.workingDir')\"\n          :placeholder=\"t('generic.placeholder', {text: '/myapp'}, true)\"\n          @update:value=\"update\"\n        />\n      </div>\n      <div class=\"col span-6\">\n        <div\n          :style=\"{ 'align-items': 'center' }\"\n          class=\"row\"\n        >\n          <div\n            class=\"col span-6\"\n            data-testid=\"input-command-stdin\"\n          >\n            <LabeledSelect\n              v-model:value=\"stdinSelect\"\n              :label=\"t('workload.container.command.stdin')\"\n              :options=\"commandOptions\"\n              :mode=\"mode\"\n              @update:value=\"update\"\n            />\n          </div>\n          <div\n            v-if=\"stdin\"\n            class=\"col span-6\"\n            data-testid=\"input-command-tty\"\n          >\n            <Checkbox\n              v-model:value=\"tty\"\n              :mode=\"mode\"\n              :label=\"t('workload.container.command.tty')\"\n              @update:value=\"update\"\n            />\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"spacer\" />\n    <h3>{{ t('workload.container.titles.env') }}</h3>\n    <EnvVars\n      :mode=\"mode\"\n      :config-maps=\"configMaps\"\n      :secrets=\"secrets\"\n      :value=\"value\"\n      :loading=\"loading\"\n    />\n  </div>\n</template>\n"]}]}