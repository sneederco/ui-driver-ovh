{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/Endpoints.vue?vue&type=template&id=97d8db82","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/Endpoints.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/Endpoints.vue"],"names":[],"mappings":";;;;;;wBAmFE,oBAqBO;uBApBL,oBAmBW,6BAlBmB,eAAM,GAA1B,QAAQ,EAAE,KAAK;kEACjB,KAAK;SAGH,QAAQ,CAAC,OAAO;2BADxB,oBAI8B;cAF3B,GAAG,EAAE,QAAQ,CAAC,OAAO;cACtB,KAAK,EAAC,OAAO;gCACX,QAAQ,CAAC,OAAO;2BACpB,oBASI;cAPD,GAAG,EAAE,KAAK,GAAG,QAAQ,CAAC,IAAI;cAC3B,KAAK,EAAC,OAAO;cACZ,IAAI,EAAE,QAAQ,CAAC,IAAI;cACpB,MAAM,EAAC,QAAQ;cACf,GAAG,EAAC,8BAA8B;;eAEtB,QAAQ,CAAC,IAAI;iCAAzB,oBAAsD,qCAAxB,QAAQ,CAAC,IAAI,IAAG,GAAC;;gDAAU,QAAQ,CAAC,QAAQ","sourcesContent":["<script>\nimport { NODE } from '@shell/config/types';\n\nexport default {\n  props: {\n    value: {\n      type:    [Array, String],\n      default: null,\n    },\n    row: {\n      type:     Object,\n      required: true\n    },\n    col: {\n      type:     Object,\n      required: true\n    },\n  },\n\n  computed: {\n    nodes() {\n      return this.$store.getters['cluster/all'](NODE);\n    },\n    // value may be JSON from \"field.cattle.io/publicEndpoints\" label\n    parsed() {\n      const nodes = this.nodes;\n      const nodeWithExternal = nodes.find((node) => !!node.externalIp) || {};\n      const externalIp = nodeWithExternal.externalIp;\n\n      if ( this.value?.length ) {\n        let out ;\n\n        try {\n          out = JSON.parse(this.value);\n          out.forEach((endpoint) => {\n            let protocol = 'http';\n\n            if (endpoint.port === 443) {\n              protocol = 'https';\n            }\n\n            if (endpoint.addresses) {\n              endpoint.link = `${ protocol }://${ endpoint.addresses[0] }:${ endpoint.port }`;\n            } else if (externalIp) {\n              endpoint.link = `${ protocol }://${ externalIp }:${ endpoint.port }`;\n            } else {\n              endpoint.display = `[${ this.t('servicesPage.anyNode') }]:${ endpoint.port }`;\n            }\n          });\n\n          return out;\n        } catch (err) {\n          return this.value[0];\n        }\n      }\n\n      return null;\n    },\n\n    protocol() {\n      const { parsed } = this;\n\n      if ( parsed) {\n        if (this.parsed[0].protocol) {\n          return this.parsed[0].protocol;\n        }\n\n        const match = parsed.match(/^([^:]+):\\/\\//);\n\n        if ( match ) {\n          return match[1];\n        } else {\n          return 'link';\n        }\n      }\n\n      return null;\n    }\n  },\n};\n</script>\n\n<template>\n  <span>\n    <template\n      v-for=\"(endpoint, index) in parsed\"\n      :key=\"index\"\n    >\n      <span\n        v-if=\"endpoint.display\"\n        :key=\"endpoint.display\"\n        class=\"block\"\n      >{{ endpoint.display }}</span>\n      <a\n        v-else\n        :key=\"index + endpoint.link\"\n        class=\"block\"\n        :href=\"endpoint.link\"\n        target=\"_blank\"\n        rel=\"nofollow noopener noreferrer\"\n      >\n        <span v-if=\"endpoint.port\">{{ endpoint.port }}/</span>{{ endpoint.protocol }}\n      </a>\n    </template>\n  </span>\n</template>\n"]}]}