efault-text\"\r\n      />\r\n    </template>\r\n\r\n    <template #body>\r\n      <div class=\"pl-10 pr-10\">\r\n        <ClusterPermissionsEditor\r\n          v-model:value=\"bindings\"\r\n          :use-two-columns-for-custom=\"true\"\r\n        />\r\n      </div>\r\n    </template>\r\n\r\n    <template #actions>\r\n      <div class=\"buttons\">\r\n        <button\r\n          class=\"btn role-secondary mr-10\"\r\n          @click=\"close\"\r\n        >\r\n          {{ t('generic.cancel') }}\r\n        </button>\r\n\r\n        <button\r\n          class=\"btn role-primary\"\r\n          @click=\"apply\"\r\n        >\r\n          {{ t('generic.add') }}\r\n        </button>\r\n      </div>\r\n    </template>\r\n  </Card>\r\n</template>\r\n<style lang='scss' scoped>\r\n  .prompt-rotate {\r\n    margin: 0;\r\n  }\r\n  .buttons {\r\n    display: flex;\r\n    justify-content: flex-end;\r\n    width: 100%;\r\n  }\r\n</style>\r\n"]}]}