{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/VirtualServiceGateways.vue?vue&type=template&id=381016ef","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/VirtualServiceGateways.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/VirtualServiceGateways.vue"],"names":["t"],"mappings":";;;;;EAyGM,KAAK,EAAC,YAAY;;;;;;wBAdtB,oBAkBO;uBAjBL,oBAUO,6BATkB,iBAAQ,GAAvB,OAAO,EAAE,CAAC;4BADpB,oBAUO,UARJ,GAAG,EAAE,CAAC;SAES,CAAC;2BAAjB,oBAKW;cAJT,aAEc;gBAFA,EAAE,EAAE,qBAAY,CAAC,OAAO;;kCACpC,CAAqC;oDAAlC,qBAAY,CAAC,OAAO,EAAE,MAAM,CAAC,EAAE;;;;;eAExB,CAAC,CAAC,iBAAQ,CAAC,MAAM,MAAM,CAAC;iCAApC,oBAAkD,oBAAR,GAAC;;;;;;;KAIvC,iBAAQ,CAAC,MAAM;uBADvB,oBAKO,QALP,UAKO,mBADFA,MAAC,yBAAyB,iBAAQ,CAAC,MAAM","sourcesContent":["<script>\nimport { get } from '@shell/utils/object';\nimport { ISTIO } from '@shell/config/types';\nimport { mapGetters } from 'vuex';\nexport default {\n  props: {\n    value: {\n      type:    Object,\n      default: () => {\n        return {};\n      }\n    },\n\n    row: {\n      type:    Object,\n      default: () => {\n        return {};\n      }\n    }\n  },\n\n  computed: {\n    gateways() {\n      const out = [];\n      const gateways = get(this.value, 'gateways');\n      const httpMatches = (get(this.value, 'http') || []).reduce((matches, httpRoute) => {\n        if (httpRoute.match) {\n          matches.push(...httpRoute.match);\n\n          return matches;\n        }\n      }, []);\n      const tlsMatches = (get(this.value, 'tls') || []).reduce((matches, tlsRoute) => {\n        if (tlsRoute.match) {\n          matches.push(...tlsRoute.match);\n\n          return matches;\n        }\n      }, []);\n\n      if (gateways) {\n        out.push(...gateways);\n      }\n\n      if (httpMatches && typeof httpMatches === 'object') {\n        httpMatches.forEach((matchBlock) => {\n          if (matchBlock.gateways) {\n            out.push(...matchBlock.gateways);\n          }\n        });\n      }\n\n      if (tlsMatches && typeof tlsMatches === 'object') {\n        tlsMatches.forEach((matchBlock) => {\n          if (matchBlock.gateways) {\n            out.push(...matchBlock.gateways);\n          }\n        });\n      }\n\n      return out;\n    },\n    ...mapGetters({ t: 'i18n/t' })\n  },\n\n  methods: {\n    gatewayLinks(name) {\n      let namespace;\n\n      if (!name.includes('/')) {\n        namespace = get(this.row, 'metadata.namespace') || 'istio-system';\n      } else {\n        [namespace, name] = name.split('/');\n      }\n      const routeParams = this.$route.params;\n      const routeName = 'c-cluster-product-resource-namespace-id';\n      const params = {\n        ...routeParams,\n        product:  'istio',\n        resource: ISTIO.GATEWAY,\n        namespace,\n        id:       name\n      };\n\n      return { name: routeName, params };\n    }\n  }\n};\n</script>\n\n<template>\n  <span>\n    <span\n      v-for=\"(gateway, i) in gateways\"\n      :key=\"i\"\n    >\n      <template v-if=\"i < 5\">\n        <router-link :to=\"gatewayLinks(gateway)\">\n          {{ gatewayLinks(gateway).params.id }}\n        </router-link>\n        <span v-if=\"i<gateways.length-1 && i < 4\">,</span>\n      </template>\n    </span>\n    <span\n      v-if=\"gateways.length>7\"\n      class=\"text-muted\"\n    >\n      {{ t('generic.plusMore', {n: gateways.length-4}) }}\n    </span>\n  </span>\n</template>\n"]}]}