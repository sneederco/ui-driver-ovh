{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/FleetSummaryGraph.vue?vue&type=template&id=468391be","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/FleetSummaryGraph.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/FleetSummaryGraph.vue"],"names":[],"mappings":";;;;;;EA8EQ,KAAK,EAAC,OAAO;;qBAaL,KAAK,EAAC,YAAY;;;EAU9B,KAAK,EAAC,wBAAwB;;;;;;;UAxCxB,aAAI;qBADZ,aAsCa;;QApCX,KAAK,EAAC,kBAAkB;QACxB,SAAS,EAAC,KAAK;QACd,YAAU,EAAE,UAAG,CAAC,EAAE;QAClB,QAAQ,EAAE,aAAI;QACf,MAAM,EAAC,GAAG;;QASC,MAAM;WAEP,aAAI;6BADZ,oBAoBQ,SApBR,UAoBQ;gBAhBN,oBAeQ;qCAdN,oBAaK,6BAZgB,mBAAU,GAArB,GAAG,EAAE,CAAC;0CADhB,oBAaK,QAXF,GAAG,EAAE,CAAC;sBAEP,oBAKK;wBAJH,KAAK,mBAAC,iBAAiB,KACZ,GAAG,CAAC,SAAS;0CAErB,GAAG,CAAC,KAAK;;sBAEd,oBAEK,MAFL,UAEK,mBADA,GAAG,CAAC,KAAK;;;;;;;0BAxBtB,CAGE;UAHF,aAGE;YAFC,MAAM,EAAE,mBAAU;YACnB,KAAK,EAAC,MAAM;;;WAEF,gBAAO,CAAC,YAAY,KAAK,gBAAO,CAAC,KAAK;6BAAlD,oBAA8E,qCAAvB,gBAAO,CAAC,KAAK;6BACpE,oBAAqE,qCAArD,gBAAO,CAAC,KAAK,IAAG,MAAI,oBAAG,gBAAO,CAAC,YAAY;;;;;;qBA0B7D,oBAKM,OALN,UAKM,EAFL,aAED","sourcesContent":["<script>\nimport ProgressBarMulti from '@shell/components/ProgressBarMulti';\nimport { ucFirst } from '@shell/utils/string';\nimport { colorForState, stateSort } from '@shell/plugins/dashboard-store/resource-class';\nimport { sortBy } from '@shell/utils/sort';\nimport { FLEET } from '@shell/config/types';\n\nexport default {\n  components: { ProgressBarMulti },\n\n  props: {\n    row: {\n      type:     Object,\n      required: true\n    },\n\n    clusterId: {\n      type:     String,\n      required: false,\n      default:  null,\n    }\n  },\n\n  computed: {\n    summary() {\n      if (this.clusterId) {\n        return this.row.statusResourceCountsForCluster(this.clusterId);\n      }\n\n      return this.row.status?.resourceCounts || {};\n    },\n\n    show() {\n      return this.stateParts.length > 0 && (this.row.type === FLEET.CLUSTER || this.row.targetClusters?.length);\n    },\n\n    stateParts() {\n      const summary = this.summary;\n      const keys = Object.keys(summary).filter((x) => !x.startsWith('desired'));\n\n      const out = keys.map((key) => {\n        const textColor = colorForState(key);\n\n        return {\n          label: ucFirst(key),\n          color: textColor.replace(/text-/, 'bg-'),\n          textColor,\n          value: summary[key],\n          sort:  stateSort(textColor, key),\n        };\n      }).filter((x) => x.value > 0);\n\n      return sortBy(out, 'sort:desc');\n    },\n\n  },\n};\n</script>\n\n<template>\n  <v-dropdown\n    v-if=\"show\"\n    class=\"text-center hand\"\n    placement=\"top\"\n    :show-group=\"row.id\"\n    :triggers=\"show ? ['click'] : []\"\n    offset=\"1\"\n  >\n    <ProgressBarMulti\n      :values=\"stateParts\"\n      class=\"mb-5\"\n    />\n    <span v-if=\"summary.desiredReady === summary.ready\">{{ summary.ready }}</span>\n    <span v-else>{{ summary.ready }} of {{ summary.desiredReady }}</span>\n\n    <template #popper>\n      <table\n        v-if=\"show\"\n        class=\"fixed\"\n      >\n        <tbody>\n          <tr\n            v-for=\"(obj, i) in stateParts\"\n            :key=\"i\"\n          >\n            <td\n              class=\"text-left pr-20\"\n              :class=\"{ [obj.textColor]: true }\"\n            >\n              {{ obj.label }}\n            </td>\n            <td class=\"text-right\">\n              {{ obj.value }}\n            </td>\n          </tr>\n        </tbody>\n      </table>\n    </template>\n  </v-dropdown>\n  <div\n    v-else\n    class=\"text-center text-muted\"\n  >\n    &mdash;\n  </div>\n</template>\n\n<style lang=\"scss\">\n.col-scale {\n  position: relative;\n\n  .trigger {\n    width: 100%;\n  }\n}\n\n.scale {\n  margin: 0;\n  padding: 0;\n  line-height: initial;\n}\n\n.hand {\n  .progress, .progress > .piece {\n    height: 6px;\n    border-right: 1px solid var(--body-bg);\n  }\n}\n</style>\n"]}]}