d: true,\n    },\n\n    mode: {\n      type:     String,\n      required: true,\n    },\n\n    hideSensitiveData: {\n      type:    Boolean,\n      default: true,\n    }\n  },\n\n  computed: {\n    isView() {\n      return this.mode === _VIEW;\n    },\n  },\n\n  methods: {\n    fileModifier(name, value) {\n      if (!VALID_DATA_KEY.test(name)) {\n        name = name\n          .split('')\n          .map((c) => VALID_DATA_KEY.test(c) ? c : '_')\n          .join('');\n      }\n\n      return { name, value };\n    },\n  }\n};\n</script>\n\n<template>\n  <KeyValue\n    key=\"data\"\n    v-model:value=\"value.data\"\n    :mode=\"mode\"\n    :initial-empty-row=\"true\"\n    :handle-base64=\"true\"\n    :value-trim=\"false\"\n    :add-allowed=\"true\"\n    :read-allowed=\"true\"\n    :value-concealed=\"isView && hideSensitiveData\"\n    :file-modifier=\"fileModifier\"\n    :parse-lines-from-file=\"true\"\n    read-icon=\"\"\n    add-icon=\"\"\n  />\n</template>\n"]}]}