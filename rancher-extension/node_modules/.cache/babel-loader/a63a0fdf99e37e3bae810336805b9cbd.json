{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/GrowlManager.vue?vue&type=template&id=7bac6a09&scoped=true","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/GrowlManager.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/GrowlManager.vue"],"names":["stack"],"mappings":";;qBAmGS,KAAK,EAAC,YAAY;;qBAcZ,KAAK,EAAC,gBAAgB;qBAGtB,KAAK,EAAC,YAAY;;;;;;wBAtB/B,oBA6CM;IA5CJ,KAAK,EAAC,iBAAiB;IACtB,YAAU,0CAAE,mDAAU;IACtB,YAAU,0CAAE,mDAAU;;IAEvB,oBAuCM,OAvCN,UAuCM;yBAtCJ,oBAqCM,6BApCmBA,UAAK,GAApB,KAAK,EAAE,GAAG;8BADpB,oBAqCM;UAnCH,GAAG,EAAE,KAAK,CAAC,EAAE;UACd,IAAI,EAAC,OAAO;UACX,iBAAe,kBAAkB,KAAK,CAAC,EAAE;UACzC,kBAAgB,oBAAoB,KAAK,CAAC,EAAE;UAC5C,aAAW,qBAAqB,GAAG;UACnC,KAAK,yCAAyB,KAAK,CAAC,KAAK;;UAE1C,oBA2BM;YA1BJ,KAAK,mBAAC,eAAe,oBACK,KAAK,CAAC,OAAO;;YAEvC,oBAEM,OAFN,UAEM;cADJ,oBAAuD;gBAAnD,KAAK,wCAAwB,KAAK,CAAC,IAAI;;;;YAE7C,oBAmBM,OAnBN,UAmBM;cAlBJ,oBAGE;gBAFA,KAAK,EAAC,4BAA4B;gBACjC,OAAK,aAAE,cAAK,CAAC,KAAK;;;eAGb,KAAK,CAAC,KAAK;iCADnB,oBAMM;;oBAJH,EAAE,kBAAkB,KAAK,CAAC,EAAE;oBAC7B,KAAK,EAAC,kBAAkB;sCAErB,KAAK,CAAC,KAAK;;;eAGR,KAAK,CAAC,OAAO;iCADrB,oBAMI;;oBAJD,EAAE,oBAAoB,KAAK,CAAC,EAAE;oBAC9B,KAAK,mCAAmB,KAAK,CAAC,KAAK;sCAEjC,KAAK,CAAC,OAAO","sourcesContent":["<script>\nimport { mapState } from 'vuex';\n\nexport default {\n  data() {\n    return { autoRemoveTimer: null };\n  },\n\n  computed: {\n    ...mapState('growl', ['stack']),\n\n    shouldRun() {\n      return this.stack.length && this.stack.find((x) => x.timeout > 0);\n    }\n  },\n\n  watch: {\n    stack() {\n      if ( this.shouldRun ) {\n        this.startAutoRemove();\n      } else {\n        this.stopAutoRemove();\n      }\n    },\n  },\n\n  methods: {\n    remove(growl) {\n      this.$store.dispatch('growl/remove', growl.id);\n    },\n\n    close(growl) {\n      this.$store.dispatch('growl/close', growl.id);\n\n      // If a user closes a growl, we won't get the mouse leave event, so we won't start the auto removal\n      // again, leaving to stuck growls that should timeout\n      this.startAutoRemove();\n    },\n\n    closeAll() {\n      this.$store.dispatch('growl/clear');\n    },\n\n    closeExpired() {\n      const now = new Date().getTime();\n\n      // Check that we should still be running the auto-close interval timer\n      if (!this.shouldRun) {\n        this.stopAutoRemove();\n      }\n\n      for ( const growl of this.stack ) {\n        if ( !growl.timeout ) {\n          continue;\n        }\n\n        if ( growl.started + growl.timeout < now ) {\n          this.remove(growl);\n        }\n      }\n    },\n\n    startAutoRemove() {\n      if ( this.autoRemoveTimer || !this.shouldRun ) {\n        return false;\n      }\n\n      this.autoRemoveTimer = setInterval(() => {\n        this.closeExpired();\n      }, 1000);\n\n      return true;\n    },\n\n    stopAutoRemove() {\n      if ( this.autoRemoveTimer ) {\n        clearInterval(this.autoRemoveTimer);\n        this.autoRemoveTimer = null;\n      }\n    },\n\n    mouseEnter() {\n      this.stopAutoRemove();\n    },\n\n    mouseLeave() {\n      this.startAutoRemove();\n    },\n  }\n};\n\n</script>\n\n<template>\n  <div\n    class=\"growl-container\"\n    @mouseenter=\"mouseEnter\"\n    @mouseleave=\"mouseLeave\"\n  >\n    <div class=\"growl-list\">\n      <div\n        v-for=\"(growl, idx) in stack\"\n        :key=\"growl.id\"\n        role=\"alert\"\n        :aria-labelledby=\"`growl-title-${ growl.id }`\"\n        :aria-describedby=\"`growl-message-${ growl.id }`\"\n        :data-testid=\"`growl-list-item-${idx}`\"\n        :class=\"{'growl': true, ['bg-'+growl.color]: true}\"\n      >\n        <div\n          class=\"growl-message\"\n          :class=\"{'growl-center': !growl.message}\"\n        >\n          <div class=\"icon-container\">\n            <i :class=\"{icon: true, ['icon-'+growl.icon]: true}\" />\n          </div>\n          <div class=\"growl-text\">\n            <i\n              class=\"close hand icon icon-close\"\n              @click=\"close(growl)\"\n            />\n            <div\n              v-if=\"growl.title\"\n              :id=\"`growl-title-${ growl.id }`\"\n              class=\"growl-text-title\"\n            >\n              {{ growl.title }}\n            </div>\n            <p\n              v-if=\"growl.message\"\n              :id=\"`growl-message-${ growl.id }`\"\n              :class=\"{ 'has-title': !!growl.title }\"\n            >\n              {{ growl.message }}\n            </p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<style lang=\"scss\" scoped>\n  .growl-container {\n    z-index: 1000;\n    position: absolute;\n    top: var(--header-height);\n    right: 0;\n    width: 100%;\n\n    @media only screen and (min-width: map-get($breakpoints, '--viewport-7')) {\n      width: 420px;\n    }\n  }\n\n  .growl-list {\n    max-height: calc(100vh - 50px);\n    overflow: hidden;\n  }\n\n  .growl {\n    border-radius: var(--border-radius);\n    margin: 10px;\n    position: relative;\n    word-break: break-all;\n    box-shadow: 0 3px 5px 0px var(--shadow);\n\n    $growl-icon-size: 20px;\n\n    .icon-container {\n      align-self: center;\n      flex-basis: 10%;\n      padding: 10px 20px 10px 10px;\n      i {\n        font-size: $growl-icon-size;\n        width: $growl-icon-size;\n        height: $growl-icon-size;\n      }\n    }\n\n    .growl-message {\n      display: flex;\n\n      &.growl-center {\n        align-items: center;\n      }\n\n      .growl-text {\n        position: relative;\n        flex-basis: 90%;\n        padding: 10px 10px 10px 0;\n        word-break: break-word;\n        white-space: normal;\n\n        .close {\n          position: absolute;\n          top: 12px;\n          right: 10px;\n        }\n        .growl-text-title {\n          font-size: 16px;\n        }\n\n        > P {\n          padding-top: 2px;\n\n          &.has-title {\n            margin-top: 5px;\n          }\n        }\n      }\n    }\n  }\n</style>\n"]}]}