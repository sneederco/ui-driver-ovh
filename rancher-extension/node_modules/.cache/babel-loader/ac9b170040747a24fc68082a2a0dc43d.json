v>\n</template>\n\n<style lang=\"scss\" scoped>\n.plus-minus {\n  min-width: 70px;\n  display: flex;\n  align-items: center;\n  button:hover {\n    background-color: var(--accent-btn);\n  }\n  .value {\n    min-width: 25px;\n    max-width: 30px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n}\n.label {\n  padding-right: 1em;\n}\n</style>\n"]}]}