{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/ImagePercentageBar.vue?vue&type=template&id=5ad5aa7a&scoped=true","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/ImagePercentageBar.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/ImagePercentageBar.vue"],"names":["t"],"mappings":";;;;EAiDI,KAAK,EAAC,QAAQ;;qBAET,KAAK,EAAC,cAAc;qBAOpB,KAAK,EAAC,MAAM;;;;;;WAVV,kBAAS;qBADlB,oBAcM,OAdN,UAcM;QAVJ,oBAMM,OANN,UAMM;UALJ,aAIE;YAHC,MAAM,EAAE,mBAAU;YAClB,GAAG,EAAE,CAAC;YACN,GAAG,EAAE,GAAG;;;;QAGb,oBAEM,OAFN,UAEM,mBADD,YAAK,SAAQ,SAClB;;qBAEF,oBAEM,oCADDA,MAAC","sourcesContent":["<script>\nimport ProgressBarMulti from '@shell/components/ProgressBarMulti';\nexport default {\n  components: { ProgressBarMulti },\n\n  props: {\n    value: {\n      type:    [String, Number],\n      default: 0\n    },\n    row: {\n      type:    Object,\n      default: () => {}\n    },\n    col: {\n      type:    Object,\n      default: () => {}\n    },\n  },\n\n  computed: {\n    percentage() {\n      const value = Number.parseFloat(this.value);\n      let color = 'bg-success';\n\n      if (value === 0) {\n        color = 'bg-secondary';\n      } else if (value < 30) {\n        color = 'bg-darker';\n      } else if (value < 70) {\n        color = 'bg-warning';\n      }\n\n      return [{\n        value,\n        color\n      }];\n    },\n\n    completed() {\n      return Number.parseFloat(this.value) === 100;\n    },\n  },\n};\n</script>\n\n<template>\n  <div\n    v-if=\"!completed\"\n    class=\"parent\"\n  >\n    <div class=\"progress-box\">\n      <ProgressBarMulti\n        :values=\"percentage\"\n        :min=\"0\"\n        :max=\"100\"\n      />\n    </div>\n    <div class=\"text\">\n      {{ value || 0 }}%\n    </div>\n  </div>\n  <div v-else>\n    {{ t('generic.completed') }}\n  </div>\n</template>\n\n<style lang=\"scss\" scoped>\n.parent {\n  display: grid;\n  grid-template-areas: \"progress text\";\n  grid-template-columns: auto 80px;\n  align-items: center;\n  .progress {\n    background-color: darken(#EBEEF5, 15%);\n    width: 100%;\n  }\n  .progress-box {\n    grid-area: progress;\n  }\n  .text {\n    grid-area: text;\n    text-align: center;\n  }\n}\n</style>\n"]}]}