{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/detail/fleet.cattle.io.bundle.vue?vue&type=template&id=30629259&scoped=true","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/detail/fleet.cattle.io.bundle.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/detail/fleet.cattle.io.bundle.vue"],"names":["t","$fetchState"],"mappings":";;qBA8FS,KAAK,EAAC,0BAA0B;;;;;;wBADvC,oBAUM;IATJ,oBAGM,OAHN,UAGM;MAFJ,oBAA2C,6BAApCA,MAAC;;MACR,oBAAgC,+BAAvB,sBAAa;;;KAETC,gBAAW,CAAC,OAAO;uBAAlC,aAAsC;uBACtC,aAGE;;UADC,IAAI,EAAE,wBAAe","sourcesContent":["<script>\nimport { FLEET } from '@shell/config/types';\nimport FleetResources from '@shell/components/fleet/FleetResources';\nimport FleetUtils from '@shell/utils/fleet';\nimport { checkSchemasForFindAllHash } from '@shell/utils/auth';\nimport Loading from '@shell/components/Loading.vue';\nimport { FLEET as FLEET_ANNOTATIONS } from '@shell/config/labels-annotations';\n\nexport default {\n  name: 'FleetBundleDetail',\n\n  components: { Loading, FleetResources },\n  props:      {\n    value: {\n      type:     Object,\n      required: true,\n    }\n  },\n\n  data() {\n    return { allBundleDeployments: [] };\n  },\n\n  async fetch() {\n    const allDispatches = await checkSchemasForFindAllHash({\n      allBundleDeployments: {\n        inStoreType: 'management',\n        type:        FLEET.BUNDLE_DEPLOYMENT,\n      },\n\n      // must be loaded for bundle.targetClusters to work\n      allFleetClusters: {\n        inStoreType: 'management',\n        type:        FLEET.CLUSTER\n      },\n      clusterGroups: {\n        inStoreType: 'management',\n        type:        FLEET.CLUSTER_GROUP\n      }\n    }, this.$store);\n\n    this.allBundleDeployments = allDispatches.allBundleDeployments || [];\n  },\n\n  computed: {\n    bundleResources() {\n      if (!this.allBundleDeployments) {\n        return [];\n      }\n\n      const bundleDeploymentsByClusterId = this.allBundleDeployments\n        .reduce((res, bd) => {\n          if (this.value.id === FleetUtils.bundleIdFromBundleDeploymentLabels(bd.metadata?.labels)) {\n            res[FleetUtils.clusterIdFromBundleDeploymentLabels(bd.metadata?.labels)] = bd;\n          }\n\n          return res;\n        }, {});\n\n      return this.value.targetClusters.reduce((res, cluster) => {\n        const bd = bundleDeploymentsByClusterId[cluster.id];\n\n        if (bd) {\n          FleetUtils.resourcesFromBundleDeploymentStatus(bd.status)\n            .forEach((r) => {\n              const type = FleetUtils.resourceType(r);\n              const key = `${ cluster.id }-${ type }-${ r.namespace }-${ r.name }`;\n\n              res.push({\n                ...r,\n                key,\n                type,\n                id:          FleetUtils.resourceId(r),\n                clusterId:   cluster.id,\n                clusterName: cluster.nameDisplay,\n\n                detailLocation: FleetUtils.detailLocation(r, cluster.metadata.labels[FLEET_ANNOTATIONS.CLUSTER_NAME]),\n              });\n            });\n        }\n\n        return res;\n      }, []);\n    },\n    resourceCount() {\n      return this.bundleResources.length;\n    },\n  }\n};\n\n</script>\n\n<template>\n  <div>\n    <div class=\"bundle-title mt-20 mb-20\">\n      <h2>{{ t('fleet.bundles.resources') }}</h2>\n      <span>{{ resourceCount }}</span>\n    </div>\n    <Loading v-if=\"$fetchState.pending\" />\n    <FleetResources\n      v-else\n      :rows=\"bundleResources\"\n    />\n  </div>\n</template>\n\n<style lang=\"scss\" scoped>\n.bundle-title {\n  display: flex;\n  align-items: center;\n\n  h2 {\n    margin: 0 10px 0 0;\n  }\n\n  span {\n    background-color: var(--darker);\n    color: var(--default);\n    padding: 5px 10px;\n    border-radius: 15px;\n  }\n}\n</style>\n"]}]}