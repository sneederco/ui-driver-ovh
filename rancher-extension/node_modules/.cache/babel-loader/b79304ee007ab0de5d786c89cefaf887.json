{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/form/LifecycleHooks.vue?vue&type=template&id=09c162c2","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/form/LifecycleHooks.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/form/LifecycleHooks.vue"],"names":["t"],"mappings":";;qBAgES,KAAK,EAAC,OAAO;qBACZ,KAAK,EAAC,UAAU;qBAWhB,KAAK,EAAC,UAAU;;;;;wBAbxB,oBAsBM;IArBJ,oBASM,OATN,UASM;MARJ,oBAEK,MAFL,UAEK,mBADAA,MAAC;;MAEN,aAIE;QAHQ,KAAK,EAAE,eAAS;;gDAAT,eAAS;UAET,eAAM;;QADpB,IAAI,EAAE,WAAI;;;;IAKf,oBASM;MARJ,oBAEK,MAFL,UAEK,mBADAA,MAAC;;MAEN,aAIE;QAHQ,KAAK,EAAE,aAAO;;gDAAP,aAAO;UAEP,eAAM;;QADpB,IAAI,EAAE,WAAI","sourcesContent":["<script>\nimport HookOption from '@shell/components/form/HookOption';\nimport { _VIEW } from '@shell/config/query-params';\nimport { isEmpty } from '@shell/utils/object';\n\nexport default {\n  emits: ['update:value'],\n\n  components: { HookOption },\n\n  props: {\n    mode: {\n      type:     String,\n      required: true,\n    },\n\n    // container spec\n    value: {\n      type:    Object,\n      default: () => {\n        return {};\n      }\n    },\n  },\n\n  data() {\n    return {\n      postStart:   this.value.postStart,\n      preStop:     this.value.preStop,\n      hookOptions: ['postStart', 'preStop']\n    };\n  },\n\n  computed: {\n    isView() {\n      return this.mode === _VIEW;\n    },\n  },\n\n  methods: {\n    update() {\n      const out = {\n        postStart: this.postStart,\n        preStop:   this.preStop\n      };\n\n      for (const prop in out) {\n        const val = out[prop];\n\n        if (val === '' || typeof val === 'undefined' || val === null || isEmpty(val)) {\n          delete this.value[prop];\n        } else {\n          this.value[prop] = val;\n        }\n      }\n\n      this.$emit('update:value', this.value);\n    },\n  }\n};\n</script>\n\n<template>\n  <div>\n    <div class=\"mb-20\">\n      <h3 class=\"clearfix\">\n        {{ t('workload.container.lifecycleHook.postStart.label') }}\n      </h3>\n      <HookOption\n        v-model:value=\"postStart\"\n        :mode=\"mode\"\n        @update:value=\"update\"\n      />\n    </div>\n\n    <div>\n      <h3 class=\"clearfix\">\n        {{ t('workload.container.lifecycleHook.preStop.label') }}\n      </h3>\n      <HookOption\n        v-model:value=\"preStop\"\n        :mode=\"mode\"\n        @update:value=\"update\"\n      />\n    </div>\n  </div>\n</template>\n"]}]}