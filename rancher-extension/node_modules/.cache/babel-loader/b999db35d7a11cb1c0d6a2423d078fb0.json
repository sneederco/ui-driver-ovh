{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/edit/monitoring.coreos.com.receiver/types/pagerduty.vue?vue&type=template&id=e781b26c","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/edit/monitoring.coreos.com.receiver/types/pagerduty.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/edit/monitoring.coreos.com.receiver/types/pagerduty.vue"],"names":[],"mappings":";;qBA6DS,KAAK,EAAC,WAAW;qBACf,KAAK,EAAC,YAAY;qBAQlB,KAAK,EAAC,YAAY;qBAQpB,KAAK,EAAC,WAAW;qBACf,KAAK,EAAC,aAAa;qBASrB,KAAK,EAAC,KAAK;;;;;;;wBAjClB,oBAwCM;8BAvCJ,oBAIM,SAJD,KAAK,EAAC,KAAK;MACd,oBAEM,SAFD,KAAK,EAAC,aAAa;QACtB,oBAAe,YAAX,QAAM;;;;IAGd,oBAgBM,OAhBN,UAgBM;MAfJ,oBAOM,OAPN,UAOM;QANJ,aAKE;UAJQ,KAAK,EAAE,qBAAe;kEAAf,qBAAe;UAC7B,OAAO,EAAE,4BAAsB;UAC/B,IAAI,EAAE,WAAI;UACX,KAAK,EAAC,kBAAkB;;;;MAG5B,oBAMM,OANN,UAMM;QALJ,aAIE;UAHQ,KAAK,EAAE,YAAK,CAAC,wBAAkB,CAAC,qBAAe;kEAAxC,YAAK,CAAC,wBAAkB,CAAC,qBAAe;UACtD,IAAI,EAAE,WAAI;UACX,KAAK,EAAC,yBAAyB;;;;;IAIrC,oBASM,OATN,UASM;MARJ,oBAOM,OAPN,UAOM;QANJ,aAKE;UAJQ,KAAK,EAAE,YAAK,CAAC,WAAW,CAAC,SAAS;kEAA3B,YAAK,CAAC,WAAW,CAAC,SAAS;UACzC,IAAI,EAAE,WAAI;UACX,KAAK,EAAC,WAAW;UACjB,WAAW,EAAC,uBAAuB;;;;;IAIzC,oBAMM,OANN,UAMM;MALJ,aAIE;QAHQ,KAAK,EAAE,YAAK,CAAC,aAAa;gEAAnB,YAAK,CAAC,aAAa;QACjC,IAAI,EAAE,WAAI;QACX,KAAK,EAAC,6BAA6B","sourcesContent":["<script>\n/**\n * The Route and Receiver resources are deprecated. Going forward,\n * routes and receivers should be configured within AlertmanagerConfigs.\n * Any updates to receiver configuration forms, such as Slack/email/PagerDuty\n * etc, should be made to the receiver forms that are based on the\n * AlertmanagerConfig resource, which has a different API. The new forms are\n * located in @shell/edit/monitoring.coreos.com.alertmanagerconfig/types.\n */\nimport { LabeledInput } from '@components/Form/LabeledInput';\nimport LabeledSelect from '@shell/components/form/LabeledSelect';\nimport { Checkbox } from '@components/Form/Checkbox';\n\nexport default {\n  components: {\n    Checkbox, LabeledInput, LabeledSelect\n  },\n  props: {\n    mode: {\n      type:     String,\n      required: true,\n    },\n    value: {\n      type:     Object,\n      required: true\n    }\n  },\n  data() {\n    this.value['http_config'] = this.value.http_config || {};\n    this.value['send_resolved'] = typeof this.value.send_resolved === 'boolean' ? this.value.send_resolved : true;\n\n    const integrationMapping = {\n      'Events API v2': 'routing_key',\n      Prometheus:      'service_key'\n    };\n\n    const integrationTypeOptions = Object.keys(integrationMapping);\n\n    return {\n      integrationMapping,\n      integrationTypeOptions,\n      integrationType: this.value.service_key ? integrationTypeOptions[1] : integrationTypeOptions[0]\n    };\n  },\n  watch: {\n    integrationType() {\n      this.integrationTypeOptions.forEach((option) => {\n        this.value[this.integrationMapping[option]] = null;\n      });\n    }\n  }\n};\n</script>\n\n<template>\n  <div>\n    <div class=\"row\">\n      <div class=\"col span-12\">\n        <h3>Target</h3>\n      </div>\n    </div>\n    <div class=\"row mb-20\">\n      <div class=\"col span-6\">\n        <LabeledSelect\n          v-model:value=\"integrationType\"\n          :options=\"integrationTypeOptions\"\n          :mode=\"mode\"\n          label=\"Integration Type\"\n        />\n      </div>\n      <div class=\"col span-6\">\n        <LabeledInput\n          v-model:value=\"value[integrationMapping[integrationType]]\"\n          :mode=\"mode\"\n          label=\"Default Integration Key\"\n        />\n      </div>\n    </div>\n    <div class=\"row mb-20\">\n      <div class=\"col span-12\">\n        <LabeledInput\n          v-model:value=\"value.http_config.proxy_url\"\n          :mode=\"mode\"\n          label=\"Proxy URL\"\n          placeholder=\"e.g. http://my-proxy/\"\n        />\n      </div>\n    </div>\n    <div class=\"row\">\n      <Checkbox\n        v-model:value=\"value.send_resolved\"\n        :mode=\"mode\"\n        label=\"Enable send resolved alerts\"\n      />\n    </div>\n  </div>\n</template>\n"]}]}