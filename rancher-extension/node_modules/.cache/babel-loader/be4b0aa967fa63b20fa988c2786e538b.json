Q,EAAE,uBAAiB;;;QAE9B,oBAAwC,6BAAjCA,MAAC;;QACR,oBA4EQ;UA3EN,oBASQ;YARN,oBAOK;cANH,oBAEK,MAFL,UAEK,mBADAA,MAAC;;cAEN,oBAEK,MAFL,UAEK,mBADAA,MAAC;;;;WAIA,uBAAc;6BAAxB,oBAYK;gBAXH,oBAUK;kBATH,oBAQI;oBAPF,IAAI,EAAC,oCAAoC;oBACzC,MAAM,EAAC,QAAQ;oBACf,GAAG,EAAC,8BAA8B;oBAClC,IAAI,EAAC,MAAM;oBACV,YAAU,EAAEA,MAAC,qCAAqCA,MAAC;sCAEjDA,MAAC;;gBAEH,oBAAmC,6BAA5B,uBAAc,CAAC,KAAK;;;;WAExB,sBAAgB;6BAA1B,oBAYK;gBAXH,oBAUK;kBATH,oBAQI;oBAPF,IAAI,EAAC,sCAAsC;oBAC3C,MAAM,EAAC,QAAQ;oBACf,GAAG,EAAC,8BAA8B;oBAClC,IAAI,EAAC,MAAM;oBACV,YAAU,EAAEA,MAAC,qCAAqCA,MAAC;sCAEjDA,MAAC;;gBAEH,oBAA+B,6BAAxB,sBAAgB;;;;WAEpB,mBAAU;6BAApB,oBAYK;gBAXH,oBAUK;kBATH,oBAQI;oBAPF,IAAI,EAAC,gCAAgC;oBACrC,MAAM,EAAC,QAAQ;oBACf,GAAG,EAAC,8BAA8B;oBAClC,IAAI,EAAC,MAAM;oBACV,YAAU,EAAEA,MAAC,qCAAqCA,MAAC;sCAEjD,gBAAO,IAAG,GAAC,oBAAGA,MAAC;;gBAEjB,oBAA+B,6BAAxB,mBAAU,CAAC,KAAK;;;;WAEpB,oBAAW;6BAArB,oBAYK;gBAXH,oBAUK;kBATH,oBAQI;oBAPF,IAAI,EAAC,iCAAiC;oBACtC,MAAM,EAAC,QAAQ;oBACf,GAAG,EAAC,8BAA8B;oBAClC,IAAI,EAAC,MAAM;oBACV,YAAU,EAAEA,MAAC,qCAAqCA,MAAC;sCAEjDA,MAAC;;gBAEH,oBAAgC,6BAAzB,oBAAW,CAAC,KAAK;;;;WAErB,6BAAoB;6BAA9B,oBAYK;gBAXH,oBAUK;kBATH,oBAQI;oBAPF,IAAI,EAAC,oCAAoC;oBACzC,MAAM,EAAC,QAAQ;oBACf,GAAG,EAAC,8BAA8B;oBAClC,IAAI,EAAC,MAAM;oBACV,YAAU,EAAEA,MAAC,qCAAqCA,MAAC;sCAEjDA,MAAC;;gBAEH,oBAAyC,6BAAlC,6BAAoB,CAAC,KAAK;;;;;QAG1C,oBAWI,KAXJ,WAWI;UAVF,oBASI;YARF,KAAK,EAAC,oBAAoB;YACzB,IAAI,EAAEE,oBAAe;YACtB,MAAM,EAAC,QAAQ;YACf,GAAG,EAAC,8BAA8B;YAClC,IAAI,EAAC,MAAM;YACV,YAAU,EAAEF,MAAC;8BAEXA,MAAC;;;SAGQ,oBAAW,CAAC,MAAM;2BAAlC,oBAyBW;cAxBT,oBAEK,MAFL,WAEK,mBADAA,MAAC;;cAEN,oBAoBQ;mCAnBN,oBAkBK,6BAjBc,oBAAW,GAApB,CAAC,EAAE,CAAC;wCADd,oBAkBK;oBAhBF,GAAG,EAAE,CAAC;oBACP,KAAK,EAAC,MAAM;;oBAEZ,oBAIK;sBAHH,oBAEM,OAFN,WAEM;wBADJ,oBAAoC;0BAAhC,KAAK,0BAAU,CAAC,CAAC,IAAI;;yCAAW,GAAC,oBAAGA,MAAC,CAAC,CAAC,CAAC,KAAK;;;;oBAGrD,oBAOK;uBALK,CAAC,CAAC,OAAO;yCADjB,oBAKoB;;4BAHjB,IAAI,EAAE,CAAC,CAAC,OAAO;4BAChB,IAAI,EAAC,MAAM;4BACV,YAAU,EAAEA,MAAC,qCAAqCA,MAAC,CAAC,CAAC,CAAC,KAAK;8CAC1D,CAAC,CAAC,OAAO","sourcesContent":["<script>\nimport Loading from '@shell/components/Loading';\nimport BackLink from '@shell/components/BackLink';\nimport BackRoute from '@shell/mixins/back-link';\nimport { MANAGEMENT } from '@shell/config/types';\nimport { SETTING } from '@shell/config/settings';\nimport { getVendor } from '@shell/config/private-label';\nimport { mapGetters } from 'vuex';\nimport TabTitle from '@shell/components/TabTitle';\nimport { PanelLocation, ExtensionPoint } from '@shell/core/types';\nimport ExtensionPanel from '@shell/components/ExtensionPanel';\n\nexport default {\n  components: {\n    BackLink, ExtensionPanel, Loading, TabTitle\n  },\n  mixins: [BackRoute],\n  async fetch() {\n    this.settings = await this.$store.dispatch(`management/findAll`, { type: MANAGEMENT.SETTING });\n  },\n  data() {\n    return {\n      extensionType:     ExtensionPoint.PANEL,\n      extensionLocation: PanelLocation.ABOUT_TOP,\n      dashboardVersion:  this.$config.dashboardVersion,\n      settings:          null,\n      SETTING\n    };\n  },\n  computed: {\n    ...mapGetters(['releaseNotesUrl']),\n    rancherVersion() {\n      return this.settings.find((s) => s.id === SETTING.VERSION_RANCHER);\n    },\n    appName() {\n      return getVendor();\n    },\n    cliVersion() {\n      return this.settings.find((s) => s.id === SETTING.VERSION_CLI);\n    },\n    helmVersion() {\n      return this.settings.find((s) => s.id === SETTING.VERSION_HELM);\n    },\n    dockerMachineVersion() {\n      return this.settings.find((s) => s.id === SETTING.VERSION_MACHINE);\n    },\n    downloads() {\n      return [\n        this.createOSOption('about.os.mac', 'icon-apple', this.settings?.find((s) => s.id === SETTING.CLI_URL.DARWIN)?.value),\n        this.createOSOption('about.os.linux', 'icon-linux', this.settings?.find((s) => s.id === SETTING.CLI_URL.LINUX)?.value),\n        this.createOSOption('about.os.windows', 'icon-windows', this.settings?.find((s) => s.id === SETTING.CLI_URL.WINDOWS)?.value)\n      ];\n    },\n    downloadCli() {\n      return this.downloads.filter((d) => !!d.cliLink);\n    }\n  },\n  methods: {\n    createOSOption(label, icon, cliLink) {\n      const slash = cliLink?.lastIndexOf('/');\n\n      return {\n        label,\n        icon,\n        cliLink,\n        cliFile: slash >= 0 ? cliLink.substr(slash + 1, cliLink.length - 1) : cliLink\n      };\n    },\n\n  }\n};\n</script>\n\n<template>\n  <Loading v-if=\"!settings\" />\n  <div\n    v-else\n    class=\"about\"\n  >\n    <BackLink :link=\"backLink\" />\n    <div class=\"title-block mt-20 mb-40\">\n      <h1>\n        <TabTitle breadcrumb=\"vendor-only\">\n          {{ t('about.title') }}\n        </TabTitle>\n      </h1>\n      <router-link\n        :to=\"{ name: 'diagnostic' }\"\n        class=\"btn role-primary\"\n        data-testid=\"about__diagnostics_button\"\n        role=\"button\"\n        :aria-label=\"t('about.diagnostic.title')\"\n        @keyup.space=\"$router.push({ name: 'diagnostic' })\"\n      >\n        {{ t('about.diagnostic.title') }}\n      </router-link>\n    </div>\n    <!-- Extensions area -->\n    <ExtensionPanel\n      :resource=\"{}\"\n      :type=\"extensionType\"\n      :location=\"extensionLocation\"\n    />\n    <h3>{{ t('about.versions.title') }}</h3>\n    <table>\n      <thead>\n        <tr>\n          <th class=\"custom-th\">\n            {{ t('about.versions.component') }}\n          </th>\n          <th class=\"custom-th\">\n            {{ t('about.versions.version') }}\n          </th>\n        </tr>\n      </thead>\n      <tr v-if=\"rancherVersion\">\n        <td>\n          <a\n            href=\"https://github.com/rancher/rancher\"\n            target=\"_blank\"\n            rel=\"nofollow noopener noreferrer\"\n            role=\"link\"\n            :aria-label=\"t('about.versions.githubRepo', {name: t(`about.versions.rancher`) })\"\n          >\n            {{ t(\"about.versions.rancher\") }}\n          </a>\n        </td><td>{{ rancherVersion.value }}</td>\n      </tr>\n      <tr v-if=\"dashboardVersion\">\n        <td>\n          <a\n            href=\"https://github.com/rancher/dashboard\"\n            target=\"_blank\"\n            rel=\"nofollow noopener noreferrer\"\n            role=\"link\"\n            :aria-label=\"t('about.versions.githubRepo', {name: t(`generic.dashboard`)})\"\n          >\n            {{ t(\"generic.dashboard\") }}\n          </a>\n        </td><td>{{ dashboardVersion }}</td>\n      </tr>\n      <tr v-if=\"cliVersion\">\n        <td>\n          <a\n            href=\"https://github.com/rancher/cli\"\n            target=\"_blank\"\n            rel=\"nofollow noopener noreferrer\"\n            role=\"link\"\n            :aria-label=\"t('about.versions.githubRepo', {name: t(`about.versions.cli`) })\"\n          >\n            {{ appName }} {{ t(\"about.versions.cli\") }}\n          </a>\n        </td><td>{{ cliVersion.value }}</td>\n      </tr>\n      <tr v-if=\"helmVersion\">\n        <td>\n          <a\n            href=\"https://github.com/rancher/helm\"\n            target=\"_blank\"\n            rel=\"nofollow noopener noreferrer\"\n            role=\"link\"\n            :aria-label=\"t('about.versions.githubRepo', {name: t(`about.versions.helm`) })\"\n          >\n            {{ t(\"about.versions.helm\") }}\n          </a>\n        </td><td>{{ helmVersion.value }}</td>\n      </tr>\n      <tr v-if=\"dockerMachineVersion\">\n        <td>\n          <a\n            href=\"https://github.com/rancher/machine\"\n            target=\"_blank\"\n            rel=\"nofollow noopener noreferrer\"\n            role=\"link\"\n            :aria-label=\"t('about.versions.githubRepo', {name: t(`about.versions.machine`) })\"\n          >\n            {{ t(\"about.versions.machine\") }}\n          </a>\n        </td><td>{{ dockerMachineVersion.value }}</td>\n      </tr>\n    </table>\n    <p class=\"pt-20\">\n      <a\n        class=\"release-notes-link\"\n        :href=\"releaseNotesUrl\"\n        target=\"_blank\"\n        rel=\"nofollow noopener noreferrer\"\n        role=\"link\"\n        :aria-label=\"t('about.versions.releaseNotes')\"\n      >\n        {{ t('about.versions.releaseNotes') }}\n      </a>\n    </p>\n    <template v-if=\"downloadCli.length\">\n      <h3 class=\"pt-40\">\n        {{ t('about.downloadCLI.title') }}\n      </h3>\n      <table>\n        <tr\n          v-for=\"(d, i) in downloadCli\"\n          :key=\"i\"\n          class=\"link\"\n        >\n          <th>\n            <div class=\"os\">\n              <i :class=\"`icon ${d.icon} mr-5`\" /> {{ t(d.label) }}\n            </div>\n          </th>\n          <td>\n            <a\n              v-if=\"d.cliLink\"\n              :href=\"d.cliLink\"\n              role=\"link\"\n              :aria-label=\"t('about.versions.downloadCli', { os: t(d.label) })\"\n            >{{ d.cliFile }}</a>\n          </td>\n        </tr>\n      </table>\n    </template>\n  </div>\n</template>\n\n<style lang=\"scss\" scoped>\n.about {\n  .title-block {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n  }\n\n  table {\n    border-collapse: collapse;\n    overflow: hidden;\n    border-radius: var(--border-radius);\n\n    tr > th:first-of-type {\n      width: 20%;\n    }\n\n    th, td {\n      border: 1px solid var(--border);\n      padding: 8px 5px;\n      min-width: 150px;\n      text-align: left;\n    }\n\n    th.custom-th {\n      background-color: var(--sortable-table-top-divider);\n      border-bottom: 1px solid var(--sortable-table-top-divider);\n    }\n\n    th:not(.custom-th) {\n      font-weight: normal;\n    }\n\n    a {\n      cursor: pointer;\n    }\n\n    .os {\n      display: flex;\n      align-items: center;\n    }\n  }\n}\n\n</style>\n"]}]}