{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/AppSummaryGraph.vue?vue&type=template&id=151025de","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/AppSummaryGraph.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/AppSummaryGraph.vue"],"names":[],"mappings":";;;;;EA8GQ,KAAK,EAAC,OAAO;;qBAaL,KAAK,EAAC,YAAY;;;EAU9B,KAAK,EAAC,wBAAwB;;;;;;;;UA7CxB,aAAI;qBADZ,aA2Ca;;QAzCX,KAAK,EAAC,kBAAkB;QACxB,SAAS,EAAC,KAAK;QACd,YAAU,EAAE,UAAG,CAAC,EAAE;QAClB,QAAQ,EAAE,aAAI;QACf,MAAM,EAAC,GAAG;;QAcC,MAAM,WALR,CAayM;WANxM,aAAI;6BADZ,oBAoBQ,SApBR,UAoBQ;gBAhBN,oBAeQ;qCAdN,oBAaK,6BAZgB,mBAAU,GAArB,GAAG,EAAE,CAAC;0CADhB,oBAaK,QAXF,GAAG,EAAE,CAAC;sBAEP,oBAKK;wBAJH,KAAK,mBAAC,iBAAiB,IACb,GAAG,CAAC,SAAS;0CAEpB,GAAG,CAAC,KAAK;;sBAEd,oBAEK,MAFL,UAEK,mBADA,GAAG,CAAC,KAAK;;;;;;;0BA7BtB,CAGE;UAHF,aAGE;YAFC,MAAM,EAAE,mBAAU;YACnB,KAAK,EAAC,MAAM;;;WAGN,aAAM;6BADd,aAKc;;gBAHX,EAAE,EAAE,aAAM;;kCAEX,CAAkB;oDAAf,qBAAY;;;;6BAEjB,oBAAsC,qCAAtB,qBAAY;;;;;;qBA0B9B,oBAKM,OALN,UAKM,EAFL,aAED","sourcesContent":["<script>\nimport ProgressBarMulti from '@shell/components/ProgressBarMulti';\nimport { colorForState, stateDisplay, stateSort } from '@shell/plugins/dashboard-store/resource-class';\nimport { sortBy } from '@shell/utils/sort';\n\nexport default {\n  components: { ProgressBarMulti },\n\n  props: {\n    row: {\n      type:     Object,\n      required: true\n    },\n\n    labelKey: {\n      type:    String,\n      default: null\n    },\n\n    linkTo: {\n      type:    Object,\n      default: null\n    }\n  },\n\n  computed: {\n    show() {\n      return this.stateParts.length > 0;\n    },\n\n    stateParts() {\n      const out = {};\n\n      for ( const r of this.row.deployedResources ) {\n        const textColor = colorForState(r.state, r.error, r.transitioning);\n        const state = stateDisplay(r.state);\n        const key = `${ textColor }/${ state }`;\n\n        if ( out[key] ) {\n          out[key].value += 1;\n        } else {\n          out[key] = {\n            key,\n            label: state,\n            color: textColor.replace(/text-/, 'bg-'),\n            textColor,\n            value: 1,\n            sort:  stateSort(textColor, state),\n          };\n        }\n      }\n\n      return sortBy(Object.values(out), 'sort:desc');\n    },\n\n    colorParts() {\n      const out = {};\n\n      for ( const p of this.stateParts ) {\n        if ( out[p.color] ) {\n          out[p.color].value += 1;\n        } else {\n          out[p.color] = {\n            color: p.color,\n            value: p.value,\n            sort:  p.sort,\n          };\n        }\n      }\n\n      return sortBy(Object.values(out), 'sort:desc');\n    },\n\n    displayLabel() {\n      const count = this.row?.deployedResources?.length || 0;\n\n      if ( this.labelKey ) {\n        return this.t(this.labelKey, { count });\n      }\n\n      return `${ count }`;\n    }\n  },\n};\n</script>\n\n<template>\n  <v-dropdown\n    v-if=\"show\"\n    class=\"text-center hand\"\n    placement=\"top\"\n    :show-group=\"row.id\"\n    :triggers=\"show ? ['click'] : []\"\n    offset=\"1\"\n  >\n    <ProgressBarMulti\n      :values=\"colorParts\"\n      class=\"mb-5\"\n    />\n    <router-link\n      v-if=\"linkTo\"\n      :to=\"linkTo\"\n    >\n      {{ displayLabel }}\n    </router-link>\n    <span v-else>{{ displayLabel }}</span>\n\n    <template #popper>\n      <table\n        v-if=\"show\"\n        class=\"fixed\"\n      >\n        <tbody>\n          <tr\n            v-for=\"(obj, i) in stateParts\"\n            :key=\"i\"\n          >\n            <td\n              class=\"text-left pr-20\"\n              :class=\"{[obj.textColor]: true}\"\n            >\n              {{ obj.label }}\n            </td>\n            <td class=\"text-right\">\n              {{ obj.value }}\n            </td>\n          </tr>\n        </tbody>\n      </table>\n    </template>\n  </v-dropdown>\n  <div\n    v-else\n    class=\"text-center text-muted\"\n  >\n    &mdash;\n  </div>\n</template>\n\n<style lang=\"scss\">\n  .col-scale {\n    position: relative;\n\n    .trigger {\n      width: 100%;\n    }\n  }\n\n  .scale {\n    margin: 0;\n    padding: 0;\n    line-height: initial;\n  }\n</style>\n"]}]}