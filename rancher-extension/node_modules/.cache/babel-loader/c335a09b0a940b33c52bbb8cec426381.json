UAAU,EAAE;YACV,IAAI,EAAM,MAAuC;YACjD,QAAQ,EAAE,IAAG;SACd;QAED,SAAS,EAAE;YACT,IAAI,EAAM,MAAM;YAChB,QAAQ,EAAE,IAAG;SACf;KACD;IAED,IAAI;QACF,OAAO;YACL,KAAK;YACL,SAAS,EAAO,EAAE;YAClB,cAAc,EAAE;gBACd,GAAG,IAAI,CAAC,KAAK,CAAC,eAAe;gBAC7B,IAAI,EAAE,mDAAkD;aAC1D;SACD,CAAA;IACH,CAAC;IAED,OAAO;;QACL,IAAI,CAAC,SAAQ,GAAI,CAAA,MAAA,IAAI,CAAC,QAAQ,CAAC,CAAC,CAAC,0CAAE,KAAI,KAAK,EAAE,CAAA;IAChD,CAAC;IAED,QAAQ,EAAE;QACR,QAAQ;YACN,OAAO,IAAI,CAAC,KAAK,CAAC,cAAc,CAAC,GAAG,CAAC,CAAC,OAA4C,EAAE,EAAC,CAAE,CAAC;gBACtF,KAAK,EAAE,OAAO,CAAC,WAAW;gBAC1B,KAAK,EAAE,OAAO,CAAC,EAAC;aACjB,CAAC,CAAC,CAAA;QACL,CAAC;QAED,WAAW;;YACT,OAAO,CAAC,CAAA,MAAA,IAAI,CAAC,KAAK,CAAC,iBAAiB,0CAAE,MAAM,CAAA,CAAA;QAC9C,CAAC;KACF;IAED,OAAO,EAAE;QACP,UAAU;YACR,IAAI,CAAC,MAAM,CAAC,MAAM,CAAC,oBAAoB,CAAC,CAAA;QAC1C,CAAA;KACF;CACD,CAAA","file":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/fleet/dashboard/ResourceDetails.vue.tsx","sourceRoot":"","sourcesContent":["<script lang=\"ts\">\nimport { PropType } from 'vue';\nimport { FLEET } from '@shell/config/types';\nimport LabeledSelect from '@shell/components/form/LabeledSelect.vue';\nimport FleetResources from '@shell/components/fleet/FleetResources.vue';\nimport { RcButton } from '@components/RcButton';\nimport { FleetDashboardState } from '@shell/types/fleet';\nimport FleetApplicationSource from '@shell/components/formatter/FleetApplicationSource.vue';\n\nexport default {\n  name: 'FleetDashboardResourceDetails',\n\n  components: {\n    LabeledSelect,\n    FleetResources,\n    FleetApplicationSource,\n    RcButton,\n  },\n\n  props: {\n    value: {\n      type:     Object,\n      required: true\n    },\n\n    statePanel: {\n      type:     Object as PropType<FleetDashboardState>,\n      required: true\n    },\n\n    workspace: {\n      type:     Object,\n      required: true\n    }\n  },\n\n  data() {\n    return {\n      FLEET,\n      clusterId:      '',\n      detailLocation: {\n        ...this.value._detailLocation,\n        name: 'c-cluster-fleet-application-resource-namespace-id'\n      }\n    };\n  },\n\n  mounted() {\n    this.clusterId = this.clusters[0]?.value || '';\n  },\n\n  computed: {\n    clusters() {\n      return this.value.targetClusters.map((cluster: { id: string, nameDisplay: string }) => ({\n        label: cluster.nameDisplay,\n        value: cluster.id\n      }));\n    },\n\n    noResources() {\n      return !this.value.resourcesStatuses?.length;\n    },\n  },\n\n  methods: {\n    closePanel() {\n      this.$store.commit('slideInPanel/close');\n    }\n  }\n};\n</script>\n\n<template>\n  <div class=\"details-panel\">\n    <div\n      class=\"header\"\n      :data-testid=\"'fleet-dashboard-resource-details-header'\"\n    >\n      <h3 class=\"title\">\n        <i :class=\"value.dashboardIcon\" />\n        <router-link\n          class=\"label\"\n          :to=\"detailLocation\"\n        >\n          {{ value.id }}\n        </router-link>\n        <i\n          v-if=\"statePanel.id !== 'success'\"\n          class=\"ml-5 state-icon\"\n          :class=\"statePanel.icon\"\n          :style=\"{ color: statePanel.color }\"\n        />\n      </h3>\n      <RcButton\n        small\n        ghost\n        data-testid=\"slide-in-close\"\n        :aria-label=\"'slide-in-close'\"\n        tabindex=\"0\"\n        @click=\"closePanel\"\n        @keydown.space.enter.stop.prevent=\"closePanel\"\n      >\n        <i class=\"icon icon-close\" />\n      </RcButton>\n    </div>\n\n    <h4>\n      {{ t('fleet.dashboard.source') }}\n    </h4>\n    <div class=\"mb-15\">\n      <FleetApplicationSource\n        v-if=\"value.source.value\"\n        :row=\"value\"\n      />\n      <div\n        v-else\n        class=\"text-muted\"\n      >\n        &mdash;\n      </div>\n    </div>\n\n    <h4>\n      {{ t('fleet.dashboard.resources') }}\n    </h4>\n    <FleetResources\n      :rows=\"value.resourcesStatuses\"\n      :cluster-id=\"clusterId\"\n      :search=\"!noResources\"\n    >\n      <template\n        v-if=\"!noResources\"\n        #header-left\n      >\n        <div class=\"row\">\n          <div class=\"col span-10\">\n            <LabeledSelect\n              v-model:value=\"clusterId\"\n              :label=\"t('fleet.cluster.label')\"\n              :options=\"clusters\"\n              :mode=\"'edit'\"\n              :disabled=\"workspace.id === 'fleet-local'\"\n            />\n          </div>\n        </div>\n      </template>\n    </FleetResources>\n  </div>\n</template>\n\n<style lang=\"scss\">\n  .details-panel {\n    padding: 10px;\n\n    .sortable-table-header {\n      .fixed-header-actions {\n        align-items: center;\n      }\n    }\n\n    .header {\n      display: flex;\n      align-items: center;\n      padding: 0;\n      margin: 0 0 20px 0;\n\n      .title {\n        display: flex;\n        align-items: center;\n        flex: 1;\n        margin-bottom: 0;\n\n        .icon {\n          font-size: 2em;\n          margin-right: 16px;\n        }\n\n        .label {\n          margin-right: 8px;\n        }\n\n        .state-icon {\n          font-size: 1.5em;\n        }\n      }\n    }\n  }\n\n  .col {\n    .labeled-select {\n      min-width: 250px;\n    }\n  }\n</style>\n"]}]}