;;MAGxC,oBAOM,OAPN,UAOM;QANJ,aAKE;UAJQ,KAAK,EAAE,YAAK,CAAC,aAAa;kEAAnB,YAAK,CAAC,aAAa;UACjC,IAAI,EAAE,WAAI;UACX,KAAK,EAAC,OAAO;UACb,KAAK,EAAC,6BAA6B;;;;;gCAIzC,oBAEK,QAFD,KAAK,EAAC,OAAO,IAAC,oBAElB;;IACA,oBASM,OATN,UASM;MARJ,oBAOM,OAPN,UAOM;QANJ,aAKE;UAJQ,KAAK,EAAE,YAAK,CAAC,IAAI;kEAAV,YAAK,CAAC,IAAI;UACxB,IAAI,EAAE,WAAI;UACX,KAAK,EAAC,QAAQ;UACd,WAAW,EAAC,wBAAwB;;;;;IAI1C,oBA2BM,OA3BN,UA2BM;MA1BJ,oBAQM,OARN,UAQM;QAPJ,aAME;UALQ,KAAK,EAAE,YAAK,CAAC,IAAI;kEAAV,YAAK,CAAC,IAAI;UACxB,IAAI,EAAE,WAAI;UACX,KAAK,EAAC,MAAM;UACZ,aAAW,EAAC,kBAAkB;UAC9B,WAAW,EAAC,oBAAoB;;;;MAGpC,oBAQM,OARN,UAQM;QAPJ,aAME;UALQ,KAAK,EAAE,YAAK,CAAC,IAAI;kEAAV,YAAK,CAAC,IAAI;UACxB,IAAI,EAAE,WAAI;UACX,KAAK,EAAC,MAAM;UACZ,aAAW,EAAC,kBAAkB;UAC9B,WAAW,EAAC,SAAS;;;;MAGzB,oBAOM,OAPN,UAOM;QANJ,aAKE;UAJQ,KAAK,EAAE,YAAK,CAAC,WAAW;kEAAjB,YAAK,CAAC,WAAW;UAC/B,IAAI,EAAE,WAAI;UACX,KAAK,EAAC,OAAO;UACb,KAAK,EAAC,SAAS;;;;;IAIrB,oBAkBM,OAlBN,WAkBM;MAjBJ,oBAOM,OAPN,WAOM;QANJ,aAKE;UAJQ,KAAK,EAAE,YAAK,CAAC,aAAa;kEAAnB,YAAK,CAAC,aAAa;UACjC,IAAI,EAAE,WAAI;UACX,KAAK,EAAC,UAAU;UAChB,WAAW,EAAC,WAAW;;;;MAG3B,oBAQM,OARN,WAQM;QAPJ,aAME;UALQ,KAAK,EAAE,YAAK,CAAC,aAAa;kEAAnB,YAAK,CAAC,aAAa;UACjC,IAAI,EAAE,WAAI;UACX,KAAK,EAAC,UAAU;UAChB,IAAI,EAAC,UAAU;UACf,YAAY,EAAC,kBAAkB;;;;;IAIrC,aAKE;MAJC,KAAK,EAAE,YAAK;MACb,KAAK,EAAC,OAAO;MACZ,IAAI,EAAE,WAAI;MACV,gBAAY,uCAAEA,UAAK,UAAU,MAAM","sourcesContent":["<script>\n/**\n * The Route and Receiver resources are deprecated. Going forward,\n * routes and receivers should be configured within AlertmanagerConfigs.\n * Any updates to receiver configuration forms, such as Slack/email/PagerDuty\n * etc, should be made to the receiver forms that are based on the\n * AlertmanagerConfig resource, which has a different API. The new forms are\n * located in @shell/edit/monitoring.coreos.com.alertmanagerconfig/types.\n */\nimport { LabeledInput } from '@components/Form/LabeledInput';\nimport { Checkbox } from '@components/Form/Checkbox';\nimport TLS from '../tls';\n\nexport default {\n  emits:      ['input'],\n  components: {\n    Checkbox, LabeledInput, TLS\n  },\n  props: {\n    mode: {\n      type:     String,\n      required: true,\n    },\n    value: {\n      type:     Object,\n      required: true\n    }\n  },\n  data() {\n    this.value['send_resolved'] = this.value.send_resolved || false;\n    this.value['require_tls'] = this.value.require_tls || false;\n\n    return {};\n  },\n};\n</script>\n\n<template>\n  <div>\n    <div class=\"row\">\n      <div class=\"col span-12\">\n        <h3>Target</h3>\n      </div>\n    </div>\n    <div class=\"row mb-20\">\n      <div class=\"col span-6\">\n        <LabeledInput\n          v-model:value=\"value.to\"\n          :mode=\"mode\"\n          label=\"Default Recipient Address\"\n          placeholder=\"e.g. admin@example.com\"\n        />\n      </div>\n      <div class=\"col span-6\">\n        <Checkbox\n          v-model:value=\"value.send_resolved\"\n          :mode=\"mode\"\n          class=\"mt-20\"\n          label=\"Enable send resolved alerts\"\n        />\n      </div>\n    </div>\n    <h2 class=\"mb-10\">\n      SMTP\n    </h2>\n    <div class=\"row mb-20\">\n      <div class=\"col span-12\">\n        <LabeledInput\n          v-model:value=\"value.from\"\n          :mode=\"mode\"\n          label=\"Sender\"\n          placeholder=\"e.g. admin@example.com\"\n        />\n      </div>\n    </div>\n    <div class=\"row mb-20\">\n      <div class=\"col span-4\">\n        <LabeledInput\n          v-model:value=\"value.host\"\n          :mode=\"mode\"\n          label=\"Host\"\n          data-testid=\"input-email-host\"\n          placeholder=\"e.g. 192.168.1.121\"\n        />\n      </div>\n      <div class=\"col span-4\">\n        <LabeledInput\n          v-model:value=\"value.port\"\n          :mode=\"mode\"\n          label=\"Port\"\n          data-testid=\"input-email-port\"\n          placeholder=\"e.g. 80\"\n        />\n      </div>\n      <div class=\"col span-4\">\n        <Checkbox\n          v-model:value=\"value.require_tls\"\n          :mode=\"mode\"\n          class=\"mt-20\"\n          label=\"Use TLS\"\n        />\n      </div>\n    </div>\n    <div class=\"row mb-20\">\n      <div class=\"col span-6\">\n        <LabeledInput\n          v-model:value=\"value.auth_username\"\n          :mode=\"mode\"\n          label=\"Username\"\n          placeholder=\"e.g. John\"\n        />\n      </div>\n      <div class=\"col span-6\">\n        <LabeledInput\n          v-model:value=\"value.auth_password\"\n          :mode=\"mode\"\n          label=\"Password\"\n          type=\"password\"\n          autocomplete=\"current-password\"\n        />\n      </div>\n    </div>\n    <TLS\n      :value=\"value\"\n      class=\"mb-20\"\n      :mode=\"mode\"\n      @update:value=\"$emit('input', $event)\"\n    />\n  </div>\n</template>\n"]}]}