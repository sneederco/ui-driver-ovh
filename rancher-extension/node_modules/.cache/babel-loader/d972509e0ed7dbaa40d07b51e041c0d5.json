{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/CommunityLinks.vue?vue&type=template&id=50534f1b&scoped=true","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/CommunityLinks.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/CommunityLinks.vue"],"names":["pref","prefKey","t","selectedLocaleLabel"],"mappings":";;;;;;EAkIQ,KAAK,EAAC,cAAc;;;;;;;;UAnCf,mBAAU;qBAArB,oBAiDM;QAhDJ,aA+CY;UA9CT,IAAI,EAAEA,SAAI;UACV,UAAQ,EAAEC,YAAO;;UAEP,KAAK,WACd,CAEK;YAFL,oBAEK,6BADAC,MAAC;;4BAEG,CACX;;+BAAA,oBAqBM,6BApBgB,gBAAO,GAAnB,IAAI,EAAE,CAAC;oCADjB,oBAqBM;gBAnBH,GAAG,EAAE,CAAC;gBACP,KAAK,EAAC,cAAc;;iBAGZ,IAAI,CAAC,KAAK,CAAC,UAAU;mCAD7B,aAOc;;sBALX,EAAE,EAAE,IAAI,CAAC,KAAK;sBACf,IAAI,EAAC,MAAM;sBACV,YAAU,EAAE,IAAI,CAAC,KAAK;;wCAEvB,CAAgB;0DAAb,IAAI,CAAC,KAAK;;;;mCAEf,oBAOuB;;sBALpB,IAAI,EAAE,IAAI,CAAC,KAAK;sBACjB,GAAG,EAAC,8BAA8B;sBAClC,MAAM,EAAC,QAAQ;sBACf,IAAI,EAAC,MAAM;sBACV,YAAU,EAAE,IAAI,CAAC,KAAK;wCACpB,IAAI,CAAC,KAAK;;;;YAEjB,YAAQ;;aAEAC,wBAAmB,KAAKD,MAAC;+BADjC,oBAcM,OAdN,UAcM;kBAVJ,oBASI;oBARF,KAAK,EAAC,MAAM;oBACZ,QAAQ,EAAC,GAAG;oBACX,YAAU,EAAEA,MAAC;oBACd,IAAI,EAAC,MAAM;oBACV,OAAK,0CAAE,uCAAI;oBACX,SAAO,oDAAQ,uCAAI;sCAEjBA,MAAC","sourcesContent":["<script>\nimport SimpleBox from '@shell/components/SimpleBox';\nimport Closeable from '@shell/mixins/closeable';\nimport { MANAGEMENT } from '@shell/config/types';\nimport { SETTING } from '@shell/config/settings';\nimport { mapGetters } from 'vuex';\nimport { isRancherPrime } from '@shell/config/version';\nimport { fetchLinks } from '@shell/config/home-links';\nimport { processLink } from '@shell/plugins/clean-html';\n\n// i18n-ignore footer.wechat.title\nexport default {\n  name: 'CommunityLinks',\n\n  components: { SimpleBox },\n\n  props: {\n    linkOptions: {\n      type:    Object,\n      default: () => {\n        return {};\n      },\n    },\n    isSupportPage: {\n      type:    Boolean,\n      default: false,\n    },\n  },\n\n  mixins: [Closeable],\n\n  async fetch() {\n    this.links = await fetchLinks(this.$store, this.hasSupport, this.isSupportPage, (str) => this.t(str));\n  },\n\n  data() {\n    return { links: {}, showWeChatModal: false };\n  },\n\n  computed: {\n    ...mapGetters('i18n', [\n      'selectedLocaleLabel'\n    ]),\n\n    hasOptions() {\n      return !!Object.keys(this.options).length || !!Object.keys(this.$slots).length;\n    },\n\n    hasSupport() {\n      return isRancherPrime() || this.$store.getters['management/byId'](MANAGEMENT.SETTING, SETTING.SUPPORTED )?.value === 'true';\n    },\n\n    options() {\n      // Use linkOptions if provided - used by Harvester\n      if (this.linkOptions && Object.keys(this.linkOptions).length) {\n        const options = [];\n\n        Object.keys(this.linkOptions).forEach((key) => {\n          options.push({\n            key,\n            label: this.t(key),\n            value: this.linkOptions[key]\n          });\n        });\n\n        return options;\n      }\n\n      // Combine the links\n      const all = [];\n\n      if (this.links.custom) {\n        all.push(...this.links.custom);\n      }\n\n      if (this.links.defaults) {\n        all.push(...this.links.defaults.filter((link) => link.enabled));\n      }\n\n      // Process the links\n      return all.map((item) => ({\n        ...item,\n        value: processLink(item.value)\n      }));\n    }\n  },\n  methods: {\n    show() {\n      this.$store.dispatch('management/promptModal', { component: 'WechatDialog' });\n    }\n  },\n};\n</script>\n\n<template>\n  <div v-if=\"hasOptions\">\n    <SimpleBox\n      :pref=\"pref\"\n      :pref-key=\"prefKey\"\n    >\n      <template #title>\n        <h2>\n          {{ t('customLinks.displayTitle') }}\n        </h2>\n      </template>\n      <div\n        v-for=\"(link, i) in options\"\n        :key=\"i\"\n        class=\"support-link\"\n      >\n        <router-link\n          v-if=\"link.value.startsWith('/') \"\n          :to=\"link.value\"\n          role=\"link\"\n          :aria-label=\"link.label\"\n        >\n          {{ link.label }}\n        </router-link>\n        <a\n          v-else\n          :href=\"link.value\"\n          rel=\"noopener noreferrer nofollow\"\n          target=\"_blank\"\n          role=\"link\"\n          :aria-label=\"link.label\"\n        > {{ link.label }} </a>\n      </div>\n      <slot />\n      <div\n        v-if=\"selectedLocaleLabel === t('locale.zh-hans')\"\n        class=\"support-link\"\n      >\n        <a\n          class=\"link\"\n          tabindex=\"0\"\n          :aria-label=\"t('footer.wechat.title')\"\n          role=\"link\"\n          @click=\"show\"\n          @keydown.enter=\"show\"\n        >\n          {{ t('footer.wechat.title') }}\n        </a>\n      </div>\n    </SimpleBox>\n  </div>\n</template>\n\n<style lang='scss' scoped>\n  h2 {\n    display: flex;\n    align-items: center;\n\n    i {\n      font-size: 12px;\n      margin-left: 5px;\n    }\n  }\n  .support-link:not(:last-child) {\n    margin-bottom: 15px;\n  }\n</style>\n"]}]}