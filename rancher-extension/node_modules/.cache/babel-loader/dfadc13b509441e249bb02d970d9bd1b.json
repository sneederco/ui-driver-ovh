//,'') }}\n          <i class=\"icon icon-external-link\" />\n        </a>\n      </template>\n      <span\n        v-else\n        class=\"text-muted\"\n      >&mdash;</span>\n    </template>\n  </ResourceTable>\n</template>\n"]}]}