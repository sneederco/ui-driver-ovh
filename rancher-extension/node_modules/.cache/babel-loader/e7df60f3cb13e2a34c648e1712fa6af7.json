AAC;MACxD,CAAC;IACH,CAAC;EACH,CAAC;AACH,CAAC","file":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/edit/autoscaling.horizontalpodautoscaler/resource-metric.vue","sourceRoot":"","sourcesContent":["<script>\nimport LabeledSelect from '@shell/components/form/LabeledSelect';\nimport MetricTarget from '@shell/edit/autoscaling.horizontalpodautoscaler/metric-target';\n\nexport const DEFAULT_RESOURCE_METRIC = {\n  type:     'Resource',\n  resource: {\n    name:   'cpu',\n    target: {\n      type:               'Utilization',\n      averageUtilization: 80,\n    },\n  },\n};\n\nexport default {\n  components: { LabeledSelect, MetricTarget },\n  props:      {\n    value: {\n      type:    Object,\n      default: () => ({\n        name:   '',\n        target: {}\n      }),\n    },\n\n    mode: {\n      type:    String,\n      default: 'create',\n    },\n  },\n\n  data() {\n    return {\n      resourceTypes: [\n        { label: this.t('hpa.types.cpu'), value: 'cpu' },\n        { label: this.t('hpa.types.memory'), value: 'memory' },\n      ],\n    };\n  },\n};\n</script>\n\n<template>\n  <div class=\"resource-metric\">\n    <div class=\"row mb-20\">\n      <div class=\"col span-6\">\n        <LabeledSelect\n          v-model:value=\"value.name\"\n          :mode=\"mode\"\n          :label=\"t('hpa.metrics.headers.resource')\"\n          :options=\"resourceTypes\"\n        />\n      </div>\n    </div>\n    <div class=\"row\">\n      <MetricTarget\n        v-model:value=\"value.target\"\n        :mode=\"mode\"\n        metric-resource=\"resource\"\n        :resource-name=\"value.name\"\n      />\n    </div>\n  </div>\n</template>\n"]}]}