{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js??ruleSet[1].rules[4]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js??ruleSet[0].use[0]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/auth/login/saml.vue?vue&type=template&id=301d0884&scoped=true","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/auth/login/saml.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/auth/login/saml.vue"],"names":["t","displayName"],"mappings":";;qBA8DO,KAAK,EAAC,aAAa;;;EAGpB,KAAK,EAAC,WAAW;;qBAEZ,KAAK,EAAC,aAAa;;;EAKtB,KAAK,EAAC,uBAAuB;;qBAKxB,KAAK,EAAC,aAAa;qBAGnB,KAAK,EAAC,gBAAgB;;;wBAlBjC,oBAgCM,OAhCN,UAgCM;KA9BI,mBAAU;uBADlB,oBAqBM,OArBN,UAqBM;UAjBJ,oBAEM,OAFN,UAEM,mBADDA,MAAC;;WAGE,wBAAe;6BADvB,oBAKM,OALN,UAKM,mBADDA,MAAC;6BAEN,oBAOW;gBANT,oBAEM,OAFN,UAEM,mBADDA,MAAC,CAAC,0BAAiB;;gBAExB,oBAEM,OAFN,UAEM,mBADD,qBAAY;;;;;MAKZ,wBAAe;uBADxB,oBAQS;;UANP,GAAG,EAAC,KAAK;UACT,KAAK,EAAC,gBAAgB;UACtB,KAAwB,EAAxB,oBAAwB;UACvB,OAAK,0CAAE,yCAAK;4BAEVA,MAAC,uCAAuCC,gBAAW","sourcesContent":["<script>\nimport Login from '@shell/mixins/login';\nexport default {\n  mixins: [Login],\n\n  methods: {\n    async login() {\n      const { requestId, publicKey, responseType } = this.$route.query;\n\n      const res = await this.$store.dispatch('auth/login', {\n        provider: this.name,\n        body:     {\n          finalRedirectUrl: window.location.origin,\n          requestId,\n          publicKey,\n          responseType\n        }\n      });\n\n      const { idpRedirectUrl } = res;\n\n      window.location.href = idpRedirectUrl;\n    },\n  },\n\n  computed: {\n    // If any of the 3 params is specified, this is a CLI login\n    isCLILogin() {\n      const {\n        cli,\n        requestId,\n        publicKey,\n        responseType\n      } = this.$route.query;\n\n      return cli || publicKey || responseType || requestId;\n    },\n    // If this is a CLI login, we must have the correct respone type and the other params must not be empty\n    invalidCLILogin() {\n      const { requestId, publicKey, responseType } = this.$route.query;\n\n      if (this.isCLILogin) {\n        return responseType !== 'kubeconfig' || !requestId || !publicKey;\n      }\n\n      return false;\n    },\n    cliLoginCode() {\n      const { requestId } = this.$route.query;\n\n      return requestId;\n    },\n    warningMessageKey() {\n      const { cli } = this.$route.query;\n\n      return cli === 'true' ? 'login.cli.warning' : 'login.cli.warningLegacy';\n    }\n  }\n};\n</script>\n\n<template>\n  <div class=\"text-center\">\n    <div\n      v-if=\"isCLILogin\"\n      class=\"cli-login\"\n    >\n      <div class=\"cli-message\">\n        {{ t('login.cli.welcome') }}\n      </div>\n      <div\n        v-if=\"invalidCLILogin\"\n        class=\"cli-message cli-error\"\n      >\n        {{ t('login.cli.invalidParams') }}\n      </div>\n      <template v-else>\n        <div class=\"cli-message\">\n          {{ t(warningMessageKey, {}, true) }}\n        </div>\n        <div class=\"cli-login-code\">\n          {{ cliLoginCode }}\n        </div>\n      </template>\n    </div>\n    <button\n      v-if=\"!invalidCLILogin\"\n      ref=\"btn\"\n      class=\"btn bg-primary\"\n      style=\"font-size: 18px;\"\n      @click=\"login\"\n    >\n      {{ t('login.loginWithProvider', {provider: displayName}) }}\n    </button>\n  </div>\n</template>\n<style lang=\"scss\" scoped>\n  .cli-login {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n\n    > div {\n      margin-bottom: 8px\n    }\n\n    .cli-message {\n      font-size: 16px;\n\n      &.cli-error {\n        color: var(--error);\n      }\n    }\n\n    .cli-login-code {\n      font-family: 'Courier New', Courier, monospace;\n      border: 1px solid var(--border);\n      border-radius: var(--border-radius);\n      padding: 4px 8px;\n      margin: 8px 0 16px 0;\n      letter-spacing: 1px;\n      font-size: 16px;\n    }\n  }\n</style>\n"]}]}