\"\n          :label=\"t('workload.storage.emptyDir.sizeLimit.label')\"\n          :increment=\"1024\"\n          :input-exponent=\"2\"\n          :output-modifier=\"true\"\n          :placeholder=\"t('workload.storage.emptyDir.sizeLimit.placeholder')\"\n        />\n      </div>\n    </div>\n  </div>\n</template>\n"]}]}