R,KAAK,EAAE,KAAK,CAAC,GAAG,CAAC,KAAK;4CAAf,KAAK,CAAC,GAAG,CAAC,KAAK;cAC7B,IAAI,EAAE,WAAI;cACV,IAAI,EAAE,WAAI;cACV,SAAS,EAAE,gBAAS;cACpB,aAAW,wBAAwB,KAAK,CAAC,CAAC;;;;;;;;IAMrD,oBAwBM,OAxBN,UAwBM;MAvBJ,oBAsBM,OAtBN,UAsBM;QArBJ,oBAMK;4CALAA,MAAC,uCAAsC,GAC1C;0BAAA,oBAGE,KAHF,UAGE;uCAFiBA,MAAC,kBAAkB,WAAI;;;;QAI5C,aAamB;UAZT,KAAK,EAAE,YAAK,CAAC,KAAK;kEAAX,YAAK,CAAC,KAAK;UACzB,WAAS,EAAEA,MAAC;UACZ,mBAAiB,EAAE,EAAE;UACrB,IAAI,EAAE,WAAI;;UAEA,OAAO,WAChB,CAIE,AALgB,KAAK;YACvB,aAIE;cAHA,GAAG,EAAC,UAAU;cACN,KAAK,EAAE,KAAK,CAAC,GAAG,CAAC,KAAK;4CAAf,KAAK,CAAC,GAAG,CAAC,KAAK;cAC7B,IAAI,EAAE,WAAI","sourcesContent":["<script>\n\nimport PolicyRulePort from '@shell/edit/networking.k8s.io.networkpolicy/PolicyRulePort';\nimport ArrayListGrouped from '@shell/components/form/ArrayListGrouped';\nimport { _EDIT } from '@shell/config/query-params';\nimport PolicyRuleTarget from '@shell/edit/networking.k8s.io.networkpolicy/PolicyRuleTarget';\n\n// Components shown for Network Policy --> Ingress/Egress Rules --> Rule Type are...\n// Edit Network Policy --> `PolicyRules` 1 --> M `PolicyRule` 1 --> M `PolicyRuleTarget`\n\nexport default {\n  components: {\n    ArrayListGrouped, PolicyRulePort, PolicyRuleTarget\n  },\n  props: {\n    value: {\n      type:    Object,\n      default: () => {\n        return {};\n      },\n    },\n    mode: {\n      type:    String,\n      default: _EDIT,\n    },\n    type: {\n      type:    String,\n      default: 'ingress'\n    },\n    namespace: {\n      type:    String,\n      default: ''\n    },\n  },\n  data() {\n    return { targetKey: this.type === 'ingress' ? 'from' : 'to' };\n  }\n};\n</script>\n\n<template>\n  <div class=\"rule\">\n    <div class=\"row mb-40\">\n      <div class=\"col span-12\">\n        <h2>\n          {{ t(`networkpolicy.${type}.ruleLabel`) }}\n          <i\n            v-clean-tooltip=\"t(`networkpolicy.${type}.ruleHint`)\"\n            class=\"icon icon-info\"\n          />\n        </h2>\n        <ArrayListGrouped\n          v-model:value=\"value[targetKey]\"\n          :add-label=\"t(`networkpolicy.rules.${type}.add`)\"\n          :default-add-value=\"{}\"\n          :mode=\"mode\"\n        >\n          <template #default=\"props\">\n            <PolicyRuleTarget\n              ref=\"lastTarget\"\n              v-model:value=\"props.row.value\"\n              :mode=\"mode\"\n              :type=\"type\"\n              :namespace=\"namespace\"\n              :data-testid=\"`policy-rule-target-${props.i}`\"\n            />\n          </template>\n        </ArrayListGrouped>\n      </div>\n    </div>\n    <div class=\"row mb-20\">\n      <div class=\"col span-12\">\n        <h2>\n          {{ t('networkpolicy.rules.ports.label') }}\n          <i\n            v-clean-tooltip=\"t(`networkpolicy.${type}.portHint`)\"\n            class=\"icon icon-info\"\n          />\n        </h2>\n        <ArrayListGrouped\n          v-model:value=\"value.ports\"\n          :add-label=\"t('networkpolicy.rules.addPort')\"\n          :default-add-value=\"{}\"\n          :mode=\"mode\"\n        >\n          <template #default=\"props\">\n            <PolicyRulePort\n              ref=\"lastPort\"\n              v-model:value=\"props.row.value\"\n              :mode=\"mode\"\n            />\n          </template>\n        </ArrayListGrouped>\n      </div>\n    </div>\n  </div>\n</template>\n"]}]}