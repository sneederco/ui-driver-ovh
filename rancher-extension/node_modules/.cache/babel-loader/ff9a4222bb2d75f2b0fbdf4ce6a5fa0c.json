AI,EAAC,OAAO;YACX,OAAO,EAAE,kBAAY;YACrB,GAAG,EAAE,IAAI;YACV,KAAK,EAAC,OAAO;;YAEF,KAAK,WACd,CAAmC;cAAnC,oBAAmC,6BAA5BA,MAAC;;;;;UAGZ,aASa;YARH,KAAK,EAAE,iBAAW;oEAAX,iBAAW;YAC1B,IAAI,EAAC,aAAa;YACjB,OAAO,EAAE,wBAAkB;YAC5B,KAAK,EAAC,OAAO;;YAEF,KAAK,WACd,CAA+C;cAA/C,oBAA+C,6BAAxCA,MAAC;;;;;UAGZ,aAQE;YAPQ,KAAK,EAAE,UAAI,CAAC,WAAW;oEAAhB,UAAI,CAAC,WAAW;YAC9B,IAAI,EAAE,iBAAW,GAAG,UAAI,GAAG,UAAI;YAChC,IAAI,EAAC,QAAQ;YACb,GAAG,EAAC,GAAG;YACN,MAAM,EAAEA,MAAC;YACT,WAAW,EAAEA,MAAC;YACf,KAAK,EAAC,OAAO;;;UAEf,aASa;YARH,KAAK,EAAE,aAAO;oEAAP,aAAO;YACtB,IAAI,EAAC,SAAS;YACb,OAAO,EAAE,oBAAc;YACxB,KAAK,EAAC,OAAO;;YAEF,KAAK,WACd,CAA2C;cAA3C,oBAA2C,6BAApCA,MAAC;;;;;UAGZ,aAQE;YAPQ,KAAK,EAAE,UAAI,CAAC,OAAO;oEAAZ,UAAI,CAAC,OAAO;YAC1B,IAAI,EAAE,aAAO,GAAG,UAAI,GAAG,UAAI;YAC5B,IAAI,EAAC,QAAQ;YACb,GAAG,EAAC,GAAG;YACP,GAAG,EAAC,OAAO;YACV,MAAM,EAAEA,MAAC;YACT,WAAW,EAAEA,MAAC;;;;2BAGnB,oBAKE,6BAJmB,YAAM,GAAjB,GAAG,EAAE,CAAC;gCADhB,aAKE;YAHC,GAAG,EAAE,CAAC;YACP,KAAK,EAAC,OAAO;YACZ,KAAK,EAAE,GAAG;;;;;IAKN,OAAO,WAChB,CAYM;MAZN,oBAYM,OAZN,UAYM;QAXJ,oBAKS;UAJP,KAAK,EAAC,0BAA0B;UAC/B,OAAK,0CAAE,yCAAK;4BAEVA,MAAC;;QAGN,aAGE;UAFA,IAAI,EAAC,OAAO;UACX,OAAK,EAAE,cAAK","sourcesContent":["<script>\nimport AsyncButton from '@shell/components/AsyncButton';\nimport { Banner } from '@components/Banner';\nimport { Card } from '@components/Card';\nimport { RadioGroup } from '@components/Form/Radio';\nimport UnitInput from '@shell/components/form/UnitInput';\nimport { _EDIT, _VIEW } from '@shell/config/query-params';\n\nimport { exceptionToErrorsArray } from '@shell/utils/error';\n\nexport default {\n  emits: ['close'],\n\n  components: {\n    AsyncButton,\n    Banner,\n    Card,\n    RadioGroup,\n    UnitInput\n  },\n\n  props: {\n    kubeNodes: {\n      type:    Array,\n      default: () => []\n    },\n\n    normanNodeId: {\n      type:    String,\n      default: ''\n    }\n  },\n\n  data() {\n    return {\n      radioOptions: [{\n        label: this.t('generic.yes'),\n        value: true,\n      }, {\n        label: this.t('generic.no'),\n        value: false,\n      }],\n      gracePeriodOptions: [{\n        label: this.t('drainNode.gracePeriod.default'),\n        value: false,\n      }, {\n        label: this.t('drainNode.gracePeriod.custom'),\n        value: true,\n      }],\n      timeoutOptions: [{\n        label: this.t('drainNode.timeout.default'),\n        value: false,\n      }, {\n        label: this.t('drainNode.timeout.custom'),\n        value: true,\n      }],\n\n      gracePeriod: false,\n      timeout:     false,\n\n      body: {\n        deleteLocalData: false,\n        force:           false,\n        gracePeriod:     null,\n        timeout:         null\n      },\n\n      EDIT: _EDIT,\n      VIEW: _VIEW,\n\n      errors: [],\n    };\n  },\n\n  watch: {\n    gracePeriod(neu) {\n      if (neu && !this.body.gracePeriod) {\n        this.body.gracePeriod = 30;\n      }\n    },\n    'body.gracePeriod'(neu) {\n      if (neu && neu < 1) {\n        this.body['gracePeriod'] = 1;\n      }\n    },\n    timeout(neu) {\n      if (neu && !this.body.timeout) {\n        this.body.timeout = 60;\n      }\n    },\n    'body.timeout'(neu) {\n      if (neu) {\n        if (neu < 1) {\n          this.body['timeout'] = 1;\n        } else if (neu > 10800) {\n          this.body['timeout'] = 10800;\n        }\n      }\n    },\n  },\n\n  methods: {\n    close() {\n      this.$emit('close');\n    },\n\n    async apply(buttonDone) {\n      const { gracePeriod, timeout, ...parsedBody } = this.body;\n\n      if (this.gracePeriod) {\n        parsedBody.gracePeriod = gracePeriod;\n      }\n      if (this.timeout) {\n        parsedBody.timeout = timeout;\n      }\n\n      try {\n        await Promise.all(this.kubeNodes.map((node) => node.norman?.doAction('drain', parsedBody)));\n        this.close();\n      } catch (e) {\n        this.errors = exceptionToErrorsArray(e);\n        buttonDone(false);\n      }\n    }\n  }\n};\n</script>\n\n<template>\n  <Card\n    class=\"prompt-rotate\"\n    :show-highlight-border=\"false\"\n  >\n    <template #title>\n      <h4 class=\"text-default-text\">\n        <template v-if=\"kubeNodes.length > 1\">\n          {{ t('drainNode.titleMultiple', { count: kubeNodes.length }) }}\n        </template>\n        <template v-else>\n          {{ t('drainNode.titleOne', { name: kubeNodes[0]?.name }, true) }}\n        </template>\n      </h4>\n    </template>\n\n    <template #body>\n      <div class=\"pl-10 pr-10\">\n        <div>\n          <RadioGroup\n            v-model:value=\"body.deleteLocalData\"\n            name=\"deleteLocalData\"\n            :options=\"radioOptions\"\n            :row=\"true\"\n            class=\"mb-15\"\n          >\n            <template #label>\n              <h5>{{ t('drainNode.deleteLocalData') }}</h5>\n            </template>\n          </RadioGroup>\n          <RadioGroup\n            v-model:value=\"body.force\"\n            name=\"force\"\n            :options=\"radioOptions\"\n            :row=\"true\"\n            class=\"mb-15\"\n          >\n            <template #label>\n              <h5>{{ t('drainNode.force') }}</h5>\n            </template>\n          </RadioGroup>\n          <RadioGroup\n            v-model:value=\"gracePeriod\"\n            name=\"gracePeriod\"\n            :options=\"gracePeriodOptions\"\n            class=\"mb-15\"\n          >\n            <template #label>\n              <h5>{{ t('drainNode.gracePeriod.title') }}</h5>\n            </template>\n          </RadioGroup>\n          <UnitInput\n            v-model:value=\"body.gracePeriod\"\n            :mode=\"gracePeriod ? EDIT : VIEW\"\n            type=\"number\"\n            min=\"1\"\n            :suffix=\"t('suffix.sec')\"\n            :placeholder=\"t('drainNode.gracePeriod.placeholder')\"\n            class=\"mb-10\"\n          />\n          <RadioGroup\n            v-model:value=\"timeout\"\n            name=\"timeout\"\n            :options=\"timeoutOptions\"\n            class=\"mb-15\"\n          >\n            <template #label>\n              <h5>{{ t('drainNode.timeout.title') }}</h5>\n            </template>\n          </RadioGroup>\n          <UnitInput\n            v-model:value=\"body.timeout\"\n            :mode=\"timeout ? EDIT : VIEW\"\n            type=\"number\"\n            min=\"1\"\n            max=\"10800\"\n            :suffix=\"t('suffix.sec')\"\n            :placeholder=\"t('drainNode.timeout.placeholder')\"\n          />\n        </div>\n        <Banner\n          v-for=\"(err, i) in errors\"\n          :key=\"i\"\n          color=\"error\"\n          :label=\"err\"\n        />\n      </div>\n    </template>\n\n    <template #actions>\n      <div class=\"buttons\">\n        <button\n          class=\"btn role-secondary mr-10\"\n          @click=\"close\"\n        >\n          {{ t('generic.cancel') }}\n        </button>\n\n        <AsyncButton\n          mode=\"drain\"\n          @click=\"apply\"\n        />\n      </div>\n    </template>\n  </Card>\n</template>\n<style lang='scss' scoped>\n  .prompt-rotate {\n    margin: 0;\n  }\n  .card-title h4 {\n    margin-bottom: 0;\n  }\n  .buttons {\n    display: flex;\n    justify-content: flex-end;\n    width: 100%;\n  }\n</style>\n"]}]}