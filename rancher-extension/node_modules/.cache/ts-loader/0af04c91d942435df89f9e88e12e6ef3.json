AAC,IAAG,KAAM,KAAK,CAAA;QAC5B,CAAC;KACF;IAED,OAAO,EAAE;QACP,UAAU,CAAC,KAAa;YACtB,IAAI,CAAC,KAAK,CAAC,YAAY,EAAE,KAAK,CAAC,CAAA;QACjC,CAAC;QAED,IAAI,CAAC,QAA6B;YAChC,IAAI,CAAC,KAAK,CAAC,MAAM,EAAE,QAAQ,CAAC,CAAA;QAC9B,CAAC;QAED,IAAI;YACF,IAAI,CAAC,KAAK,CAAC,MAAM,CAAC,CAAA;QACpB,CAAA;KACF;CACD,CAAC,CAAA","file":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/form/Footer.vue.tsx","sourceRoot":"","sourcesContent":["<script lang=\"ts\">\nimport { defineComponent, PropType } from 'vue';\nimport { _VIEW } from '@shell/config/query-params';\nimport AsyncButton, { AsyncButtonCallback } from '@shell/components/AsyncButton.vue';\nimport Banner from '@components/Banner/Banner.vue';\n\nexport default defineComponent({\n  emits: ['save', 'done', 'closeError'],\n\n  components: { AsyncButton, Banner },\n\n  props: {\n    /**\n     * Current mode of the page\n     * passed to asyncButton to determine lables of the button\n     */\n    mode: {\n      type:     String,\n      required: true,\n    },\n\n    errors: {\n      type:    Array as PropType<string[]>,\n      default: () => []\n    },\n\n    disableSave: {\n      type:    Boolean,\n      default: false,\n    }\n  },\n\n  computed: {\n    isView(): boolean {\n      return this.mode === _VIEW;\n    },\n  },\n\n  methods: {\n    closeError(index: number) {\n      this.$emit('closeError', index);\n    },\n\n    save(buttonCb: AsyncButtonCallback) {\n      this.$emit('save', buttonCb);\n    },\n\n    done() {\n      this.$emit('done');\n    }\n  }\n});\n</script>\n<template>\n  <div v-if=\"!isView\">\n    <div class=\"spacer-small\" />\n\n    <div\n      v-for=\"(err,idx) in errors\"\n      :key=\"idx\"\n    >\n      <Banner\n        color=\"error\"\n        :label=\"err\"\n        :closable=\"true\"\n        @close=\"closeError(idx)\"\n      />\n    </div>\n    <div class=\"buttons\">\n      <div class=\"left\">\n        <slot name=\"left\" />\n      </div>\n      <div class=\"right\">\n        <slot name=\"cancel\">\n          <button\n            type=\"button\"\n            class=\"btn role-secondary\"\n            @click=\"done\"\n          >\n            <t k=\"generic.cancel\" />\n          </button>\n        </slot>\n        <slot name=\"middle\" />\n        <slot name=\"save\">\n          <AsyncButton\n            v-if=\"!isView\"\n            :mode=\"mode\"\n            :disabled=\"disableSave\"\n            @click=\"save\"\n          />\n        </slot>\n        <slot name=\"right\" />\n      </div>\n    </div>\n  </div>\n</template>\n\n<style lang='scss'>\n  .buttons {\n    display: grid;\n    grid-template-areas:  \"left right\";\n    grid-template-columns: \"min-content auto\";\n\n    .left {\n      grid-area: left;\n      text-align: left;\n\n      .btn, button {\n        margin: 0 $column-gutter 0 0;\n      }\n    }\n\n    .right {\n      grid-area: right;\n      text-align: right;\n\n      .btn, button {\n        margin: 0 0 0 $column-gutter;\n      }\n    }\n  }\n</style>\n"]}]}