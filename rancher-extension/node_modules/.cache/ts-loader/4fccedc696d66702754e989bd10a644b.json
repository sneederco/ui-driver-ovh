OAAO;oBACL,GAAG,KAAK,CAAC,MAAM,CAAC,CAAC,CAAC,EAAE,CAAC,EAAE,EAAC,CAAE,CAAA,GAAI,GAAG,CAAC;oBAClC,IAAI,CAAC,CAAC,CAAC,8CAA8C,EAAE,EAAE,CAAC,EAAE,SAAQ,EAAG,EAAE,IAAI,CAAC;iBAC/E,CAAA;YACH,CAAA;YAEA,OAAO,KAAK,CAAA;QACd,CAAA;KACF;CACD,CAAA","file":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/fleet/FleetClusterTargets/TargetsList.vue.tsx","sourceRoot":"","sourcesContent":["<script lang=\"ts\">\nimport { PropType } from 'vue';\nimport { Cluster } from '@shell/components/fleet/FleetClusterTargets/index.vue';\n\nexport default {\n  name: 'FleetTargetsList',\n\n  props: {\n    clusters: {\n      type:    Array as PropType<Cluster[]>,\n      default: () => [],\n    },\n\n    emptyLabel: {\n      type:    String,\n      default: ''\n    }\n  },\n\n  computed: {\n    names() {\n      const names = this.clusters.map(({ nameDisplay, name }) => nameDisplay || name);\n      const max = 10;\n\n      const remaining = names.length - max;\n\n      if (remaining > 0) {\n        return [\n          ...names.filter((_, i) => i < max),\n          this.t('fleet.clusterTargets.rules.matching.plusMore', { n: remaining }, true),\n        ];\n      }\n\n      return names;\n    }\n  }\n};\n</script>\n\n<template>\n  <div class=\"targets-list\">\n    <h3>{{ t('fleet.clusterTargets.rules.matching.title') }}</h3>\n    <span\n      v-for=\"(name, i) in names\"\n      :key=\"i\"\n      class=\"row mt-5\"\n    >\n      {{ name }}\n    </span>\n    <span\n      v-if=\"!names.length\"\n      class=\"text-label\"\n    >\n      {{ emptyLabel || t('fleet.clusterTargets.rules.matching.empty') }}\n    </span>\n  </div>\n</template>\n\n<style lang=\"scss\" scoped>\n  .targets-list {\n    height: 100%;\n    border-radius: 4px;\n    padding: 16px;\n    background-color: var(--tabbed-sidebar-bg);\n  }\n</style>\n"]}]}