e';\n\nexport const useFetch = <T>(fetch: () => Promise<T> ) => {\n  const loading = ref<boolean>(true);\n  const data = ref<T>();\n  const error = ref<any>();\n\n  const load = async() => {\n    try {\n      loading.value = true;\n\n      data.value = toValue(await fetch());\n    } catch (ex) {\n      error.value = ex;\n    } finally {\n      loading.value = false;\n    }\n  };\n\n  load();\n\n  return computed(() => ({\n    loading: loading.value,\n    data:    data.value,\n    error:   error.value\n  }));\n};\n"]}]}