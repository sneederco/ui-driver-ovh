el=\"noopener noreferrer\"\n        >\n          <div class=\"link-logo\">\n            <LazyImage :src=\"fel.iconSrc\" />\n          </div>\n          <div class=\"link-content\">\n            <t :k=\"fel.label\" />\n            <i class=\"icon icon-external-link pull-right\" />\n            <hr role=\"none\">\n            <div class=\"description\"><t :k=\"fel.description\" /></div>\n          </div>\n        </a>\n      </div>\n    </div>\n  </section>\n</template>\n"]}]}