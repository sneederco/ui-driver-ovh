AAE,YAAI,CAAC,CAAC,sEAAsE,KAAK,CAAC,QAAQ,CAAC,WAAW;QAC1H,aAAW,EAAC,8BAA8B;QACzC,eAAc,8CAAE,IAAI;;;sBAEd,CAEX;;MAAA,oBA+BM;2BA9BJ,oBA6BM,6BA5BsB,KAAK,CAAC,QAAQ,CAAC,MAAM,GAAvC,UAAU,EAAE,CAAC;gCADvB,oBA6BM;YA3BH,GAAG,EAAE,UAAU,CAAC,KAAK;YACtB,KAAK,EAAC,KAAK;;YAEX,oBAKQ;cAJN,KAAK,EAAC,yBAAyB;cAC9B,GAAG,EAAE,oBAAoB,CAAC,UAAU;gCAElC,UAAU,CAAC,KAAK;;YAErB,oBAiBM;cAhBH,EAAE,EAAE,oBAAoB,CAAC,UAAU;cACpC,KAAK,EAAC,OAAO;;eAIL,UAAU,CAAC,SAAS;iCAF5B,aAME,yBALK,UAAU,CAAC,SAAS,GAD3B,YAME;;;qBAHQ,UAAU,CAAC,aAAa;oBAC/B,EAAE,EAAE,CAAC,+BAA+B,SAAS;oBAC7C,KAAK,EAAE,UAAU,CAAC,OAAO;;iCAE5B,oBAKO;;oBAHJ,EAAE,EAAE,CAAC,+BAA+B,SAAS;sCAE3C,UAAU,CAAC,OAAO","sourcesContent":["<script lang=\"ts\">\nimport Card from '@shell/components/Resource/Detail/Card/index.vue';\nimport { useStore } from 'vuex';\nimport ActionMenu from '@shell/components/ActionMenuShell.vue';\nimport { useI18n } from '@shell/composables/useI18n';\n\nexport interface Props {\n  resource: any;\n}\n</script>\n\n<script setup lang=\"ts\">\nconst emit = defineEmits(['action-invoked']);\nconst props = defineProps<Props>();\nconst store = useStore();\nconst i18n = useI18n(store);\n\nconst getGlanceItemValueId = (glanceItem: any): string => `value-${ glanceItem.label }:${ glanceItem.content }`.toLowerCase().replaceAll(' ', '');\n</script>\n\n<template>\n  <Card\n    class=\"resource-popover-card\"\n    :title=\"resource.nameDisplay\"\n  >\n    <template #heading-action>\n      <ActionMenu\n        :resource=\"props.resource\"\n        :button-aria-label=\"i18n.t('component.resource.detail.glance.ariaLabel.actionMenu', { resource: props.resource.nameDisplay })\"\n        data-testid=\"resource-popover-action-menu\"\n        @action-invoked=\"emit('action-invoked')\"\n      />\n    </template>\n\n    <div>\n      <div\n        v-for=\"(glanceItem, i) in props.resource.glance\"\n        :key=\"glanceItem.label\"\n        class=\"row\"\n      >\n        <label\n          class=\"label text-deemphasized\"\n          :for=\"getGlanceItemValueId(glanceItem)\"\n        >\n          {{ glanceItem.label }}\n        </label>\n        <div\n          :id=\"getGlanceItemValueId(glanceItem)\"\n          class=\"value\"\n        >\n          <component\n            :is=\"glanceItem.formatter\"\n            v-if=\"glanceItem.formatter\"\n            v-bind=\"glanceItem.formatterOpts\"\n            :id=\"i === 0 ? 'first-glance-item' : undefined\"\n            :value=\"glanceItem.content\"\n          />\n          <span\n            v-else\n            :id=\"i === 0 ? 'first-glance-item' : undefined\"\n          >\n            {{ glanceItem.content }}\n          </span>\n        </div>\n      </div>\n    </div>\n  </Card>\n</template>\n\n<style lang=\"scss\" scoped>\n.resource-popover-card {\n  width: 288px;\n\n  .dropdown-item {\n    display: inline-block;\n    padding: 0;\n    margin: 0;\n    border: none;\n\n    &:hover {\n      background: none;\n    }\n  }\n\n  &:deep() {\n    .badge-state {\n      height: 20px;\n      font-size: 12px;\n    }\n\n    .heading {\n      height: 24px;\n\n      .title {\n        font-size: 16px;\n        font-weight: 600;\n        line-height: 24px;\n      }\n    }\n\n    .v-popper, .btn.role-link {\n      height: 24px;\n      min-height: initial;\n      padding: 0;\n    }\n\n    .v-popper {\n      padding: 0;\n    }\n\n    .btn.role-link {\n      color: #141419;\n      padding: 0 12px;\n      i {\n        display: inline-flex;\n        justify-content: center;\n        font-size: 12px;\n        width: 2.5px;\n      }\n\n      &:hover {\n        background-color: transparent\n      }\n    }\n  }\n\n  .row {\n    display: flex;\n    flex-direction: row;\n    line-height: 21px;\n\n    &:not(:first-of-type) {\n      margin-top: 4px;\n    }\n\n    .label {\n      width: 50%;\n    }\n  }\n}\n</style>\n"]}]}