{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/CopyCode.vue?vue&type=template&id=2163c48c&scoped=true","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/CopyCode.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/templateLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:CiAgPGNvZGUKICAgIHYtY2xlYW4tdG9vbHRpcD0idG9vbHRpcCIKICAgIGNsYXNzPSJjb3B5IgogICAgQGNsaWNrLnN0b3AucHJldmVudD0iY2xpY2tlZCIKICA+PHNsb3QgLz48L2NvZGU+Cg=="},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/CopyCode.vue"],"names":[],"mappings":";EA8DE,CAAC,CAAC,CAAC,CAAC;IACF,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;IACxB,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;IACX,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;EAC9B,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC","file":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/CopyCode.vue","sourceRoot":"","sourcesContent":["<script>\nimport { isArray } from '@shell/utils/array';\nimport { copyTextToClipboard } from '@shell/utils/clipboard';\nimport { exceptionToErrorsArray } from '@shell/utils/error';\n\nfunction flatten(node) {\n  if ( node.text ) {\n    return node.text;\n  } else if ( isArray(node) ) {\n    return node.map(flatten).join(' ');\n  } else if ( node.children ) {\n    if ( isArray(node.children) ) {\n      return node.children.map(flatten).join(' ');\n    } else {\n      return node.children;\n    }\n  } else {\n    return '';\n  }\n}\n\nexport default {\n  emits: ['copied', 'error'],\n\n  data() {\n    return { copied: false };\n  },\n\n  methods: {\n    clicked($event) {\n      $event.stopPropagation();\n      $event.preventDefault();\n\n      const content = flatten(this.$slots.default()).trim();\n\n      copyTextToClipboard(content).then(() => {\n        this.copied = true;\n\n        setTimeout(() => {\n          this.copied = false;\n        }, 2000);\n        this.$emit('copied');\n      }).catch((e) => {\n        this.$emit('error', exceptionToErrorsArray(e));\n      });\n    },\n  },\n\n  computed: {\n    tooltip() {\n      const content = this.copied ? 'Copied!' : 'Click to Copy';\n\n      return {\n        content,\n        hideOnTargetClick: false\n      };\n    }\n  }\n};\n</script>\n\n<template>\n  <code\n    v-clean-tooltip=\"tooltip\"\n    class=\"copy\"\n    @click.stop.prevent=\"clicked\"\n  ><slot /></code>\n</template>\n\n<style lang=\"scss\" scoped>\n  .copy {\n    cursor: pointer;\n  }\n</style>\n"]}]}