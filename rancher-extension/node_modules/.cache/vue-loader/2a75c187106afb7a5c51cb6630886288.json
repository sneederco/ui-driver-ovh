AAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC;EACZ","file":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/dialog/SloDialog.vue","sourceRoot":"","sourcesContent":["<script>\nimport { Card } from '@components/Card';\nimport AsyncButton from '@shell/components/AsyncButton';\nimport { IS_SSO, LOGGED_OUT } from '@shell/config/query-params';\n\nexport default {\n  emits: ['close'],\n\n  components: { Card, AsyncButton },\n\n  props: {\n    authProvider: {\n      type:     Object,\n      required: true\n    }\n  },\n\n  computed: {\n    name() {\n      return this.t(`model.authConfig.provider.\"${ this.authProvider?.id }\"`);\n    }\n  },\n\n  methods: {\n    async doLogout(logoutAll = false) {\n      const options = { force: true, provider: this.authProvider };\n\n      if (logoutAll) {\n        // SLO - Single Log Out\n        options.slo = true;\n        options.provider = this.authProvider;\n\n        await this.$store.dispatch('auth/logout', options, { root: true });\n\n        this.$emit('close');\n      } else {\n        // Rancher Log Out (ensure we show the logging out page as per standard log out)\n        this.$router.replace({ name: 'auth-logout', query: { [LOGGED_OUT]: true, [IS_SSO]: true } });\n      }\n    },\n\n    cancel() {\n      this.$emit('close');\n    }\n  }\n};\n</script>\n\n<template>\n  <Card\n    class=\"prompt-remove\"\n    :show-highlight-border=\"false\"\n  >\n    <template #title>\n      <h4 class=\"text-default-text\">\n        {{ t('promptSlo.title', { name }) }}\n      </h4>\n    </template>\n    <template #body>\n      <div class=\"pl-10 pr-10 mt-20 mb-20\">\n        {{ t('promptSlo.text', { name }) }}\n      </div>\n    </template>\n    <template #actions>\n      <div class=\"btn-block\">\n        <button\n          class=\"btn role-secondary\"\n          @click=\"cancel()\"\n        >\n          {{ t('generic.cancel') }}\n        </button>\n        <div class=\"spacer\" />\n        <button\n          class=\"btn role-secondary\"\n          @click=\"doLogout()\"\n        >\n          {{ t('promptSlo.rancher.active') }}\n        </button>\n        <AsyncButton\n          class=\"ml-10\"\n          :action-label=\"t('promptSlo.all.active', { name })\"\n          :waiting-label=\"t('promptSlo.all.waiting')\"\n          @click=\"doLogout(true)\"\n        />\n      </div>\n    </template>\n  </Card>\n</template>\n\n<style lang='scss' scoped>\n  .btn-block {\n    width: 100%;\n    display: flex;\n    justify-content: space-between;\n    padding: 0;\n  }\n</style>\n"]}]}