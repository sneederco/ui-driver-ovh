CAAC,CAAC,CAAC,EAAE;MACnB,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;MACtC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC;MAClB,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC;IAC1B;;IAEA,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE;MACnB,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC;MACb,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC;MACP,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,EAAE,CAAC,EAAE,CAAC,CAAC,EAAE,CAAC,CAAC,EAAE,CAAC,EAAE,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;;MAEtE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE;QAClB,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC;QACjB,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC;MACT;;MAEA,EAAE;QACA,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;MACpB;IACF;EACF","file":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/nav/NotificationCenter/NotificationHeader.vue","sourceRoot":"","sourcesContent":["<script setup lang=\"ts\">\nimport { useStore } from 'vuex';\nimport { computed, inject, ref } from 'vue';\nimport { DropdownContext, defaultContext } from '@components/RcDropdown/types';\n\nconst { dropdownItems } = inject<DropdownContext>('dropdownContext') || defaultContext;\nconst store = useStore();\nconst unreadCount = computed<number>(() => store.getters['notifications/unreadCount']);\nconst markAllReadButton = ref<HTMLElement>();\n\nconst markAllRead = (keyboard: boolean) => {\n  store.dispatch('notifications/markAllRead');\n\n  // If we have focus, then move to the next item if activated by the keyboard\n  if (keyboard && document.activeElement === markAllReadButton?.value) {\n    moveFocus(true);\n  }\n};\n\n/**\n * Handles keydown events to navigate between dropdown items.\n * @param {KeyboardEvent} e - The keydown event.\n */\nconst handleKeydown = (e: KeyboardEvent) => {\n  const shouldAdvance = e.key === 'ArrowDown';\n\n  moveFocus(shouldAdvance);\n};\n\n// User pressed up/down - move focus to the correct notification item\n// Header should always be the first item\nconst moveFocus = (shouldAdvance: Boolean) => {\n  if (dropdownItems.value.length > 1) {\n    const newIndex = shouldAdvance ? 1 : dropdownItems.value.length - 1;\n\n    if (dropdownItems.value[newIndex] instanceof HTMLElement) {\n      dropdownItems.value[newIndex].focus();\n    }\n  }\n};\n\nconst gotFocus = (e: Event) => {\n  // If no unread items, then there is no button to focus, so move to the next item\n  if (unreadCount.value === 0) {\n    moveFocus(true);\n  }\n\n  // When the header gets focus, pass the focus onto the 'mark all read' button\n  markAllReadButton?.value?.focus();\n};\n</script>\n\n<template>\n  <div\n    dropdown-menu-item\n    tabindex=\"-1\"\n    role=\"menuitem\"\n    class=\"notification-header\"\n    @click.stop\n    @keydown.up.down.stop.prevent=\"handleKeydown\"\n    @focus=\"gotFocus\"\n  >\n    <div class=\"notification-header\">\n      <div class=\"notification-title\">\n        {{ t('notificationCenter.title') }}\n      </div>\n      <div v-if=\"unreadCount !== 0\">\n        <a\n          ref=\"markAllReadButton\"\n          role=\"button\"\n          tabindex=\"-1\"\n          href=\"#\"\n          data-testid=\"notifications-center-markall-read\"\n          @keydown.up.down.stop.prevent=\"handleKeydown\"\n          @keydown.enter.space.stop=\"markAllRead(true)\"\n          @click=\"markAllRead(false)\"\n        >\n          {{ t('notificationCenter.markAllRead') }}\n        </a>\n      </div>\n    </div>\n    <div class=\"notification-border\" />\n  </div>\n</template>\n\n<style lang=\"scss\" scoped>\n  [dropdown-menu-item] {\n    display: flex;\n    flex-direction: column;\n\n    .notification-border {\n      border-bottom: 1px solid var(--border);\n      margin-left: -16px;\n      width: calc(100% + 32px);\n    }\n\n    .notification-header {\n      display: flex;\n      flex: 1;\n      padding: 6px 16px 16px 16px; // already 10px at the top of the dropdown\n\n      .notification-title {\n        font-weight: bold;\n        flex: 1;\n      }\n\n      A {\n        color: var(--link);\n      }\n    }\n  }\n</style>\n"]}]}