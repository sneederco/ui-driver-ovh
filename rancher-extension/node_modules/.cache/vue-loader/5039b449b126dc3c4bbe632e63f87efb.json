total: value.totalViolations }) }}\r\n        </h3>\r\n        <Banner\r\n          v-if=\"value.totalViolations !== value.violations.length\"\r\n          color=\"info\"\r\n        >\r\n          {{ t('gatekeeperConstraint.violations.notAll', { shown: value.violations.length }) }}\r\n        </Banner>\r\n        <SortableTable\r\n          :headers=\"headers\"\r\n          :rows=\"violations\"\r\n          :table-actions=\"false\"\r\n          :row-actions=\"false\"\r\n          :paging=\"true\"\r\n          :rows-per-page=\"10\"\r\n          key-field=\"id\"\r\n        />\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n"]}]}