         type=\"button\"\n            class=\"btn role-secondary mr-10\"\n            @click=\"close\"\n          >\n            {{ t('generic.cancel') }}\n          </button>\n          <AsyncButton\n            mode=\"continue\"\n            @click=\"apply\"\n          />\n        </div>\n      </div>\n    </template>\n  </Card>\n</template>\n<style lang='scss' scoped>\n.prompt-restore {\n  margin: 0;\n}\n\n.bottom {\n  display: flex;\n  flex-direction: column;\n  flex: 1;\n\n  .buttons {\n    display: flex;\n    justify-content: flex-end;\n    width: 100%;\n  }\n}\n</style>\n"]}]}