{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/Resource/Detail/Metadata/index.vue?vue&type=style&index=0&id=28858cd7&lang=scss&scoped=true","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/Resource/Detail/Metadata/index.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/css-loader/dist/cjs.js","mtime":1773048121362},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/stylePostLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/postcss-loader/dist/cjs.js","mtime":1773048124224},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/postcss-loader/dist/cjs.js","mtime":1773048124224},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/sass-loader/dist/cjs.js","mtime":1773048121092},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:Ci5tZXRhZGF0YSB7CiAgICAubGFiZWxzLWFuZC1hbm5vdGF0aW9ucy1lbXB0eSB7CiAgICAgIGdyaWQtY29sdW1uOiBzcGFuIDI7CiAgICB9Cn0K"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/Resource/Detail/Metadata/index.vue"],"names":[],"mappings":";AAmFA,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE;IACN,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE;MAC5B,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,EAAE,CAAC;IACrB;AACJ","file":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/Resource/Detail/Metadata/index.vue","sourceRoot":"","sourcesContent":["<script setup lang=\"ts\">\nimport IdentifyingInformation, { Row as IdentifyingInformationRow } from '@shell/components/Resource/Detail/Metadata/IdentifyingInformation/index.vue';\nimport Labels, { Label } from '@shell/components/Resource/Detail/Metadata/Labels/index.vue';\nimport Annotations, { Annotation } from '@shell/components/Resource/Detail/Metadata/Annotations/index.vue';\nimport SpacedRow from '@shell/components/Resource/Detail/SpacedRow.vue';\nimport KeyValue from '@shell/components/Resource/Detail/Metadata/KeyValue.vue';\nimport { computed } from 'vue';\nimport { useI18n } from '@shell/composables/useI18n';\nimport { useStore } from 'vuex';\nimport { ExtensionPoint, PanelLocation } from '@shell/core/types';\nimport ExtensionPanel from '@shell/components/ExtensionPanel.vue';\n\nexport interface MetadataProps {\n  resource: any;\n  identifyingInformation: IdentifyingInformationRow[],\n  labels: Label[],\n  annotations: Annotation[],\n  onShowConfiguration?: (returnFocusSelector: string) => void;\n}\n\nconst {\n  resource, identifyingInformation, labels, annotations\n} = defineProps<MetadataProps>();\nconst emit = defineEmits(['show-configuration']);\n\nconst store = useStore();\nconst i18n = useI18n(store);\n\nconst showBothEmpty = computed(() => labels.length === 0 && annotations.length === 0);\n</script>\n\n<template>\n  <SpacedRow\n    class=\"metadata ppb-3\"\n    v-bind=\"$attrs\"\n  >\n    <div\n      class=\"identifying-info\"\n    >\n      <IdentifyingInformation :rows=\"identifyingInformation\" />\n    </div>\n    <!-- In the renders we want the same empty message that the labels/annotations show but we want it to span two columns. This is a cheap way to keep the look consistent without duplicating code. -->\n    <div\n      v-if=\"showBothEmpty\"\n      class=\"labels-and-annotations-empty\"\n    >\n      <KeyValue\n        type=\"active\"\n        :rows=\"[]\"\n        :propertyName=\"i18n.t('component.resource.detail.metadata.labelsAndAnnotations')\"\n        @show-configuration=\"(returnFocusSelector: string) => emit('show-configuration', returnFocusSelector)\"\n      />\n    </div>\n    <!-- I'm not using v-else here so I can maintain the spacing correctly with the other columns in other rows. -->\n    <div\n      v-if=\"!showBothEmpty\"\n      class=\"labels\"\n    >\n      <Labels\n        :labels=\"labels\"\n        @show-configuration=\"(returnFocusSelector: string) => emit('show-configuration', returnFocusSelector)\"\n      />\n    </div>\n    <div\n      v-if=\"!showBothEmpty\"\n      class=\"annotations\"\n    >\n      <Annotations\n        :annotations=\"annotations\"\n        @show-configuration=\"(returnFocusSelector: string) => emit('show-configuration', returnFocusSelector)\"\n      />\n    </div>\n  </SpacedRow>\n  <!-- Extensions area -->\n  <ExtensionPanel\n    class=\"ppb-3\"\n    :resource=\"resource\"\n    :type=\"ExtensionPoint.PANEL\"\n    :location=\"PanelLocation.DETAIL_TOP\"\n  />\n</template>\n\n<style lang=\"scss\" scoped>\n.metadata {\n    .labels-and-annotations-empty {\n      grid-column: span 2;\n    }\n}\n</style>\n"]}]}