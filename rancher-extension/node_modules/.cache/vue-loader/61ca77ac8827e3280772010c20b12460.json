      type:    [Number, String],\n      default: () => 0,\n    },\n\n    opts: {\n      type:    Object,\n      default: () => {},\n    },\n\n    needParseSi: {\n      type:    Boolean,\n      default: false\n    }\n  },\n  computed: {\n    formattedValue() {\n      let parseValue = this.value;\n\n      if (this.needParseSi) {\n        parseValue = parseSi(this.value);\n      }\n\n      return formatSi(parseValue, {\n        suffix:      'iB',\n        firstSuffix: 'B',\n        increment:   1024,\n        ...this.opts\n      });\n    }\n  }\n};\n</script>\n\n<template>\n  <span v-if=\"value\">{{ formattedValue }}</span>\n  <span\n    v-else\n    class=\"text-muted\"\n  >&mdash;</span>\n</template>\n"]}]}