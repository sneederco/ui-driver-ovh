,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC;IACZ,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC;EAClB","file":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/edit/storage.k8s.io.storageclass/provisioners/kubernetes.io/azure-disk.vue","sourceRoot":"","sourcesContent":["<script>\r\nimport { LabeledInput } from '@components/Form/LabeledInput';\r\nimport LabeledSelect from '@shell/components/form/LabeledSelect';\r\nimport { _CREATE } from '@shell/config/query-params';\r\n\r\nexport default {\r\n  components: { LabeledInput, LabeledSelect },\r\n  props:      {\r\n    value: {\r\n      type:     Object,\r\n      required: true\r\n    },\r\n    mode: {\r\n      type:     String,\r\n      required: true\r\n    }\r\n  },\r\n  data() {\r\n    const kindOptions = [\r\n      {\r\n        label: this.t('storageClass.azure-disk.kind.shared'),\r\n        value: 'shared'\r\n      },\r\n      {\r\n        label: this.t('storageClass.azure-disk.kind.dedicated'),\r\n        value: 'dedicated'\r\n      },\r\n      {\r\n        label: this.t('storageClass.azure-disk.kind.managed'),\r\n        value: 'managed'\r\n      },\r\n    ];\r\n\r\n    // The 'shared' kind was removed by azure so we don't want to create any new ones. However we still should\r\n    // show the option for existing storage classes.\r\n    if (this.value.parameters.kind !== 'shared') {\r\n      kindOptions.shift();\r\n    }\r\n\r\n    if (this.mode === _CREATE) {\r\n      this.value.parameters['kind'] = this.value.parameters.kind || kindOptions[0].value;\r\n    }\r\n\r\n    return { kindOptions };\r\n  },\r\n};\r\n</script>\r\n<template>\r\n  <div>\r\n    <div class=\"row mb-10\">\r\n      <div class=\"col span-4\">\r\n        <LabeledInput\n          v-model:value=\"value.parameters.storageaccounttype\"\n          :placeholder=\"t('storageClass.azure-disk.storageAccountType.placeholder')\"\n          :label=\"t('storageClass.azure-disk.storageAccountType.label')\"\n          :mode=\"mode\"\n        />\r\n      </div>\r\n      <div class=\"col span-4\">\r\n        <LabeledSelect\n          v-model:value=\"value.parameters.kind\"\n          :options=\"kindOptions\"\n          :label=\"t('storageClass.azure-disk.kind.label')\"\n          :mode=\"mode\"\n        />\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n<style lang=\"scss\" scoped>\r\n  .col > .labeled-select:not(.taggable) {\r\n    height: 100%;\r\n    max-height: 100%;\r\n  }\r\n</style>\r\n"]}]}