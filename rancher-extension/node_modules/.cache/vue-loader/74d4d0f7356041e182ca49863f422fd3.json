l=\"false\"\r\n    :validation-passed=\"bindings.length > 0\"\r\n    @error=\"e=>errors = e\"\r\n    @finish=\"saveOverride\"\r\n    @cancel=\"done\"\r\n  >\r\n    <ClusterPermissionsEditor\r\n      v-model:value=\"bindings\"\r\n      :cluster-name=\"$store.getters['currentCluster'].id\"\r\n    />\r\n  </CruResource>\r\n</template>\r\n"]}]}