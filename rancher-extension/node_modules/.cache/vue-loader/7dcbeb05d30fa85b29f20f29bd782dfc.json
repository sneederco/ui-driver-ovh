eturn '';\n    }\n  }\n});\n</script>\n<template>\n  <Banner\n    v-if=\"!!asBanner && !!validationMessage\"\n    color=\"error\"\n    :label=\"validationMessage\"\n    :icon=\"icon\"\n  />\n  <span\n    v-else-if=\"!!validationMessage\"\n    class=\"text-error\"\n    data-testid=\"error-span\"\n  >{{ validationMessage }}</span>\n</template>\n"]}]}