padding: 5px 10px;\n    }\n\n    .step-list {\n      margin: 0;\n    }\n\n    .info-column:not(:last-child) {\n      border-right: 1px solid var(--tabbed-border);\n    }\n    .info-row {\n      margin-bottom: 10px;\n      .info-row-label {\n        padding-top: 2px;\n        display: inline-block;\n      }\n    }\n    .info-column,\n    .info-row {\n      label {\n        color: var(--input-label);\n      }\n    }\n\n    .info-column {\n      .usage {\n        margin-bottom: 10px;\n        label {\n          display: inline-block;\n          font-size: 12px;\n          padding-top: 6px;\n        }\n      }\n      .flex-item-half {\n        align-items: center;\n      }\n    }\n  }\n</style>\n"]}]}