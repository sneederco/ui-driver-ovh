AE;UACN,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;QAChC;;QAEA,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE;UACL,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;QAC/B;MACF;;IAEF;;AAEJ","file":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/Resource/Detail/Metadata/IdentifyingInformation/index.vue","sourceRoot":"","sourcesContent":["<script lang=\"ts\">\nimport { RouteLocationRaw } from 'vue-router';\n\nexport interface Row {\n    label: string;\n    value?: string;\n    valueOverride?: {\n      component: any,\n      props?: Object\n    },\n    to?: RouteLocationRaw;\n    dataTestid?: string;\n    valueDataTestid?: string;\n    status?: 'success' | 'warning' | 'info' | 'error',\n}\n\nexport interface MetadataProps {\n  rows: Row[];\n}\n</script>\n\n<script setup lang=\"ts\">\nconst { rows } = defineProps<MetadataProps>();\n\nconst getRowValueId = (row:Row): string => `value-${ row.label }:${ row.value }`.toLowerCase().replaceAll(' ', '');\n</script>\n\n<template>\n  <div class=\"identifying-information\">\n    <div\n      v-for=\"row in rows\"\n      :key=\"`${row.label}:${row.value}`\"\n      class=\"row\"\n      :data-testid=\"row.dataTestid\"\n    >\n      <label\n        class=\"label text-deemphasized\"\n        :for=\"getRowValueId(row)\"\n      >\n        {{ row.label }}\n      </label>\n      <!-- A custom component specified as an object, responsible for it's own styling -->\n      <div\n        v-if=\"typeof row.valueOverride?.component !== 'string' && row.valueOverride?.component && row.value\"\n        :id=\"getRowValueId(row)\"\n        class=\"full-custom-value\"\n      >\n        <component\n          :is=\"row.valueOverride?.component\"\n          v-if=\"row.valueOverride?.component\"\n          v-bind=\"row.valueOverride?.props\"\n          :data-testid=\"row.valueDataTestid\"\n        />\n      </div>\n      <!-- A formatter with a component specified as a string -->\n      <div\n        v-else-if=\"row.valueOverride?.component && row.value\"\n        :id=\"getRowValueId(row)\"\n        class=\"value\"\n      >\n        <component\n          :is=\"row.valueOverride?.component\"\n          v-if=\"row.valueOverride?.component\"\n          v-bind=\"row.valueOverride?.props\"\n          :data-testid=\"row.valueDataTestid\"\n        />\n      </div>\n      <div\n        v-else\n        :id=\"getRowValueId(row)\"\n        class=\"value\"\n      >\n        <div\n          v-if=\"row.status\"\n          :class=\"['status', row.status]\"\n        />\n        <router-link\n          v-if=\"row.value && row.to\"\n          :to=\"row.to\"\n          :data-testid=\"row.valueDataTestid\"\n        >\n          {{ row.value }}\n        </router-link>\n        <span\n          v-else-if=\"row.value\"\n          :data-testid=\"row.valueDataTestid\"\n          tabindex=\"0\"\n          :aria-label=\"row.value\"\n        >{{ row.value }}</span>\n        <span\n          v-else\n          class=\"text-muted\"\n          :data-testid=\"row.valueDataTestid\"\n        >&mdash;</span>\n      </div>\n    </div>\n  </div>\n</template>\n\n<style lang=\"scss\" scoped>\n.identifying-information {\n    display: flex;\n    flex-direction: column;\n\n    .row {\n      margin-bottom: 8px;\n\n      .full-custom-value {\n        flex: 1;\n      }\n\n      .value {\n        display: flex;\n        flex-direction: row;\n        align-items: center;\n        flex: 1;\n\n        & > div, & > span {\n          max-width: 100%;\n        }\n\n        &, & > div, & > span {\n          @include clip;\n        }\n      }\n\n      .label {\n        width: 30%;\n        min-width: 120px;\n      }\n\n      .status {\n        display: inline-block;\n        $size: 8px;\n        border-radius: 50%;\n        width: $size;\n        height: $size;\n        margin-right: 12px;\n\n        &.success {\n          background-color: var(--success);\n        }\n\n        &.warning {\n          background-color: var(--warning);\n        }\n\n        &.error {\n          background-color: var(--error);\n        }\n\n        &.info {\n          background-color: var(--info);\n        }\n      }\n\n    }\n\n}\n</style>\n"]}]}