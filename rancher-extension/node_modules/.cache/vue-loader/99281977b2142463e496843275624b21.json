uleTarget\n              ref=\"lastTarget\"\n              v-model:value=\"props.row.value\"\n              :mode=\"mode\"\n              :type=\"type\"\n              :namespace=\"namespace\"\n              :data-testid=\"`policy-rule-target-${props.i}`\"\n            />\n          </template>\n        </ArrayListGrouped>\n      </div>\n    </div>\n    <div class=\"row mb-20\">\n      <div class=\"col span-12\">\n        <h2>\n          {{ t('networkpolicy.rules.ports.label') }}\n          <i\n            v-clean-tooltip=\"t(`networkpolicy.${type}.portHint`)\"\n            class=\"icon icon-info\"\n          />\n        </h2>\n        <ArrayListGrouped\n          v-model:value=\"value.ports\"\n          :add-label=\"t('networkpolicy.rules.addPort')\"\n          :default-add-value=\"{}\"\n          :mode=\"mode\"\n        >\n          <template #default=\"props\">\n            <PolicyRulePort\n              ref=\"lastPort\"\n              v-model:value=\"props.row.value\"\n              :mode=\"mode\"\n            />\n          </template>\n        </ArrayListGrouped>\n      </div>\n    </div>\n  </div>\n</template>\n"]}]}