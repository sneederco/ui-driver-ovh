nimport CopyToClipboard from '@shell/components/CopyToClipboard';\nimport { mapGetters } from 'vuex';\nexport default {\n  components: { CopyToClipboard },\n  props:      {\n    row: {\n      type:     Object,\n      required: true\n    },\n  },\n  computed: {\n    internalSameAsExternal() {\n      return this.row.internalIp === this.row.externalIp;\n    },\n    ...mapGetters({ t: 'i18n/t' })\n  },\n  methods: {\n    isIp(ip) {\n      return ip && (isV4Format(ip) || isV6Format(ip));\n    }\n  }\n};\n</script>\n\n<template>\n  <span>\n    <template v-if=\"isIp(row.externalIp)\">\n      {{ row.externalIp }} <CopyToClipboard\n        :aria-label=\"t('internalExternalIP.copyExternalIp')\"\n        label-as=\"tooltip\"\n        :text=\"row.externalIp\"\n        class=\"icon-btn\"\n        action-color=\"bg-transparent\"\n      />\n    </template>\n    <template v-else>\n      -\n    </template>\n    /\n    <template v-if=\"internalSameAsExternal && isIp(row.internalIp)\">\n      {{ t('tableHeaders.internalIpSameAsExternal') }}\n    </template>\n    <template v-else-if=\"isIp(row.internalIp)\">\n      {{ row.internalIp }}<CopyToClipboard\n        :aria-label=\"t('internalExternalIP.copyInternalIp')\"\n        label-as=\"tooltip\"\n        :text=\"row.internalIp\"\n        class=\"icon-btn\"\n        action-color=\"bg-transparent\"\n      />\n    </template>\n    <template v-else>\n      -\n    </template>\n  </span>\n</template>\n\n<style lang='scss' scoped>\n.icon-btn {\n  margin-left: 8px;\n}\n</style>\n"]}]}