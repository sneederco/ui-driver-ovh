ed')\"\n      />\n    </template>\n\n    <div>\n      <div\n        v-for=\"(glanceItem, i) in props.resource.glance\"\n        :key=\"glanceItem.label\"\n        class=\"row\"\n      >\n        <label\n          class=\"label text-deemphasized\"\n          :for=\"getGlanceItemValueId(glanceItem)\"\n        >\n          {{ glanceItem.label }}\n        </label>\n        <div\n          :id=\"getGlanceItemValueId(glanceItem)\"\n          class=\"value\"\n        >\n          <component\n            :is=\"glanceItem.formatter\"\n            v-if=\"glanceItem.formatter\"\n            v-bind=\"glanceItem.formatterOpts\"\n            :id=\"i === 0 ? 'first-glance-item' : undefined\"\n            :value=\"glanceItem.content\"\n          />\n          <span\n            v-else\n            :id=\"i === 0 ? 'first-glance-item' : undefined\"\n          >\n            {{ glanceItem.content }}\n          </span>\n        </div>\n      </div>\n    </div>\n  </Card>\n</template>\n\n<style lang=\"scss\" scoped>\n.resource-popover-card {\n  width: 288px;\n\n  .dropdown-item {\n    display: inline-block;\n    padding: 0;\n    margin: 0;\n    border: none;\n\n    &:hover {\n      background: none;\n    }\n  }\n\n  &:deep() {\n    .badge-state {\n      height: 20px;\n      font-size: 12px;\n    }\n\n    .heading {\n      height: 24px;\n\n      .title {\n        font-size: 16px;\n        font-weight: 600;\n        line-height: 24px;\n      }\n    }\n\n    .v-popper, .btn.role-link {\n      height: 24px;\n      min-height: initial;\n      padding: 0;\n    }\n\n    .v-popper {\n      padding: 0;\n    }\n\n    .btn.role-link {\n      color: #141419;\n      padding: 0 12px;\n      i {\n        display: inline-flex;\n        justify-content: center;\n        font-size: 12px;\n        width: 2.5px;\n      }\n\n      &:hover {\n        background-color: transparent\n      }\n    }\n  }\n\n  .row {\n    display: flex;\n    flex-direction: row;\n    line-height: 21px;\n\n    &:not(:first-of-type) {\n      margin-top: 4px;\n    }\n\n    .label {\n      width: 50%;\n    }\n  }\n}\n</style>\n"]}]}