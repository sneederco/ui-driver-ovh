eProduct?.afterLoginRoute, this.$router)) {\n      return this.$router.replace(isSingleProduct.afterLoginRoute);\n    }\n\n    return this.$router.replace(dashboardHome);\n  }\n};\n</script>\n<template>\n  <div />\n</template>\n"]}]}