border);\n            background: var(--rc-active-disabled-background);\n            color: var(--rc-disabled-text-color);\n\n            cursor: not-allowed;\n        }\n    }\n\n    &.inactive {\n        background: var(--rc-inactive-background);\n        border-color: var(--rc-inactive-border);\n\n        &.disabled {\n            border-color: var(--rc-inactive-disabled-border);\n            color: var(--rc-disabled-text-color);\n        }\n    }\n}\n</style>\n"]}]}