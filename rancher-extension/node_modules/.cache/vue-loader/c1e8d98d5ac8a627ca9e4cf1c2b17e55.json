/div>\r\n      <div class=\"col span-6\">\r\n        <LabeledInput\r\n          v-model:value=\"value.tls_config.key_file\"\r\n          :mode=\"mode\"\r\n          :label=\"t('monitoring.receiver.tls.keyFilePath.label')\"\r\n          :placeholder=\"t('monitoring.receiver.tls.keyFilePath.placeholder')\"\r\n        />\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n"]}]}