le logout\n        await this.$store.dispatch('auth/logout', { force: true }, { root: true });\n      }\n    } else {\n      // simple logout\n      await this.$store.dispatch('auth/logout', { force: true }, { root: true });\n    }\n  }\n};\n</script>\n\n<template>\n  <main\n    class=\"main-layout\"\n    :aria-label=\"t('layouts.logout')\"\n  >\n    <div>\n      <h1 v-t=\"'logout.message'\" />\n    </div>\n  </main>\n</template>\n<style lang=\"scss\" scoped>\n  main > div {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    height: 100vh;\n  }\n</style>\n"]}]}