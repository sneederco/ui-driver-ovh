\n\nexport default {\n  name: 'DetailClusterGroup',\n\n  emits: ['input'],\n\n  components: {\n    Loading,\n    ResourceTabs,\n    ResourcesSummary,\n    FleetClusters,\n    Tab,\n  },\n\n  props: {\n    value: {\n      type:     Object,\n      required: true,\n    },\n  },\n\n  async fetch() {\n    const hash = {\n      workspaces:    this.$store.dispatch('cluster/findAll', { type: FLEET.WORKSPACE }),\n      FleetClusters: this.$store.dispatch('management/findAll', { type: FLEET.CLUSTER }),\n    };\n\n    await allHash(hash);\n  },\n\n  computed: {\n    clusterSchema() {\n      return this.$store.getters['management/schemaFor'](FLEET.CLUSTER);\n    }\n  }\n};\n</script>\n\n<template>\n  <Loading v-if=\"$fetchState.pending\" />\n  <div v-else>\n    <h2 class=\"mt-20\">\n      Resource Summary\n    </h2>\n    <ResourcesSummary :value=\"value.status.resourceCounts\" />\n\n    <ResourceTabs\n      :value=\"value\"\n      mode=\"view\"\n      class=\"mt-20\"\n      @input=\"$emit('input', $event)\"\n    >\n      <Tab\n        label=\"Clusters\"\n        name=\"clusters\"\n      >\n        <FleetClusters\n          :schema=\"clusterSchema\"\n          :rows=\"value.targetClusters\"\n          :paging=\"true\"\n          :table-actions=\"false\"\n          :search=\"false\"\n          paging-label=\"sortableTable.paging.resource\"\n        />\n      </Tab>\n    </ResourceTabs>\n  </div>\n</template>\n"]}]}