{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/dialog/ForceMachineRemoveDialog.vue?vue&type=style&index=0&id=f13f46b6&lang=scss&scoped=true","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/dialog/ForceMachineRemoveDialog.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/css-loader/dist/cjs.js","mtime":1773048121362},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/stylePostLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/postcss-loader/dist/cjs.js","mtime":1773048124224},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/postcss-loader/dist/cjs.js","mtime":1773048124224},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/sass-loader/dist/cjs.js","mtime":1773048121092},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:CiAgLmFjdGlvbnMgewogICAgdGV4dC1hbGlnbjogcmlnaHQ7CiAgfQo="},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/dialog/ForceMachineRemoveDialog.vue"],"names":[],"mappings":";EAkIE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE;IACP,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC;EACnB","file":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/dialog/ForceMachineRemoveDialog.vue","sourceRoot":"","sourcesContent":["<script>\nimport { mapGetters } from 'vuex';\nimport { exceptionToErrorsArray } from '@shell/utils/error';\nimport { alternateLabel } from '@shell/utils/platform';\nimport AsyncButton from '@shell/components/AsyncButton';\nimport { Banner } from '@components/Banner';\nimport { Card } from '@components/Card';\nimport CopyToClipboardText from '@shell/components/CopyToClipboardText';\n\nexport default {\n  emits: ['close'],\n\n  components: {\n    AsyncButton,\n    Banner,\n    Card,\n    CopyToClipboardText\n  },\n\n  props: {\n    machine: {\n      type:    Object,\n      default: () => {\n        return {};\n      }\n    }\n  },\n\n  data() {\n    return { errors: [], confirmName: '' };\n  },\n\n  computed: {\n    ...mapGetters({ t: 'i18n/t' }),\n\n    nameToMatch() {\n      return this.machine?.spec?.infrastructureRef?.name;\n    },\n\n    deleteDisabled() {\n      const confirmFailed = this.confirmName !== this.nameToMatch;\n\n      return this.preventDelete || confirmFailed;\n    },\n\n    protip() {\n      return this.t('promptRemove.protip', { alternateLabel });\n    },\n  },\n\n  methods: {\n    close() {\n      this.confirmName = '';\n      this.errors = [];\n      this.$emit('close');\n    },\n\n    async remove(buttonDone) {\n      try {\n        await this.machine.forceMachineRemove();\n        buttonDone(true);\n        this.close();\n      } catch (e) {\n        this.errors = exceptionToErrorsArray(e);\n        buttonDone(false);\n      }\n    }\n  }\n};\n</script>\n\n<template>\n  <Card\n    class=\"prompt-restore\"\n    :show-highlight-border=\"false\"\n  >\n    <template #title>\n      <h4 class=\"text-default-text\">\n        {{ t('promptForceRemove.modalTitle') }}\n      </h4>\n    </template>\n    <template #body>\n      <div class=\"pl-10 pr-10\">\n        <span\n          v-clean-html=\"t('promptForceRemove.removeWarning', { nameToMatch }, true)\"\n        />\n        <div class=\"mt-10 mb-10\">\n          {{ t('promptForceRemove.confirmName') }}\n        </div>\n        <div class=\"mb-10\">\n          <CopyToClipboardText\n            :aria-label=\"t('promptForceRemove.ariaLabel')\"\n            :text=\"nameToMatch\"\n          />\n        </div>\n        <input\n          id=\"confirm\"\n          v-model=\"confirmName\"\n          type=\"text\"\n        >\n        <div class=\"text-info mt-20\">\n          {{ protip }}\n        </div>\n        <Banner\n          v-for=\"(error, i) in errors\"\n          :key=\"i\"\n          class=\"\"\n          color=\"error\"\n          :label=\"error\"\n        />\n      </div>\n    </template>\n    <template #actions>\n      <button\n        class=\"btn role-secondary mr-10\"\n        @click=\"close\"\n      >\n        {{ t('generic.cancel') }}\n      </button>\n      <AsyncButton\n        mode=\"delete\"\n        class=\"btn bg-error ml-10\"\n        :disabled=\"deleteDisabled\"\n        @click=\"remove\"\n      />\n    </template>\n  </Card>\n</template>\n\n<style lang='scss' scoped>\n  .actions {\n    text-align: right;\n  }\n</style>\n"]}]}