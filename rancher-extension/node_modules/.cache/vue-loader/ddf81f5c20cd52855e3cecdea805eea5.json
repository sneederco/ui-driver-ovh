{"remainingRequest":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js??ruleSet[0].use[1]!/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/Scale.vue?vue&type=style&index=0&id=3f612187&lang=scss","dependencies":[{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/Scale.vue","mtime":1773049044048},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/css-loader/dist/cjs.js","mtime":1773048121362},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/stylePostLoader.js","mtime":1773048124128},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/postcss-loader/dist/cjs.js","mtime":1773048124224},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/postcss-loader/dist/cjs.js","mtime":1773048124224},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/sass-loader/dist/cjs.js","mtime":1773048121092},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/cache-loader/dist/cjs.js","mtime":1773048121146},{"path":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/vue-loader/dist/index.js","mtime":1773048124128}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:CiAgLmNvbC1zY2FsZSB7CiAgICBwb3NpdGlvbjogcmVsYXRpdmU7CgogICAgLnRyaWdnZXIgewogICAgICB3aWR0aDogMTAwJTsKICAgIH0KICB9CgogIC5zY2FsZSB7CiAgICBtYXJnaW46IDA7CiAgICBwYWRkaW5nOiAwOwogICAgbGluZS1oZWlnaHQ6IGluaXRpYWw7CiAgfQoK"},{"version":3,"sources":["/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/Scale.vue"],"names":[],"mappings":";EAgIE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE;IACT,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;;IAElB,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE;MACP,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC;IACb;EACF;;EAEA,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE;IACL,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC;IACT,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC;IACV,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC,CAAC;EACtB","file":"/private/tmp/ui-driver-ovh-fresh/rancher-extension/node_modules/@rancher/shell/components/formatter/Scale.vue","sourceRoot":"","sourcesContent":["<script>\nimport ProgressBarMulti from '@shell/components/ProgressBarMulti';\n\nexport default {\n  components: { ProgressBarMulti },\n\n  props: {\n    row: {\n      type:     Object,\n      required: true\n    },\n\n    col: {\n      type:    Object,\n      default: null\n    }\n  },\n\n  computed: {\n    canAdjust() {\n      const row = this.row;\n\n      if ( !row.scales ) {\n        return false;\n      }\n\n      if ( row.scales.global || row.scales.auto ) {\n        return false;\n      }\n\n      return true;\n    },\n\n    showHover() {\n      return this.row.complexScale || this.canAdjust;\n    }\n  },\n\n  methods: {\n    scaleDown() {\n      this.row.scaleDown();\n    },\n\n    scaleUp() {\n      this.row.scaleUp();\n    },\n  },\n};\n</script>\n\n<template>\n  <v-dropdown\n    :class=\"{'hand': showHover}\"\n    placement=\"top\"\n    :show-group=\"row.id\"\n    :triggers=\"showHover ? ['click'] : []\"\n    offset=\"1\"\n  >\n    <span>\n      <ProgressBarMulti\n        v-if=\"row.complexScale\"\n        :values=\"row.scaleParts\"\n      />\n      <p\n        v-if=\"row.scales && row.scales.global\"\n        class=\"scale\"\n      >Global</p>\n      <span\n        v-else\n        class=\"scale\"\n      >\n        {{ row.scales.current }}\n        <div\n          v-if=\"row.scales.auto\"\n          class=\"text-small text-muted\"\n        >\n          ({{ row.scales.desired }})\n        </div>\n        <span v-else-if=\"row.showDesiredScale\">\n          <i class=\"icon icon-chevron-right\" />\n          {{ row.scales.desired }}\n        </span>\n      </span>\n    </span>\n\n    <template #popper>\n      <div\n        v-if=\"canAdjust\"\n        class=\"text-center pb-5\"\n      >\n        <button\n          type=\"button\"\n          class=\"btn btn-sm bg-primary scale-btn\"\n          @click=\"scaleDown\"\n        >\n          <i class=\"icon icon-minus\" />\n        </button>\n        <button\n          type=\"button\"\n          class=\"btn btn-sm bg-primary scale-btn\"\n          @click=\"scaleUp\"\n        >\n          <i class=\"icon icon-plus\" />\n        </button>\n      </div>\n      <table\n        v-if=\"row.complexScale\"\n        class=\"fixed\"\n      >\n        <tbody>\n          <tr\n            v-for=\"(obj, i) in row.scaleParts\"\n            :key=\"i\"\n          >\n            <td :class=\"{'text-left': true, [obj.textColor]: true}\">\n              {{ obj.label }}\n            </td>\n            <td class=\"text-right\">\n              {{ obj.value }}\n            </td>\n          </tr>\n        </tbody>\n      </table>\n    </template>\n  </v-dropdown>\n</template>\n\n<style lang=\"scss\">\n  .col-scale {\n    position: relative;\n\n    .trigger {\n      width: 100%;\n    }\n  }\n\n  .scale {\n    margin: 0;\n    padding: 0;\n    line-height: initial;\n  }\n\n</style>\n"]}]}