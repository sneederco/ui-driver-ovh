{
  "sampleFields": [
    {
      "name": "provisioningMode",
      "label": "Provisioning Mode",
      "type": "select",
      "required": true,
      "placeholder": "Choose provisioning mode",
      "exampleValues": ["hosted-mks", "node-rke2-k3s"]
    },
    {
      "name": "mksClusterName",
      "label": "MKS Cluster Name",
      "type": "text",
      "requiredWhen": { "provisioningMode": "hosted-mks" },
      "placeholder": "prod-mks-cluster",
      "exampleValues": ["prod-mks-cluster", "dev-mks"]
    },
    {
      "name": "mksRegion",
      "label": "MKS Region",
      "type": "select",
      "requiredWhen": { "provisioningMode": "hosted-mks" },
      "placeholder": "Choose MKS region",
      "exampleValues": ["GRA", "SBG", "BHS"]
    },
    {
      "name": "mksVersion",
      "label": "Kubernetes Version",
      "type": "select",
      "requiredWhen": { "provisioningMode": "hosted-mks" },
      "placeholder": "Choose Kubernetes version",
      "exampleValues": ["1.30", "1.29"]
    },
    {
      "name": "mksNodepoolFlavor",
      "label": "Default Node Pool Flavor",
      "type": "select",
      "requiredWhen": { "provisioningMode": "hosted-mks" },
      "placeholder": "Choose node pool flavor",
      "exampleValues": ["b2-7", "c2-15", "r2-15"]
    },
    {
      "name": "mksNodepoolDesiredNodes",
      "label": "Default Node Pool Size",
      "type": "number",
      "requiredWhen": { "provisioningMode": "hosted-mks" },
      "exampleValues": [1, 3, 5]
    },
    {
      "name": "region",
      "label": "OVH Region",
      "type": "select",
      "requiredWhen": { "provisioningMode": "node-rke2-k3s" },
      "placeholder": "Choose region",
      "exampleValues": ["GRA", "SBG", "BHS"]
    },
    {
      "name": "flavor",
      "label": "Instance Flavor",
      "type": "select",
      "requiredWhen": { "provisioningMode": "node-rke2-k3s" },
      "placeholder": "Choose flavor",
      "exampleValues": ["b2-7", "c2-15", "r2-15"]
    },
    {
      "name": "image",
      "label": "Image",
      "type": "select",
      "requiredWhen": { "provisioningMode": "node-rke2-k3s" },
      "placeholder": "Choose image",
      "exampleValues": ["ubuntu-22.04", "debian-12", "rocky-9"]
    }
  ]
}
